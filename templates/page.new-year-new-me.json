      "blocks": {
        "select_KyxyD8": {
          "type": "select",
          "settings": {
            "title": "Does This Help With COPD, Asthma, Bronchitis, Or The Common Cold?",
            "content": "We designed BetterLungs® to support healthy respiratory and immune systems while keeping everyone in mind. Our ingredients have been studied extensively in many settings! With that said, no supplement can make claims regarding any diagnosis. As always, we recommend that you check with your doctor or pharmacist before starting any new dietary supplement as they have your full medical history available"
          }
        },
        "select_JPXqac": {
          "type": "select",
          "settings": {
            "title": "Is It Safe To Take COPD And/Or Asthma Medication With BetterLungs?",
            "content": "While all of our formulations are pieced together by a Doctor of Pharmacy, we recommend that you check with your doctor or pharmacist before starting any new dietary supplement as they have your full medical history available."
          }
        },
        "select_NR4XVK": {
          "type": "select",
          "settings": {
            "title": "Does This Help My Lungs If I Vape Or Smoke?",
            "content": "The ingredients in BetterLungs were selected with smokers, and their lung health, in mind. The idea for the product came from our Chief Scientist who wanted to help the smokers in his family and those with chronic bronchitis and COPD."
          }
        },
        "select_NEecx6": {
          "type": "select",
          "settings": {
            "title": "Can I Take This For Extended Periods Of Time?",
            "content": "Most of the ingredients work better the longer you take them, so definitely!"
          }
        },
        "select_RP6zix": {
          "type": "select",
          "settings": {
            "title": "How Long Does It Take For This Product To Work?",
            "content": "While some customers notice positive effects in the first few days, we tell our customers to give the product 4 weeks for maximum effect."
          }
        },
        "select_YCBXDf": {
          "type": "select",
          "settings": {
            "title": "How can I get in touch with the team?",
            "content": "If you have questions, you can give us a call at 1-877-851-8979 or email us at hello@betterbrandhealth.com."
          }
        }
