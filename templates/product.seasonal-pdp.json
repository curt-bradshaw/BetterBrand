\n                  class=\"progress-bar\"\n                  style=\"display:block;width:0; height:10px; border-radius: 5px; background:#234134;margin-bottom: 20px;\"\n                ><\/div>\n              <\/div>\n            <\/div>\n           \n              <div class=\"collapsible-content__heading\">\n                 Early Holidays Deal \n              <\/div>\n           \n<\/div>\n\n        \n<style>\nbody.temp-product-seasonal-pdp .ntg-col.product-info-col .c-t-o{\n\npadding: 20px;\n  margin-top: 20px;\n  border-radius: 5px;\n  background: #F0FFE9;\ntext-align:center !important;\n.progress-container-liner{\n         display: flex !important;\n         justify-content: center;\n         flex-direction: column;\n         position:relative;\n\n\n\n         .progress-bar {\n             margin-bottom: 0;\n             display:none;\n               position:relative;\n               background:#234134 !important;\n           }\n\n           .progress-bar-bg{\n               position: absolute;\n               content: \"\";\n               background:#FEE876;\n               width: 100%;\n               height: 10px;\n               z-index: 0;\n               top: 0;\n               border-radius: 8px;\n               display: block;\n           }\n\n           .percentage{\n             margin-top: 0;\n             margin-bottom: 10px;\n           }\n       }\n\n .collapsible-content__heading {\n\tcolor: #233F21;\n\tfont-family: Suisse_Intl_Mono !important;\n\ttext-shadow: 1px 0px 0px #ffd700;\n\tfont-size: 16px;\n\tfont-style: normal;\n\tfont-weight: 700;\n\tline-height: 25px;\n}\n\n}\n\nbody.temp-product-seasonal-pdp .ntg-col.product-info-col .c-t-o *{\ntext-align:center !important;\n}\n<\/style> \n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    const container = document.querySelector('.progress-container-liner');\n    const progressBar = container.querySelector('.progress-bar');\n    const percentageElement = container.querySelector('.percentage');\n    const targetPercentage = parseInt(container.dataset.percentage);\n    const progressColor = '#4caf50';\n\n    let currentPercentage = 100;\n    progressBar.style.background = progressColor;\n\n    function animateProgress(target, duration, onComplete) {\n      const startPercentage = currentPercentage;\n      const startTime = performance.now();\n\n      function animate(currentTime) {\n        const elapsed = currentTime - startTime;\n        const progress = Math.min(elapsed \/ duration, 1);\n\n        \/\/ Easing function for smooth animation (optional)\n        const easeProgress = progress; \/\/ Linear - you can change this to easeInOut, etc.\n\n        currentPercentage = startPercentage + (target - startPercentage) * easeProgress;\n\n        progressBar.style.width = currentPercentage + '%';\n        percentageElement.textContent = Math.round(currentPercentage);\n\n        if (progress < 1) {\n          requestAnimationFrame(animate);\n        } else {\n          currentPercentage = target;\n          progressBar.style.width = target + '%';\n          percentageElement.textContent = Math.round(target);\n          if (onComplete) onComplete();\n        }\n      }\n      requestAnimationFrame(animate);\n    }\n\n    \/\/ Start the sequence\n    animateProgress(targetPercentage, 2000, function () {\n      console.log('Reached 60%, starting countdown to 10%');\n\n      \/\/ Start decreasing to 10% after 3 minutes (180,000 milliseconds)\n      setTimeout(() => {\n        animateProgress(100, 18000000, function () {\n          console.log('Countdown complete - reached 10%');\n        });\n      }, 500); \/\/ Small delay before starting the countdown\n    });\n  });\n<\/script>"}},"icon_with_text_sea_nLqztH":{"type":"icon-with-text-sea","settings":{"page":"the-stress-of-cold-season"}}},"block_order":["text_jH9WKY","text_RFfAAA","rating_gVX7HP","text_9YakWe","text_mA9MMw","buy_buttons_cRDRTY","custom_liquid_JgfEXN","icon_with_text_sea