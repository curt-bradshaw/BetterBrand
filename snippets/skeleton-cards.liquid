<!-- start skeleton-cards (SNIPPET) -->

<style>
  .skeleton-card {
    flex: 0 0 auto;
    width: 280.13px;
    background-color: #fff;
    box-shadow: 2px 4px 12px 0 #00000017;
    padding-bottom: 10px;
    border-radius: 12px;
    height: fit-content;
    overflow: hidden;
    border: 1px solid #444;
  }
  .skeleton-card:nth-of-type(2) {
    transform: scale(1.14)
  }
  .skeleton-card > div {
    background: linear-gradient(90deg, #ccc 25%, #ececec 50%, #ccc 75%);
    background-size: 200% 200%;
    animation: pulse 2s linear infinite;
  }
  .skeleton-card__image {
    width: 100%;
    aspect-ratio: 0.925;
  }
  .skeleton-card__title {
    width: 90%;
    height: 25px;
    margin-top: 10px;
    margin-left: 10px;
    border-radius: 6px;
  }
  .skeleton-card__reviews {
    width: 75%;
    height: 25px;
    margin-top: 5px;
    margin-left: 10px;
    border-radius: 6px;
  }
  .skeleton-card__price {
    width: 25%;
    min-width: 68px;
    height: 40px;
    margin-top: 5px;
    margin-left: 10px;
    border-radius: 6px;
  }
  @keyframes pulse {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  @media (max-width: 767px) {
    .skeleton-card {
      width: 200.34px;
    }
  }
</style>


{% capture skeleton %} 
  <div class="skeleton-card">
    <div class="skeleton-card__image"></div>
    <div class="skeleton-card__title"></div>
    <div class="skeleton-card__reviews"></div>
    <div class="skeleton-card__price"></div>
  </div>
{% endcapture %}


