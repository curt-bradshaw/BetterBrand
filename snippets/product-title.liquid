<!-- start product-title.liquid (SNIPPET) -->

{% comment %} Start Shopify ID Styles {% endcomment %}
<style>
	#shopify-section-{{ section.id }} .product-title {
		color: {{ block.settings.product_title_color }};
		font-size: var(--ProductTitleFontSize);
		text-transform: var(--productTitleTransform);
		font-family: var(--bookmaniaFont);
		font-weight: 700;
		line-height: 1.2;
	}

	@media (max-width: 1019px) {
		#shopify-section-{{ section.id }} .product-title {
			font-size: var(--ProductTitleFontSizeTablet);
		}

		#shopify-section-{{ section.id }} .mobile .product-title {
			text-align: var(--product_info_mobile_direction);
		}
	}

	@media (max-width: 767px) {
		#shopify-section-{{ section.id }} .product-title {
			font-size: var(--ProductTitleFontSizeMobile);
		}
	}
</style>
{% comment %} End Shopify ID Styles {% endcomment %}
 
<style>
	.product-title {
		line-height: 1;
		font-weight: bold;
		margin-bottom: 0;
		letter-spacing: -0.8px;
    margin-bottom: 20px;
	}

	.product-title p {
		padding: 0 0;
		text-align: center;
		line-height: 22px;
		margin: 10px 0;
		color: #000;
		text-transform: uppercase;
	}

	@media (max-width: 1019px) {
		.product-title {
			text-align: center;
		}
	}

	@media (max-width: 767px) {
		.product-title {
			letter-spacing: 0px;
		}
	}
</style>

<h1 class="product-title">{{ product_title }}</h1>
