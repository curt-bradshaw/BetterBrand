<!-- start footer-layout04.liquid (SNIPPET) -->
<section
  data-section-id="{{ section.id }}"
  class="site-footer {% if settings.enabled_atc_float_box and template contains "product" %}product-page-has-float-box{% endif %}"
  data-section-type="main-footer"
>
  <h3 class="hide">Footer</h3>
  <div class="wrapper">
    <div class="half-content">
      <div class=" grid__item mobile text-center footer_img">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo_footer' -%}
            {% assign logo_max_width = block.settings.logo_max_width %}
            {% assign logo_max_height = block.settings.logo_max_height %}
            {% assign custom_dimensions = block.settings.choose_custom_dimensions %}
            <div class="half-content grid__item menu-footer-grid footer_logo mobile">
              {% if block.settings.enable_svg_logo %}
                <a
                  title="{{ block.settings.shop_logo_alt }}"
                  class="footer__logo-anchor"
                  {% if template.name contains 'index' %}
                    href="#"
                  {% else %}
                    href="/"
                  {% endif %}
                >
                  {{- block.settings.logo_svg_html -}}
                </a>
              {% elsif block.settings.logo_url != blank %}
                <a
                  title="{{ block.settings.shop_logo_alt }}"
                  class="footer__logo-anchor"
                  {% if template.name contains 'index' %}
                    href="#"
                  {% else %}
                    href="/"
                  {% endif %}
                >
                  {%-
                    render 'responsive-image' with
                    image: block.settings.logo_url,
                    alt: block.settings.logo_url.alt,
                    width: 600,
                    lazyload: true
                  -%}
                </a>
              {% else %}
                <a
                  title="{{ block.settings.shop_logo_alt }}"
                  class="footer__logo-anchor"
                  {% if template.name contains 'index' %}
                    href="#"
                  {% else %}
                    href="/"
                  {% endif %}
                >
                  {{- block.settings.shop_logo_alt -}}
                </a>
              {% endif %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'logo_footer' -%}
          <div class="half-content grid__item menu-footer-grid footer_logo no-mobile">
            {% if block.settings.enable_svg_logo %}
              <a
                class="footer__logo-anchor"
                title="{{ block.settings.shop_logo_alt }}"
                {% if template.name contains 'index' %}
                  href="#"
                {% else %}
                  href="/"
                {% endif %}
              >
                {{- block.settings.logo_svg_html -}}
              </a>
            {% elsif block.settings.logo_url != blank %}
              <a
                class="footer__logo-anchor"
                title="{{ block.settings.shop_logo_alt }}"
                {% if template.name contains 'index' %}
                  href="#"
                {% else %}
                  href="/"
                {% endif %}
              >
                {%-
                  render 'responsive-image' with
                  image: block.settings.logo_url,
                  alt: block.settings.logo_url.alt,
                  width: 400,
                  lazyload: true
                -%}
              </a>
            {% else %}
              <a
                class="footer__logo-anchor"
                title="{{ block.settings.shop_logo_alt }}"
                {% if template.name contains 'index' %}
                  href="#"
                {% else %}
                  href="/"
                {% endif %}
              >
                {{- block.settings.shop_logo_alt -}}
              </a>
            {% endif %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- for block in section.blocks -%}
        {%- if 'newsletter' == block.type -%}
          {%- if block.settings.footer_newsletter_enable -%}
            <div class="grid__item {{ column_width }}">
              {%- if block.settings.select_newsletter == 'klaviyo' and settings.enable_klaviyo_id -%}
                {%- render "newsletter-form-klaviyo" with settings: settings, klaviyo_id: settings.klaviyo_id, section_id: section.id -%}
              {%- elsif block.settings.select_newsletter == 'newsletter-default' -%}
                {%- render 'newsletter-form', section_id: section.id -%}
              {%- elsif block.settings.select_newsletter == 'newsletter-custom' -%}
                <div class="custom-html">{{ settings.custom_newsletter_html }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {% if section.settings.enable_popular_collections %}
        <div class="popular-collection-links">
          {%- for block in section.blocks -%}
            {%- if 'popular_collection' == block.type -%}
              {%- assign pop = pop | plus: 1 -%}
  
              {%- if pop == 1 -%}
                <h4 class="popular_collections_title">{{ section.settings.collection_title }}</h4>
                <div class="popular_collections_links">
              {%- endif -%}
  
              <a
                title="{{ block.settings.text_editable | strip_html | escape }}"
                id="ftr-pop_col-link-{{ block.id }}"
                href="{{ block.settings.link_popular_collection | default: '#' }}"
              >
                {%-
                  render 'responsive-image' with
                  image: block.settings.url_popular_collection,
                  width: 200,
                  lazyload: true,
                  id: index
                -%}
                {% if block.settings.text_editable != blank %}
                  <h5 class="popular_collections_text">{{ block.settings.text_editable }}</h5>
                {% endif %}
              </a>
            {%- endif -%}
          {%- endfor -%}
          {%- comment -%} Start Closing of the "popular_collections_links" tag {%- endcomment -%}
          </div>
          {%- comment -%} End Closing of the "popular_collections_links" tag {%- endcomment -%}
        </div>
      {% endif %}


      {%- assign has_info_social = false -%}
      {%- assign position_social_and_info = section.settings.position_social_and_info -%}

      {%- for block in section.blocks -%}
        {%- if 'infos' == block.type or 'social' == block.type -%}
          {%- assign has_info_social = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_info_social and position_social_and_info == 'left' -%}
        <div class="info desktop">
          <h3 class="info__contact-title">Get In Contact</h3>
          <div class="info__contact">
            {%- for block in section.blocks -%}
              {%- if 'infos' == block.type -%}
                {%- if block.settings.enable_phone != blank and settings.text_tel != blank -%}
                  <a
                    title="Telephone"
                    class="footer__business-info-tel"
                    id="ftr-info-tel"
                    href="tel:{{ settings.text_tel | replace: '+', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: ' ', '' }}"
                    target="_blank"
                  >
                    {%- render 'icon-phone' -%}
                    <span>{{ settings.text_tel }}</span>
                  </a>
                {%- endif -%}
                {%- if block.settings.enable_email != blank -%}
                  <a
                    title="E-mail"
                    class="footer__business-info-email"
                    id="ftr-info-mail"
                    href="mailto:{{ settings.text_email }}"
                    target="_blank"
                  >
                    {%- render 'icon-envelope' -%}
                    <span>{{ settings.text_email }}</span>
                  </a>
                {%- endif -%}
                {%- if block.settings.address != blank -%}
                  <a
                    title="Adress"
                    class="footer__business-info-address"
                    id="ftr-info-adress"
                    href="{%- if block.settings.address_link -%}{{ block.settings.address_link }}{%- else -%} # {%- endif -%}"
                    target="_blank"
                  >
                    {%- render 'icon-pin' -%}
                    <span>{{ block.settings.address }}</span></a
                  >
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          <div class="social-icons-net">
            {%- for block in section.blocks -%}
              {%- if 'social' == block.type -%}
                <div class="social-net">
                  {%- case block.settings.social_media -%}
                    {%- when 'icon-facebook' -%}
                      {%- assign social_link = settings['link-facebook'] -%}

                    {%- when 'icon-instagram' -%}
                      {%- assign social_link = settings['link-instagram'] -%}

                    {%- when 'icon-pinterest' -%}
                      {%- assign social_link = settings['link-pinterest'] -%}

                    {%- when 'icon-snapchat' -%}
                      {%- assign social_link = settings['link-snapchat'] -%}

                    {%- when 'icon-tumblr' -%}
                      {%- assign social_link = settings['link-tumblr'] -%}

                    {%- when 'icon-twitter' -%}
                      {%- assign social_link = settings['link-twitter'] -%}

                    {%- when 'icon-vimeo' -%}
                      {%- assign social_link = settings['link-vimeo'] -%}

                    {%- when 'icon-youtube' -%}
                      {%- assign social_link = settings['link-youtube'] -%}

                    {%- when 'icon-tiktok' -%}
                      {%- assign social_link = settings['link-tiktok'] -%}
                  {%- endcase -%}
                  <a
                    title="{{ block.settings.social_media | strip_html | escape }}"
                    aria-label="ftr-social-{{ block.id }}"
                    id="ftr-social-{{ block.id }}"
                    href="{{ social_link | default: '#' }}"
                    target="_blank"
                  >
                    {%- render 'icon-media-social' with icon: block.settings.social_media -%}
                  </a>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.enable_html_area_1 -%}
        <div class="custom-html">{{ section.settings.footer_html_area_1 }}</div>
      {%- endif -%}
    </div>
    <!-- end first half-content -->

    {%- assign menus_footer = 0 -%}
    {%- for block in section.blocks -%}
      {%- if 'menu_footer' == block.type -%}
        {%- assign menus_footer = menus_footer | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="half-content last-half direction-last-half {% if menus_footer == 1 %} center_menus {% endif %}">
      <div class="half-content__menus">
        {%- for block in section.blocks -%}
          {%- if 'menu_footer' == block.type -%}
            <nav class="half-content grid__item menu-footer-grid">
              {%- assign menu = linklists[block.settings.menu] -%}
              {%- assign menu_title = menu.title -%}

              {%- if block.settings.title != blank -%}
                {%- assign menu_title = block.settings.title -%}
              {%- endif -%}

              <h4 class="nav-title">
                {{ menu_title }}
                {% comment %} {%- render 'icon-arrow-down' -%} {% endcomment %}
              </h4>
              <ul class="no-bullets">
                {%- for link in menu.links -%}
                  <li class="footer-menu-item">
                    <a id="ftr-menu-{{ block.id }}-{{ forloop.index }}" href="{{ link.url | default: '#' }}">
                      {{- link.title -}}
                    </a>
                  </li>
                {%- endfor -%}

                {%- if shop.customer_accounts_enabled and block.settings.enable_customer_account -%}
                  {%- if customer -%}
                    <li class="footer-menu-item">
                      {%- if customer.first_name != blank -%}
                        {%- capture first_name -%}{{ customer.first_name }}{%- endcapture -%}
                        <a href="/account">{{ 'layout.customer.logged_in_as_html' | t: first_name: first_name }}</a>
                      {%- else -%}
                        <a href="/account">{{ 'layout.customer.account' | t }}</a>
                      {%- endif -%}
                    </li>
                    <li class="footer-menu-item">
                      <a href="/account/logout" id="customer_logout_link-{{ section.id }}">
                        {{- 'layout.customer.log_out' | t -}}
                      </a>
                    </li>
                  {%- else -%}
                    <li class="footer-menu-item">
                      <a href="/account/login" id="customer_login_link-{{ section.id }}">
                        {{- 'layout.customer.log_in' | t -}}
                      </a>
                    </li>
                    <li class="footer-menu-item">
                      <a href="/account/register" id="customer_register_link-{{ section.id }}">
                        {{- 'layout.customer.create_account' | t -}}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endif -%}
              </ul>
            </nav>
            {% if forloop.index == 7 %}
              <hr class="half-content__menu-divider">
            {% endif %}
          {%- endif -%}
        {%- endfor -%}
      </div>


      <div class="info mobile">
        <h3 class="info__contact-title">Get In Contact</h3>
        <div class="info__contact">
          {%- for block in section.blocks -%}
            {%- if 'infos' == block.type -%}
              {%- if block.settings.enable_phone != blank and settings.text_tel != blank -%}
                <a
                  title="Telephone"
                  class="footer__business-info-tel"
                  id="ftr-info-tel"
                  href="tel:{{ settings.text_tel | replace: '+', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: ' ', '' }}"
                  target="_blank"
                >
                  {%- render 'icon-phone' -%}
                  <span>{{ settings.text_tel }}</span>
                </a>
              {%- endif -%}
              {%- if block.settings.enable_email != blank -%}
                <a
                  title="E-mail"
                  class="footer__business-info-email"
                  id="ftr-info-mail"
                  href="mailto:{{ settings.text_email }}"
                  target="_blank"
                >
                  {%- render 'icon-envelope' -%}
                  <span>{{ settings.text_email }}</span>
                </a>
              {%- endif -%}
              {%- if block.settings.address != blank -%}
                <a
                  title="Adress"
                  class="footer__business-info-address"
                  id="ftr-info-adress"
                  href="{%- if block.settings.address_link -%}{{ block.settings.address_link }}{%- else -%} # {%- endif -%}"
                  target="_blank"
                >
                  {%- render 'icon-pin' -%}
                  <span>{{ block.settings.address }}</span></a
                >
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="social-icons-net">
          {%- for block in section.blocks -%}
            {%- if 'social' == block.type -%}
              <div class="social-net">
                {%- case block.settings.social_media -%}
                  {%- when 'icon-facebook' -%}
                    {%- assign social_link = settings['link-facebook'] -%}

                  {%- when 'icon-instagram' -%}
                    {%- assign social_link = settings['link-instagram'] -%}

                  {%- when 'icon-pinterest' -%}
                    {%- assign social_link = settings['link-pinterest'] -%}

                  {%- when 'icon-snapchat' -%}
                    {%- assign social_link = settings['link-snapchat'] -%}

                  {%- when 'icon-tumblr' -%}
                    {%- assign social_link = settings['link-tumblr'] -%}

                  {%- when 'icon-twitter' -%}
                    {%- assign social_link = settings['link-twitter'] -%}

                  {%- when 'icon-vimeo' -%}
                    {%- assign social_link = settings['link-vimeo'] -%}

                  {%- when 'icon-youtube' -%}
                    {%- assign social_link = settings['link-youtube'] -%}

                  {%- when 'icon-tiktok' -%}
                    {%- assign social_link = settings['link-tiktok'] -%}
                {%- endcase -%}
                <a
                  title="{{ block.settings.social_media | strip_html | escape }}"
                  aria-label="ftr-social-{{ block.id }}"
                  id="ftr-social-{{ block.id }}"
                  href="{{ social_link | default: '#' }}"
                  target="_blank"
                >
                  {%- render 'icon-media-social' with icon: block.settings.social_media -%}
                </a>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="credits desktop">
        <div class="wrapper">
          <p class="copyright-class" id="copyright">
            Copyright &copy; &nbsp; {{ 'now' | date: '%Y' }}
            <a id="CopyrightReserved" href="/">{{ shop.name }}</a>. {{ section.settings.text_post_copy_right }}
          </p>

          <div class="trust-badges-footer-wrapper">
            <div class="trust-badges-wrapper">
              {%- assign cols = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'trust_badges_footer' -%}
                  {%- assign cols = cols | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}

              {%- for block in section.blocks -%}
                {%- if block.type == 'trust_badges_footer' -%}
                  <div class="footer__trust-badge" id="trust-badges-img{{ block.id }}">
                    {% if block.settings.enable_img_trust_badge %}
                      {% render 'responsive-image' with image: block.settings.img_trust_badges_footer, custom_class: true, max_width: 250, active_lazy : true, id_prefix: index, size_large: 128, size_mobile: 30, size_desk: 10 %}
                    {% else %}
                      {%- if block.settings.enable_custom_trust_badge_svg -%}
                        {{ block.settings.custom_trust_badge_svg_html }}
                      {%- else -%}
                        {%- assign snippet_icon_trust_badge = 'icon-'
                          | append: block.settings.svg_trust_badge
                          | append: '.svg'
                        -%}

                        <img
                          width="60"
                          height="40"
                          id="trust-badge-footer-{{ block.id }}"
                          src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII="
                          data-src="{{ snippet_icon_trust_badge | asset_url }}"
                          alt="{{ block.settings.svg_trust_badge | escape | replace: "-" , " " | capitalize | default: 'Image without description.' }}"
                          data-class="LazyLoad"
                        >
                      {%- endif -%}
                    {%- endif -%}
                  </div>

                  {% comment %} <style scoped>
                    #trust-badges-img{{ block.id }} img,
                    #trust-badges-img{{ block.id }} svg {
                      {%- if block.settings.choose_trust_badges_dimensions == 'height' -%}
                        height: {{ block.settings.trust_badge_image_height }}px;
                        width: auto;
                      {%- else -%}
                        height: auto;
                        width: {{ block.settings.trust_badge_image_width }}px;
                      {%- endif -%}
                    }
                  </style> {% endcomment %}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>

      {%- if has_info_social and position_social_and_info == 'right' -%}
        <div class="info">
          <h3>Get In Contact</h3>
          <div class="info__contact">
            {%- for block in section.blocks -%}
              {%- if 'infos' == block.type -%}
                {%- if block.settings.enable_phone != blank -%}
                  <a
                    title="Telephone"
                    class="footer__business-info-tel"
                    id="ftr-info-tel"
                    href="tel:{{ settings.text_tel | replace: '+', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: ' ', '' }}"
                    target="_blank"
                  >
                    {%- render 'icon-phone' -%}
                    <p>{{ settings.text_tel }}</p>
                  </a>
                {%- endif -%}
                {%- if block.settings.enable_email != blank -%}
                  <a
                    title="E-mail"
                    class="footer__business-info-email"
                    id="ftr-info-mail"
                    href="mailto:{{ settings.text_email }}"
                    target="_blank"
                  >
                    {%- render 'icon-envelope' -%}
                    <p>{{ settings.text_email }}</p>
                  </a>
                {%- endif -%}
                {%- if block.settings.address != blank -%}
                  <a
                    title="Adress"
                    class="footer__business-info-address"
                    id="ftr-info-adress"
                    href="{%- if block.settings.address_link -%}{{ block.settings.address_link }}{%- else -%} # {%- endif -%}"
                    target="_blank"
                  >
                    {%- render 'icon-pin' -%}
                    <p>{{ block.settings.address }}</p>
                  </a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          <div class="social-net">
            {%- for block in section.blocks -%}
              {%- if 'social' == block.type -%}
                {%- case block.settings.social_media -%}
                  {%- when 'icon-facebook' -%}
                    {%- assign social_link = settings['link-facebook'] -%}

                  {%- when 'icon-instagram' -%}
                    {%- assign social_link = settings['link-instagram'] -%}

                  {%- when 'icon-pinterest' -%}
                    {%- assign social_link = settings['link-pinterest'] -%}

                  {%- when 'icon-snapchat' -%}
                    {%- assign social_link = settings['link-snapchat'] -%}

                  {%- when 'icon-tumblr' -%}
                    {%- assign social_link = settings['link-tumblr'] -%}

                  {%- when 'icon-twitter' -%}
                    {%- assign social_link = settings['link-twitter'] -%}

                  {%- when 'icon-vimeo' -%}
                    {%- assign social_link = settings['link-vimeo'] -%}

                  {%- when 'icon-youtube' -%}
                    {%- assign social_link = settings['link-youtube'] -%}

                  {%- when 'icon-tiktok' -%}
                    {%- assign social_link = settings['link-tiktok'] -%}
                {%- endcase -%}
                <a
                  title="{{ block.settings.social_media | strip_html | escape }}"
                  aria-label="ftr-social-{{ block.id }}"
                  id="ftr-social-{{ block.id }}"
                  href="{{ social_link | default: '#' }}"
                  target="_blank"
                >
                  {%- render 'icon-media-social' with icon: block.settings.social_media -%}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      {%- if section.settings.enable_html_area_2 -%}
        <div class="custom-html">{{ section.settings.footer_html_area_2 }}</div>
      {%- endif -%}
    </div>
  </div>
  <!-- end wrapper -->
  <div class="credits no-desktop">
    <div class="wrapper">
      <p class="copyright-class" id="copyright">
        Copyright &copy; &nbsp; {{ 'now' | date: '%Y' }}
        <a id="CopyrightReserved--no-desktop" href="/">{{ shop.name }}</a>. {{ section.settings.text_post_copy_right }}
      </p>

      <div class="trust-badges-footer-wrapper">
        <div class="trust-badges-wrapper">
          {%- assign cols = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badges_footer' -%}
              {%- assign cols = cols | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badges_footer' -%}
              <div class="footer__trust-badge" id="trust-badges-img{{ block.id }}">
                {% if block.settings.enable_img_trust_badge %}
                  {% render 'responsive-image' with image: block.settings.img_trust_badges_footer, custom_class: true, max_width: 250, active_lazy : true, id_prefix: index, size_large: 128, size_mobile: 30, size_desk: 10 %}
                {% else %}
                  {%- if block.settings.enable_custom_trust_badge_svg -%}
                    {{ block.settings.custom_trust_badge_svg_html }}
                  {%- else -%}
                    {%- assign snippet_icon_trust_badge = 'icon-'
                      | append: block.settings.svg_trust_badge
                      | append: '.svg'
                    -%}

                    <img
                      width="60"
                      height="60"
                      id="trust-badge-footer-{{ block.id }}"
                      src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII="
                      data-src="{{ snippet_icon_trust_badge | asset_url }}"
                      alt="{{ block.settings.svg_trust_badge | escape | replace: "-" , " " | capitalize | default: 'Image without description.' }}"
                      data-class="LazyLoad"
                    >
                  {%- endif -%}
                {%- endif -%}
              </div>

              {% comment %} <style scoped>
                #trust-badges-img{{ block.id }} img,
                #trust-badges-img{{ block.id }} svg {
                  {%- if block.settings.choose_trust_badges_dimensions == 'height' -%}
                    height: {{ block.settings.trust_badge_image_height }}px;
                    width: auto;
                  {%- else -%}
                    height: auto;
                    width: {{ block.settings.trust_badge_image_width }}px;
                  {%- endif -%}
                }
              </style> {% endcomment %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
  {%- if section.settings.disclaimer_text != blank -%}
    <div class="footer-disclaimer">
      <div class="footer-disclaimer__wrapper">
        <p class="footer-disclaimer__text">{{ section.settings.disclaimer_text }}</p>
      </div>
    </div>
  {%- endif -%}
</section>

<style scoped>
  {% if section.settings.enable_pc_background_opacity %}
