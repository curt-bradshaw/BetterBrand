<!-- start product-form (SNIPPET) -->
{% form 'product',
  product,
  id: 'AddToCartForm',
  class: 'form-add-to-cart jq-cart-add-product',
  enctype: 'multipart/form-data',
  data-productid: product.id
%}
  {% if product.title == 'BetterLungs® Tea' and product.variants.size > 2 %}
    <script>
      if (!new URLSearchParams(window.location.search).has('variant')) {
        window.location.replace(window.location.pathname + '?variant={{ product.variants[2].id }}');
      }
    </script>
  {% endif %}

  <!-- Begin ReCharge code -->
  {% if product.available and settings.product_enabled_recharge %}
    {% render 'subscription-product' with product as product %}
  {% endif %}
  <!-- End ReCharge code -->

  {%- assign variant = product.selected_or_first_available_variant -%}
  {%- assign price = variant.price -%}
  {%- assign show_swatch = true -%}

  {% comment %}
    {%- if product.selected_or_first_available_selling_plan_allocation.selling_plan.id -%}
      <input
        id="product-selling-plan"
        type="hidden"
        name="selling_plan"
        value="{{ product.selected_or_first_available_selling_plan_allocation.selling_plan.id }}"
      >
    {%- endif -%}
  {% endcomment %}

  {%- if settings.enable_out_of_stock_button == false and product.available == false -%}
    {%- assign show_swatch = false -%}
  {%- endif -%}

  <div class="product-variant-wrapper {% if product.variants.size == 1 %} product-variant-wrapper--hide {% endif %}">
    {% if show_swatch %}
      {%- render 'swatch-plans-static' -%}
    {% endif %}
  </div>

  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when '@app' -%}
        {% render block %}
    {% endcase %}
  {% endfor %}

  <div class="product-form-buttons-wrapper {% if product.selected_or_first_available_variant.available == false %} hide {% endif %}">
    <div
      class="product-quantity"
      {% if product.variants.size > 1 %}
        style="display: none;"
      {% endif %}
    >
      <div class="product-form-label w3_bg">Quantity</div>
      <div class="product-quantity-content">
        <div class="product-quantity-wrapper">
          <button
            id="ButtonMinus"
            aria-label="ButtonMinus"
            type="button"
            class="btn btn-minus btn--minus"
            disabled
          >
            {% render 'icon-minus-custom' %}
          </button>
          <input
            id="ProductQuantity"
            aria-label="ProductQuantity"
            class="quantity"
            name="quantity"
            value="1"
            data-max="{% if product.selected_or_first_available_variant.inventory_policy == 'continue' or product.selected_or_first_available_variant.inventory_management == blank %}-1 {% else %}{{ product.selected_or_first_available_variant.inventory_quantity }}{% endif %}"
            step="1"
            type="number"
            {% unless product.variants.size != 0 %}
              disabled="disabled"
            {% endunless %}
          >
          <button
            id="ButtonPlus"
            aria-label="ButtonPlus"
            type="button"
            class="btn btn-plus"
            {% unless product.variants.size != 0 %}
              disabled="disabled"
            {% endunless %}
          >
            {% render 'icon-plus-custom' %}
          </button>
        </div>
        <span id="StockWarning" class="stock-wrn">
          <span>Maximum Quantity</span>
          <span>Available In Stock</span>
        </span>
      </div>
    </div>

    {%- if section.settings.show_gift_card_recipient and product.gift_card? -%}
      {% render 'gift-card-recipient-form-custom', product: product, form: form, section: section %}
    {%- endif -%}

    {% if section.settings.checkbox_upsell_product != blank and section.settings.checkbox_upsell_description != blank %}
      {% comment %} Priority Processing {% endcomment %}
      {%-
        render 'priority-processing' with
        id: "priority-processing-form",
        pp_product: all_products[section.settings.checkbox_upsell_product],
        description: section.settings.checkbox_upsell_description
      -%}
      {% comment %} End Priority Processing {% endcomment %}
    {% endif %}

    {% render 'atc-button' with product: product, variant: variant %}

    {%- if settings.enable_add_to_cart_sticky and product.available -%}
      <button type="submit" class="cart-icon btn btn-add-tocart AddToCartFixed no-show" id="AddToCart3">
        {%- if variant.compare_at_price > price and section.settings.enable_new_layout -%}
          <div class="compare-btn">
            {%- assign temp = price | times: 100.0 -%}
            {%- assign temp = temp | divided_by: variant.compare_at_price -%}
            <span class="compare-add-price {% unless variant.compare_at_price > variant.price %}hide{% endunless %}">
              {%- if variant.compare_at_price > variant.price -%}
                {{ variant.compare_at_price | money }}
              {%- endif -%}
            </span>
            <span class="compare_percent"> ({{ 100 | minus: temp | round }}% OFF)</span>
          </div>
          <span class="line"></span>
        {%- endif -%}
        {%- if settings.enable_price_atc -%}
          <span class="btn-money">{{ product.price | money }} | {{ settings.add_to_cart_label }} </span>
          <span class="divisor">|</span>
        {%- endif -%}
        <span class="btn-label">{{ settings.add_to_cart_label }}</span>
        <span class="btn-svg">{%- render 'icon-cart-fill' -%}</span>
        <span class="btn-items">&#40; 1 Item &#41;</span>

        {%- if settings.atc_progress_bar -%}
          <span class="btn-progress"></span>
        {%- endif -%}
      </button>
    {%- endif -%}
    <div id="add-to-cart-error" class="add-to-cart-errors add-to-cart--error hide"></div>
  </div>

  <div
    id="button-out-of-stock"
    class="btn btn-choose-variant"
    {% if product.selected_or_first_available_variant.available %}
      style="display: none;"
    {% endif %}
  >
    <span class="btn-label">{{ settings.out_of_stock_label | default: '( out of stock )' | escape }}</span>
  </div>
  <span class="invetoryError"></span>

  <div class="product-badges">
    {% if block.settings.product_badge_icon1 %}
      <div class="product-badge-icon">
        <img src="{{ block.settings.product_badge_icon1  | img_url: 'medium' }}" alt="{{ block.settings.product_badge_icon1.alt }}" width="" height="">
      </div>
      <div class="product-badge-icon">
        <img
          src="{{ block.settings.product_badge_icon2 | img_url: 'medium' }}"
          alt="{{ block.settings.product_badge_icon2.alt }}"
          width=""
          height=""
        >
      </div>
      <div class="product-badge-icon">
        <img
          src="{{ block.settings.product_badge_icon3 | img_url: 'medium' }}"
          alt="{{ block.settings.product_badge_icon3.alt }}"
          width=""
          height=""
        >
      </div>
    {% endif %}
  </div>

  <div class="product-buy-infos">
    {%- if section.settings.enable_product_buy_infos == false %}
      style="display: none"
    {% endif %}
    <div class="product-buy-infos-item">
      <img src="{{ block.settings.product_buy_infos_icon | image_url: width: 31 }}" alt="{{ block.settings.product_buy_infos_icon.alt }}" width="" height="">
      <span>{{ block.settings.product_buy_infos_text }}</span>
    </div>
  </div>

  <div
    class="shipping-calculate"
    {% if section.settings.enable_shipping_calculate == false %}
      style="display: none"
    {% endif %}
  >
    {%- render 'shipping-calculate' with block: block -%}
  </div>

  {% comment %}
    <div class="trust-badges">
      {%- render 'trust-badges' -%}
    </div>
  {% endcomment %}
{% endform %}

<style>
  .product-buy-infos {
    display: flex;
    flex-direction: row;
    gap: 10px;
    padding: 15px 11px;
    justify-content: center;
  }

  .product-buy-infos-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .product-buy-infos-item img {
    width: 10px;
    height: 13px;
  }

  .product-quantity{
    display: {% if product.variants.size < 2 %}flex{% else %}none{% endif %};
  }

  .product-buy-infos-item span {
    font-size: 16px;
    font-weight: 400;
    line-height: 19.6px;
    color: #234134;
    font-family: 'SuisseIntlMono', sans-serif;
    width: max-content;
  }

  .product-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    height: 141px;
  }

  .product-badge-icon {
    max-width: 149px;
    max-height: 141px;
  }

  .product-badges img {
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 1024px) {
  }

  @media screen and (max-width: 1019px) {
    .product-badges {
      width: 100%;
      height: auto;
    }
  }

  @media screen and (max-width: 767px) {
    .product-badges {
      margin-top: 15px;
      margin-bottom: 15px;
    }
    .product-buy-infos {
      padding-top: 0;
      font-size: 14px;
    }
  }
</style>
