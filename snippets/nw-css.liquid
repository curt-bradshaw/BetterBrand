{% style %}

.BAD-product-wrapper .ntg-product-detail-intro{
    display:none;
}
    cart-drawer.is-empty .drawer__inner-empty .drawer__header{
        display: flex !important;
    }
    cart-drawer .drawer__inner {
        overflow-y: hidden;
        overflow-x: hidden;
        width: 50rem;
        padding: 0px;
        max-width: 100vw;
    }
    cart-drawer .drawer__header {
        padding: 10px 20px;
        border-bottom: 1px solid #e3e3e3;
    }
    cart-drawer .drawer__header .drawer__heading {
        margin: 0px;
        font-size: 16px;
        word-spacing: 3px;
        color: #1e1e1e;
        text-transform: uppercase;
        font-weight: bold;
        line-height: 30px;
    }
    cart-drawer.is-empty .drawer__inner {
        align-items: flex-start !important;
        grid-template-rows: auto !important;
    }
    cart-drawer .drawer__header .drawer__close {
        width: 3rem;
        height: 3rem;
        min-width: unset;
        min-height: unset;
        top: auto;
        right: -10px;
        position: relative;
    }
    cart-drawer .drawer__header .drawer__close svg.icon {
        width: 12px;
        height: auto;
        color: #000;
        stroke: currentColor;
    }
    .drawer__inner-empty~* {
        display: none;
    }
    .free_shipping_cover {
        text-align: center;
        padding: 10px 20px 20px;
        border-bottom: 1px solid #eee;
    }
    .free_shipping_lable {
        font-size: 12px;
        font-weight: 400;
        line-height: 17px;
        color: #234134;
        margin-top: 10px;
        line-height: 17px;
    }
    .free_shipping_lable strong {
        color: #234134;
        font-weight: 600;
    }
    .free_shipping_bar {
        width: 100%;
        background: #eaeaea;
        height: 10px;
        position: relative;
        margin-top: 8px;
    }
    .free_shipping_bar span {
        background: #234134;
        height: 100%;
        position: absolute;
        left: 0;
    }
    .drawer__inner-empty {
        padding: 0px !important;
    }
    cart-drawer .cart-drawer__warnings {
        justify-content: flex-start;
        overflow-y: auto;
    }
    cart-drawer .cart-drawer__empty-content {
        padding: 40px 20px;
        border-bottom: 1px solid #eee;
    }
    .cart-drawer__empty-content .cart__empty-text,
    .drawer__upsell-header h3 {
        text-transform: uppercase;
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
        font-size: 16px;
        font-weight: 700;
        margin: 20px 0px;
    }
    .drawer__upsell-header h3{
        margin-top: 0px;
    }
    .cart-drawer__empty-content .ntg-btn {
        width: 90%;
        text-transform: uppercase !important;
    }
    .drawer__upsell {
        padding: 40px 20px;
    }
    .drawer__upsell-item {
        background: #f0ffe9;
        border: none !important;
        margin: 0 0 10px !important;
        padding: 15px 10px !important;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }
    .drawer__upsell-item-image {
        width: 90px;
    }
    .drawer__upsell-item-image :is(a,img) {
        display: block;
    }
    .drawer__upsell-item-image a {
        max-width: 67px;
        margin: auto;
    }
    .drawer__upsell-item-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .drawer__upsell-item-content {
        flex: 1;
        padding: 0px 20px 0px 5px;
        text-align: left;
    }
    .drawer__upsell-item-button{
        width: 80px;
    }
    .drawer__upsell-item-button .button::before,
    .drawer__upsell-item-button .button::after{
        display: none;
    }
    .drawer__upsell-item-button .button {
        background: #234134;
        color: #fff;
        border: none;
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
        padding: 7px 5px !important;
        font-size: 11px !important;
        min-height: unset;
        width: 100%;
        min-width: unset;
        border-radius: 5px;
        letter-spacing: 0px;
    }
    .drawer__upsell-item-content h4 {
        font-size: 14px;
        font-family: bookmania, Arial, Helvetica Neue, Helvetica, sans-serif;
        color: #234134;
        margin: 0px;
    }
    .drawer__upsell-item-price {
        margin-top: 5px;
        font-size: 12px;
        color: #234134;
        letter-spacing: 0.06rem;
    }
    .drawer__upsell-item-button .button.is-loading > span{
        opacity: 0;
    }
    .drawer__upsell-item-button .button .loading__spinner svg circle{
        stroke: #fff !important;
    }
    .drawer__upsell-header h3 {
        text-align: center;
    }
    .drawer__upsell-content .drawer__upsell-item {
        display: none;
    }
    .drawer__upsell-content .drawer__upsell-item:nth-child(-n+3) {
        display: flex;
    }
    cart-drawer-items .drawer__upsell {
        border-top: 1px solid #e3e3e3;
        padding: 20px;
    }
    .cart-drawer .cart-item {
        padding: 20px 0px;
        margin: 0px 20px !important; 
        column-gap: 0px !important;
        row-gap: 10px !important;
    }
    .cart-drawer .cart-item + .cart-item {
        border-top: 1px solid #e3e3e3;
    }
    .cart-drawer .cart-items thead{
        display: none;
    }
    .cart-item .cart-item__media {
        width: 9rem;
    }
    .cart-drawer .cart-items td {
        padding-top: 0px !important;
    }
    .cart-drawer .cart-item>td+td {
        padding-left: 0px !important;
    }
    .cart-drawer .cart-item__details .cart-item__name {
        font-family: bookmania, Arial, Helvetica Neue, Helvetica, sans-serif;
        font-size: 16px;
        color: #234134 !important;
        text-decoration: none;
        margin: 0 0 4px;
        letter-spacing: 0;
    }
    .cart-drawer .cart-item__details .cart-item__name + .product-option {
        display: none;
    }
    .cart-drawer .cart-item__details .product-option {
        font-size: 12px;
        color: #535353;
    }
    .cart-drawer .cart-item__totals .cart-item__price-wrapper * {
        color: #234134;
        font-size: 12px;
        letter-spacing: 0;
    }
    .cart-drawer .cart-items .cart-item__quantity quantity-input.quantity::before,
    .cart-drawer .cart-items .cart-item__quantity quantity-input.quantity::after{
        display: none;
    }
    .cart-drawer .cart-items .cart-item__quantity quantity-input.quantity{
        width: 86px;
        height: 26px;
        min-height: unset;
        border: 1px solid #e3e3e3;
    }
    .cart-drawer .cart-items .cart-item__quantity quantity-input.quantity button.quantity__button {
        width: auto;
        flex: 1;
    }
    .cart-drawer .cart-items .cart-item__quantity quantity-input.quantity .quantity__input {
        width: 28px;
        padding: 0px;
        min-width: unset;
        opacity: 1;
        color: #232323;
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
        font-size: 12px;
        font-weight: 700;
        flex: unset;
        border-left: 1px solid #e3e3e3;
        border-right: 1px solid #e3e3e3;
    }
    .cart-drawer .cart-items .cart-item__quantity quantity-input.quantity button.quantity__button svg path{
        stroke: currentColor !important;
    }
    .cart-item cart-remove-button {
        margin: 0px 0px 0px 10px !important;
    }
    .cart-item cart-remove-button .button {
        min-width: 26px;
        min-height: 26px;
    }
    cart-drawer .drawer__footer {
        background: #234134;
        color: #fff;
        padding: 35px 30px;
        border: none;
    }
    cart-drawer .drawer__inner {
        border: none !important;
    }
    .cart-drawer .drawer__footer .totals {
        margin: 0px;
        padding: 0px 0px;
        margin-bottom: 20px;
    }
    .cart-drawer .drawer__footer .totals h2.totals__total {
        font-size: 16px;
        color: #fff;
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
    }
    .cart-drawer .drawer__footer .totals .totals__total-value {
        font-size: 16px;
        color: #44BE70;
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
    }
    cart-drawer .drawer__footer .cart__ctas .button::before,
    cart-drawer .drawer__footer .cart__ctas .button::after{
        display: none;
    }
    cart-drawer .drawer__footer .cart__ctas .button {
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
        background: #f2cb49;
        color: #234134;
        border: none;
        padding: 10px;
        text-transform: uppercase;
        font-size: 18px;
        font-weight: 700;
        border-radius: 0;
        line-height: 1;
        min-height: unset;
    }
    cart-drawer .drawer__footer .cart__ctas .button span.cta-icon {
        margin-left: 5px;
    }
    cart-drawer .drawer__footer .cart__ctas .button span.cta-icon svg{
        display: block;
    }
    cart-drawer.drawer {
        z-index: 999999999999;
    }
    cart-drawer .cart-item__subscription .rebuy-button.outline {
        background: #234134;
        border: none;
        border-radius: 14px;
        padding: 11px;
        color: #fff;
        width: 100%;
        line-height: 20px;
        font-size: 14px;
        font-weight: 400;
    }
    cart-drawer .cart-item__subscription .ntg-up-row {
        display: flex;
        place-content: space-evenly;
        font-family: suisse_intl_mono, Arial, Helvetica Neue, Helvetica, sans-serif;
        align-items: center;
        margin: 0 0 10px;
        font-weight: 400;
    }
    .cart-drawer .cart-item td.cart-item__subscription {
        grid-column: 1 / 5;
    }
    .cart-drawer cart-drawer-items {
        overflow: auto;
    }
    .cart-item__subscription-dropdown select {
        background: #f0ffe9 !important;
        border: 1px solid #F0FFE9 !important;
        font-size: 12px !important;
        padding: 8px 10px !important;
        width: auto !important;
        box-shadow: unset !important;
        outline: none !important;
    }
    div#CartDrawer-CartErrors {
        display: none !important;
    }
    .cart-drawer .cart-item__details p.product-option {
        margin-bottom: 0px;
    }
    .cart-drawer .cart-item__totals .cart-item__price-wrapper {
        display: flex;
        align-items: baseline;
        gap: 5px;
    }
    @media (max-width: 749px) {
        .cart-drawer .cart-item {
            column-gap: 10px !important;
        }
        .cart-drawer .cart-item__details .cart-item__name {
            font-size: 15px;
        }
        cart-drawer .drawer__footer {
            padding: 20px 20px;
        }
        .cart-drawer .drawer__footer .totals h2.totals__total{
            font-size: 14px;
        }
        .drawer__upsell-item-image {
            width: 70px;
        }
        .drawer__upsell-item-content {
            padding: 0px 10px 0px 10px;
        }
        span.ntg-save {
            font-size: 10px;
            padding: 3px 8px 2px;
            line-height: 14px;
        }
        span.upgrade-text {
            font-size: 12px;
        }
    }
{% endstyle %}