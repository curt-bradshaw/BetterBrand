<!-- start header-searchbar-new-layout.liquid (SNIPPET) -->
<div class="header__search-form-wrapper">
  <form id="search-form" action="/search" method="get" class="header__search-form">
    <input
      class="header__search-input search-text"
      name="q"
      aria-label="search-text"
      type="text"
      id="Search-{{ search_id }}"
      value="{{ search.terms | escape }}"
      placeholder="{{ section.settings.header_searchbar_placeholder }}"
      required
    >
    <button id="SearchButton-{{ search_id }}" type="submit" class="header__search-button button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M17 17L21 21M3 11C3 13.1217 3.84285 15.1566 5.34315 16.6569C6.84344 18.1571 8.87827 19 11 19C13.1217 19 15.1566 18.1571 16.6569 16.6569C18.1571 15.1566 19 13.1217 19 11C19 8.87827 18.1571 6.84344 16.6569 5.34315C15.1566 3.84285 13.1217 3 11 3C8.87827 3 6.84344 3.84285 5.34315 5.34315C3.84285 6.84344 3 8.87827 3 11Z" stroke="#0A0A0A" style="stroke:#0A0A0A;stroke:color(display-p3 0.0392 0.0392 0.0392);stroke-opacity:1;" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>        
    </button>

    <div
      class="search-results-wrapper{% if settings.enable_page_post_suggestion %} w-80 {% endif %}"
      style="display: none;"
    >
      <div class="close-suggestions"><span class="search__terms"></span> {% render 'icon-close' %}</div>
      <div class="suggestion-half-to-half-flex">
        <div class="search-results {% if settings.enable_page_post_suggestion == false %} w-100 {% endif %}"></div>
        {% if settings.enable_page_post_suggestion %}
          <div class="search-content-container">
            <div class="search-results-pages-wrapper">
              <p class="search-section-title">Pages & Posts</p>
              <div class="search-results-pages"></div>
            </div>
          </div>
        {% endif %}
      </div>
      <div class="search-link-wrapper"></div>
    </div>
  </form>
</div>

{%- render 'header-search-suggestions-new-layout' -%}
