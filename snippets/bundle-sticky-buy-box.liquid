<script>
  /**
   * Bundle Cart Manager - Modular implementation
   * Manages bundle cart functionality with separation of concerns
   */

  // ============================================
  // CONFIGURATION & CONSTANTS
  // ============================================
  const BUNDLE_CONFIG = {
    STORAGE_KEYS: {
      CART: 'bundle-cart-products',
      INFO: 'bundle-info',
    },
    MAX_TIERS: 4,
    SCROLL_THRESHOLD: 4,
    DISCOUNT_CODE_TO_APPLY: undefined,
  };

  const PROGRESS_TIERS = [
    {
      title: '{{ config.tier_1_title }}',
      type: '{{ config.tier_1_type }}',
      {% if config.tier_1_type == 'price' %}
        min: parseFloat('{{ config.tier_1_min | times: 100 }}'),
      {% else %}
        min: parseFloat('{{ config.tier_1_min }}'),
      {% endif %}
      {% if config.tier_1_discount_value %}
        discount_value: parseFloat('{{ config.tier_1_discount_value | default: 0 }}'),
      {% endif %}
      discount_code: '{{ config.tier_1_discount_code }}',
      is_enabled: {{ config.enable_tier_1 }},
      element: document.querySelector('.bundle-sticky-box__bundle-header-progress-line-item[data-tier="1"]'),
    },
    {
      title: '{{ config.tier_2_title }}',
      type: '{{ config.tier_2_type }}',
      {% if config.tier_2_type == 'price' %}
        min: parseFloat('{{ config.tier_2_min | times: 100 }}'),
      {% else %}
        min: parseFloat('{{ config.tier_2_min }}'),
      {% endif %}
      {% if config.tier_2_discount_value %}
        discount_value: parseFloat('{{ config.tier_2_discount_value | default: 0 }}'),
      {% endif %}
      discount_code: '{{ config.tier_2_discount_code }}',
      is_enabled: {{ config.enable_tier_2 }},
      element: document.querySelector('.bundle-sticky-box__bundle-header-progress-line-item[data-tier="2"]'),
    },
    {
      title: '{{ config.tier_3_title }}',
      type: '{{ config.tier_3_type }}',
      {% if config.tier_3_type == 'price' %}
        min: parseFloat('{{ config.tier_3_min | times: 100 }}'),
      {% else %}
        min: parseFloat('{{ config.tier_3_min }}'),
      {% endif %}
      {% if config.tier_3_discount_value %}
        discount_value: parseFloat('{{ config.tier_3_discount_value | default: 0 }}'),
      {% endif %}
      discount_code: '{{ config.tier_3_discount_code }}',
      is_enabled: {{ config.enable_tier_3 }},
      element: document.querySelector('.bundle-sticky-box__bundle-header-progress-line-item[data-tier="3"]'),
    },
    {
      title: '{{ config.tier_4_title }}',
      type: '{{ config.tier_4_type }}',
      {% if config.tier_4_type == 'price' %}
        min: parseFloat('{{ config.tier_4_min | times: 100 }}'),
      {% else %}
        min: parseFloat('{{ config.tier_4_min }}'),
      {% endif %}
      {% if config.tier_4_discount_value %}
        discount_value: parseFloat('{{ config.tier_4_discount_value | default: 0 }}'),
      {% endif %}
      discount_code: '{{ config.tier_4_discount_code }}',
      is_enabled: {{ config.enable_tier_4 }},
      element: document.querySelector('.bundle-sticky-box__bundle-header-progress-line-item[data-tier="4"]'),
    },
  ];

  // ============================================
  // STORAGE MODULE
  // ============================================
  const Storage = {
    getCart() {
      const saved = localStorage.getItem(BUNDLE_CONFIG.STORAGE_KEYS.CART);
      return saved ? JSON.parse(saved) : [];
    },

    saveCart(products) {
      localStorage.setItem(BUNDLE_CONFIG.STORAGE_KEYS.CART, JSON.stringify(products));
    },

    clearCart() {
      localStorage.removeItem(BUNDLE_CONFIG.STORAGE_KEYS.CART);
    },

    saveBundleInfo(info) {
      localStorage.setItem(BUNDLE_CONFIG.STORAGE_KEYS.INFO, JSON.stringify(info));
    },
  };

  // ============================================
  // DOM SELECTORS MODULE
  // ============================================
  const DOM = {
    getProductsContainer() {
      return document.getElementById('bundle-products-container');
    },

    getProgressBarFill() {
      return document.querySelector('.bundle-sticky-box__bundle-header-progress-line-inner-fill');
    },

    getProgressText() {
      return document.querySelector('.bundle-sticky-box__bundle-header-progress-text');
    },

    getCheckoutButton() {
      return document.querySelector('.bundle-sticky-box__checkout-btn');
    },

    getCheckoutText() {
      return document.querySelector('.bundle-sticky-box__checkout-text');
    },

    getEmptyCart() {
      return document.querySelector('.bundle-sticky-box__empty-cart');
    },

    getPricingContainer() {
      return document.getElementById('pricing-summary-container');
    },

    getFinalSubtotal() {
      return document.getElementById('final-subtotal');
    },

    getFinalSubtotalOriginal() {
      return document.getElementById('final-subtotal-original');
    },

    getProductElement(productId) {
      return document.querySelector(`.bundle-sticky-box__product-item[data-product-id="${productId}"]`);
    },
  };

  // ============================================
  // UTILITIES MODULE
  // ============================================
  const Utils = {
    formatMoney(cents) {
      cents = Number(cents) || 0;
      if (!Number.isInteger(cents)) {
        cents = Math.round(cents);
      }

      const value = (cents / 100).toFixed(2);
      const finalValue = `$${value}`;

      return finalValue;
    },

    parseMoney(formatted) {
      if (!formatted) {
        return 0;
      }

      const parsed = Math.round(Number(formatted.replace(/[^0-9.-]/g, '')) * 100);

      return parsed;
    },

    generateBundleId() {
      const id = Date.now().toString(36) + Math.random().toString(36).substr(2, 4);

      return id;
    },
  };

  // ============================================
  // CALCULATOR MODULE
  // ============================================
  const Calculator = {
    getOriginalTotal(products) {
      return products.reduce((sum, product) => {
        const price = Number(product.price);
        const quantity = Number(product.quantity) || 1;

        return sum + price * quantity;
      }, 0);
    },

    getCurrentTotal(products) {
      return products.reduce((sum, product) => {
        const price = Number(product.price);
        const quantity = Number(product.quantity) || 1;

        return sum + price * quantity;
      }, 0);
    },

    getBundleDiscountPercentage(totalQuantity, totalPrice) {
      let currentTier = undefined;
      for (const tier of PROGRESS_TIERS) {
        if (!tier.is_enabled) continue;
        if (tier.type === 'quantity') {
          if (totalQuantity >= tier.min) {
            currentTier = tier;
          }
        } else {
          if (totalPrice >= tier.min) {
            currentTier = tier;
          }
        }
      }

      if (!currentTier || !currentTier.discount_value) {
        return 0;
      }

      return currentTier.discount_value;
    },

    calculateTotals(products) {
      const totalQuantity = products.reduce((sum, p) => sum + (Number(p.quantity) || 1), 0);
      const totalPrice = this.getCurrentTotal(products);

      const originalTotal = this.getOriginalTotal(products);
      const currentTotal = this.getCurrentTotal(products);
      const bundleDiscountPercentage = this.getBundleDiscountPercentage(totalQuantity, totalPrice);
      const bundleDiscountAmount = Math.round((currentTotal * bundleDiscountPercentage) / 100);
      const finalTotal = currentTotal - bundleDiscountAmount;
      const productDiscount = originalTotal - currentTotal;
      const totalDiscount = productDiscount + bundleDiscountAmount;

      return {
        originalSubtotal: originalTotal,
        currentSubtotal: currentTotal,
        finalSubtotal: finalTotal,
        productDiscount,
        bundleDiscount: bundleDiscountAmount,
        totalDiscount,
        bundleDiscountPercentage,
        totalQuantity,
      };
    },
  };

  // ============================================
  // PROGRESS BAR MODULE
  // ============================================
  const ProgressBar = {
    getEnabledTiersCount() {
      return PROGRESS_TIERS.filter((tier) => {
        const enabled = tier.is_enabled;
        return enabled !== false && enabled !== 'false' && enabled !== '';
      }).length;
    },

    updateTierState(tier, isActive) {
      if (!tier || tier.is_enabled === false || !tier.element) return;

      const className = 'bundle-sticky-box__bundle-header-progress-line-item--active';
      tier.element.classList.toggle(className, isActive);
    },

    showDiscountBadge(tier, isActive) {
      const badgeDiscount = document.querySelector('.bundle-sticky-box__badge-discount');
      if (!badgeDiscount || !tier.discount_value) return;

      badgeDiscount.classList.toggle('bundle-sticky-box__badge-discount--visible', isActive);
      if (tier.is_free_shipping) {
        badgeDiscount.textContent = 'Free Shipping';
      } else {
        badgeDiscount.textContent = `${tier.discount_value}% OFF`;
      }
    },

    removeDiscountBadge() {
      const badgeDiscount = document.querySelector('.bundle-sticky-box__badge-discount');
      if (badgeDiscount) {
        badgeDiscount.classList.remove('bundle-sticky-box__badge-discount--visible');
      }
    },

    updateProgressText(activeTiers) {
      const progressText = DOM.getProgressText();
      if (!progressText) return;

      progressText.textContent = `You've reached ${activeTiers} of 4 tiers`;
    },

    calculateActiveTiers(products, totals) {
      const quantity = products.reduce((sum, p) => sum + (Number(p.quantity) || 1), 0);
      const subtotal = Utils.parseMoney(Utils.formatMoney(totals.currentSubtotal));
      let activeCount = 0;

      PROGRESS_TIERS.forEach((tier) => {
        const enabled = tier.is_enabled;
        if (enabled === false || enabled === 'false' || enabled === '') return;

        const isActive = tier.type === 'quantity' ? quantity >= tier.min : subtotal >= tier.min;

        if (isActive) {
          BUNDLE_CONFIG.DISCOUNT_CODE_TO_APPLY = tier.discount_code || undefined;
          this.showDiscountBadge(tier, isActive);
        }


        this.updateTierState(tier, isActive);
        if (isActive) activeCount++;
      });

      if (activeCount === 0) {
        this.removeDiscountBadge();
      }

      return activeCount;
    },

    updateFillWidth(activeTiers) {
      const fillElement = DOM.getProgressBarFill();
      if (!fillElement) {
        console.warn('Progress bar fill element not found');
        return;
      }

      const enabledTiersCount = this.getEnabledTiersCount();
      if (enabledTiersCount === 0) {
        fillElement.style.setProperty('--progress-bar-color-filled-width', '0%');
        return;
      }

      const percentage = Math.min(100, Math.max(0, (activeTiers / enabledTiersCount) * 100));
      const percentageValue = Math.round(percentage * 100) / 100;
      const percentageString = `${percentageValue}%`;

      fillElement.style.setProperty('--progress-bar-color-filled-width', percentageString);
    },

    updateProgressText(products, totals) {
      const progressText = DOM.getProgressText();
      if (!progressText) return;

      const quantity = products.reduce((sum, p) => sum + (Number(p.quantity) || 1), 0);
      const subtotal = Utils.parseMoney(Utils.formatMoney(totals.currentSubtotal));
      let nextTier = undefined;
      let currentTier = undefined;

      for (let index = 0; index < PROGRESS_TIERS.length; index++) {
        const tier = PROGRESS_TIERS[index];
        if (tier.is_enabled === false) continue;
        const isActive = tier.type === 'quantity' ? quantity >= tier.min : subtotal >= tier.min;
        if (!isActive) {
          nextTier = tier;
          break;
        } else {
          currentTier = tier;
        }
      }

      if (nextTier) {
        const amountToReachNextTier = nextTier.type === 'quantity' ? nextTier.min - quantity : Utils.parseMoney(Utils.formatMoney(nextTier.min - subtotal));
        progressText.innerHTML = `You're only ${amountToReachNextTier}&nbsp;away from <strong>${nextTier.title}</strong>`;
      } else {
        progressText.innerHTML = `You've unlocked the maximum discount!`;
      }
    },

    update(products, totals) {
      const activeTiers = this.calculateActiveTiers(products, totals);
      this.updateFillWidth(activeTiers);
      this.updateProgressText(products, totals);
    },
  };

  // ============================================
  // PRODUCT TEMPLATE MODULE
  // ============================================
  const ProductTemplate = {
    createHTML(product, discountPercentage) {
      const pricingHTML = this.getPricingHTML(product.price, discountPercentage);

      return `
        <div class="bundle-sticky-box__product-content">
          <img
            src="${product.image}"
            alt="${product.title}"
            class="bundle-sticky-box__product-image"
          />
          <div class="bundle-sticky-box__product-info">
            <p class="bundle-sticky-box__product-title">${product.title}</p>
            <div class="bundle-sticky-box__product-quantity">
              <button class="bundle-sticky-box__product-btn-decrease" 
                ${product.quantity <= 1 ? 'disabled' : ''}
              data-product-id="${product.id}" onclick="BundleCart.updateQuantity(${product.id}, ${product.stock}, -1)">
                {% render 'minus-bundle' %}
              </button>
              <input type="number" class="bundle-sticky-box__product-quantity-value" data-product-id="${
                product.id
              }" onchange="BundleCart.updateQuantity(${product.id}, ${
        product.stock
      }, event.target.value, true)" value="${product.quantity}">
              <button class="bundle-sticky-box__product-btn-increase" ${
                product.quantity >= product.stock ? 'disabled' : ''
              } data-product-id="${product.id}" onclick="BundleCart.updateQuantity(${product.id}, ${product.stock}, 1)">
                {% render 'plus-bundle' %}
              </button>
            </div>
          </div>
          <div class="bundle-sticky-box__product-actions">
            <div class="bundle-sticky-box__product-pricing">
              ${pricingHTML}
            </div>
            <button class="bundle-sticky-box__remove-btn" data-product-id="${product.id}">Remove</button>
          </div>
        </div>
      `;
    },

    getPricingHTML(currPrice, discountPercentage) {
      let currentPrice = currPrice;
      let originalPrice = undefined;
      if (discountPercentage) {
        currentPrice = currPrice * (100 - discountPercentage) / 100;
        originalPrice = currPrice;
      }

      return `
        ${originalPrice ? `<span class="bundle-sticky-box__original-price">${Utils.formatMoney(originalPrice)}</span>` : ''}
        <span class="bundle-sticky-box__current-price">${Utils.formatMoney(currentPrice)}</span>
      `;
    },
  };

  // ============================================
  // SORT MODULE - Ordena os formulários de produtos na página
  // ============================================
  const SortModule = {
    originalOrder: new Map(),
    currentSortBy: 'manual',
    container: null,

    init() {
      const sortSelect = document.getElementById('filter-sort-by');
      if (!sortSelect) return;

      // Encontrar o container que contém os formulários
      const firstForm = document.querySelector('form.product-alternative-card-form');
      if (!firstForm) {
        // Tentar novamente após um pequeno delay caso os formulários ainda não estejam carregados
        setTimeout(() => this.init(), 100);
        return;
      }

      // Encontrar o container pai comum (pode ser um grid, flex container, etc)
      this.container = firstForm.parentElement;
      
      // Se o container não parece ser o correto, procurar por um container comum
      const allForms = document.querySelectorAll('form.product-alternative-card-form');
      if (allForms.length > 0) {
        // Verificar se todos os formulários têm o mesmo pai
        const firstParent = allForms[0].parentElement;
        const allSameParent = Array.from(allForms).every(form => form.parentElement === firstParent);
        
        if (allSameParent) {
          this.container = firstParent;
        } else {
          // Se não têm o mesmo pai, encontrar o container comum mais próximo
          let commonParent = firstParent;
          while (commonParent && commonParent !== document.body) {
            const allInParent = Array.from(allForms).filter(form => 
              commonParent.contains(form)
            );
            if (allInParent.length === allForms.length) {
              this.container = commonParent;
              break;
            }
            commonParent = commonParent.parentElement;
          }
        }
      }

      // Salvar ordem original dos formulários
      this.saveOriginalOrder();

      // Escutar mudanças no select
      sortSelect.addEventListener('change', (e) => {
        this.currentSortBy = e.target.value;
        this.applySort();
      });

      // Aplicar ordenação inicial se houver valor selecionado
      if (sortSelect.value) {
        this.currentSortBy = sortSelect.value;
        this.applySort();
      }
    },

    saveOriginalOrder() {
      const forms = document.querySelectorAll('form.product-alternative-card-form');
      this.originalOrder.clear();
      
      forms.forEach((form, index) => {
        this.originalOrder.set(form, index);
      });
    },

    parseMoney(moneyString) {
      if (!moneyString) return 0;
      // Remove currency symbols, spaces, and parse number
      // Format: "$XX.XX" or "XX.XX" or "XX,XX"
      const cleaned = moneyString.replace(/[^\d.,-]/g, '').replace(',', '.');
      return parseFloat(cleaned) || 0;
    },

    getFormData(form) {
      const titleEl = form.querySelector('.products-offers__card-title');
      const priceEl = form.querySelector('.product-card__item-price');
      const comparePriceEl = form.querySelector('.product-card__item-compare-at-price');
      
      return {
        form: form,
        title: titleEl ? titleEl.textContent.trim() : '',
        price: priceEl ? this.parseMoney(priceEl.textContent) : 0,
        comparePrice: comparePriceEl ? this.parseMoney(comparePriceEl.textContent) : 0,
        originalIndex: this.originalOrder.get(form) ?? Infinity,
      };
    },

    sortForms(forms) {
      if (!forms || forms.length === 0) return forms;

      const formsArray = Array.from(forms);
      const formsData = formsArray.map(form => this.getFormData(form));

      switch (this.currentSortBy) {
        case 'manual':
          // Restaurar ordem original
          return formsData.sort((a, b) => a.originalIndex - b.originalIndex).map(d => d.form);

        case 'title-ascending':
          return formsData.sort((a, b) => {
            const titleA = (a.title || '').toLowerCase();
            const titleB = (b.title || '').toLowerCase();
            return titleA.localeCompare(titleB);
          }).map(d => d.form);

        case 'title-descending':
          return formsData.sort((a, b) => {
            const titleA = (a.title || '').toLowerCase();
            const titleB = (b.title || '').toLowerCase();
            return titleB.localeCompare(titleA);
          }).map(d => d.form);

        case 'price-ascending':
          return formsData.sort((a, b) => {
            // Usar comparePrice se disponível, senão usar price
            const priceA = a.comparePrice > 0 ? a.comparePrice : a.price;
            const priceB = b.comparePrice > 0 ? b.comparePrice : b.price;
            return priceA - priceB;
          }).map(d => d.form);

        case 'price-descending':
          return formsData.sort((a, b) => {
            // Usar comparePrice se disponível, senão usar price
            const priceA = a.comparePrice > 0 ? a.comparePrice : a.price;
            const priceB = b.comparePrice > 0 ? b.comparePrice : b.price;
            return priceB - priceA;
          }).map(d => d.form);

        case 'created-ascending':
          // Ordem original (mais antigo primeiro)
          return formsData.sort((a, b) => a.originalIndex - b.originalIndex).map(d => d.form);

        case 'created-descending':
          // Ordem original reversa (mais recente primeiro)
          return formsData.sort((a, b) => b.originalIndex - a.originalIndex).map(d => d.form);

        case 'best-selling':
          // Manter ordem original (não temos dados de vendas)
          return formsData.sort((a, b) => a.originalIndex - b.originalIndex).map(d => d.form);

        default:
          return formsArray;
      }
    },

    applySort() {
      // Ordenar apenas os formulários visíveis (não ocultos)
      const visibleForms = Array.from(document.querySelectorAll('form.product-alternative-card-form'))
        .filter(form => !form.classList.contains('product-alternative-card-form--hidden'));
      
      if (visibleForms.length === 0) return;

      // Se a ordem original não foi salva ainda, salvar agora
      if (this.originalOrder.size === 0) {
        this.saveOriginalOrder();
      }

      const sortedForms = this.sortForms(visibleForms);

      // Reordenar no DOM - mover cada formulário para a posição correta
      // Encontrar o container pai comum ou usar o primeiro formulário como referência
      const firstForm = visibleForms[0];
      if (!firstForm) return;

      const referenceParent = firstForm.parentElement;
      if (!referenceParent) return;

      // Reordenar movendo cada formulário para a posição correta
      sortedForms.forEach((form, index) => {
        const currentParent = form.parentElement;
        if (currentParent && currentParent === referenceParent) {
          // Se todos estão no mesmo container, simplesmente reordenar
          referenceParent.appendChild(form);
        } else if (currentParent) {
          // Se estão em containers diferentes, mover para o container de referência
          // Mas manter a estrutura se possível
          const nextSibling = sortedForms[index + 1];
          if (nextSibling && nextSibling.parentElement) {
            nextSibling.parentElement.insertBefore(form, nextSibling);
          } else {
            currentParent.appendChild(form);
          }
        }
      });
    },
  };

  // ============================================
  // UI UPDATER MODULE
  // ============================================
  const UIUpdater = {
    renderProducts(products) {
      const container = DOM.getProductsContainer();
      if (!container) return;

      // Clear existing products
      const existing = container.querySelectorAll('.bundle-sticky-box__product-item');
      existing.forEach((el) => el.remove());
      const totals = Calculator.calculateTotals(products);

      // Render all products
      products.forEach((product) => {
        const element = document.createElement('article');
        element.className = 'bundle-sticky-box__product-item';
        element.setAttribute('data-product-id', product.id);
        element.innerHTML = ProductTemplate.createHTML(product, totals.bundleDiscountPercentage);

        // Attach remove handler
        const removeBtn = element.querySelector('.bundle-sticky-box__remove-btn');
        if (removeBtn) {
          removeBtn.addEventListener('click', () => BundleCart.removeProduct(product.id));
        }

        container.insertBefore(element, container.firstChild);
      });
    },

    updateProductPrices(products, discountPercentage) {
      const container = DOM.getProductsContainer();
      if (!container) return;

      const allLineItems = container.querySelectorAll('.bundle-sticky-box__product-item');
      allLineItems.forEach((lineItem) => {
        const productId = lineItem.dataset.productId;
        const product = products.find((p) => p.id === productId);
        if (product) {
          const pricingHTML = ProductTemplate.getPricingHTML(product.price, discountPercentage);
          const pricingHTMLContainer = lineItem.querySelector('.bundle-sticky-box__product-pricing');
          if (pricingHTMLContainer) {
            pricingHTMLContainer.innerHTML = pricingHTML;
          }
        }
      });
    },

    updateCheckoutButton(products, totals) {
      const button = DOM.getCheckoutButton();
      const text = DOM.getCheckoutText();

      if (!button || !text) return;

      const isEmpty = products.length === 0;
      button.disabled = isEmpty;

      if (isEmpty) {
        text.innerHTML = 'Build Your Bundle';
      } else {
        text.innerHTML = `PROCEED TO CHECKOUT {% render 'icon-lock' %}`;
      }
    },

    updatePricing(totals) {
      const finalSubtotalEl = DOM.getFinalSubtotal();
      const finalSubtotalOriginalEl = DOM.getFinalSubtotalOriginal();
      if (finalSubtotalEl) {
        finalSubtotalEl.textContent = Utils.formatMoney(totals.finalSubtotal);
      }

      let showOriginalSubtotal = totals.finalSubtotal < totals.originalSubtotal;

      if (finalSubtotalOriginalEl) {
        finalSubtotalOriginalEl.classList.toggle('bundle-sticky-box__badge-discount-original--visible', showOriginalSubtotal);
        finalSubtotalOriginalEl.textContent = Utils.formatMoney(totals.originalSubtotal);
      }
    },

    updateVisibility(products) {
      const isEmpty = products.length === 0;
      const container = DOM.getProductsContainer();
      const emptyCart = DOM.getEmptyCart();
      const pricingContainer = DOM.getPricingContainer();

      if (container) container.style.display = isEmpty ? 'none' : 'block';
      if (emptyCart) emptyCart.style.display = isEmpty ? 'block' : 'none';
      if (pricingContainer) pricingContainer.style.display = 'block';
    },

    updateScrollState() {
      const container = DOM.getProductsContainer();
      if (!container) return;

      const items = container.querySelectorAll('.bundle-sticky-box__product-item');
      container.classList.toggle('has-scroll', items.length > BUNDLE_CONFIG.SCROLL_THRESHOLD);
    },

    updateButtonStates() {
      const cartProducts = Storage.getCart();
      const buttons = document.querySelectorAll('.bundle-add-btn');

      buttons.forEach((btn) => {
        const productId = String(btn.dataset.productId);
        const productInCart = cartProducts.find((p) => String(p.id) === productId);

        if (productInCart) {
          const currentQuantity = parseInt(productInCart.quantity) || 1;
          const maxStock = parseInt(productInCart.stock) || 999;
          const canAddMore = currentQuantity < maxStock;

          if (canAddMore) {
            btn.innerHTML = `ADD TO BUNDLE {% render 'icon-plus' %}`;
            btn.disabled = false;
            btn.style.backgroundColor = '#28a745';
          } else {
            btn.innerHTML = 'ADDED TO BUNDLE';
            btn.disabled = true;
            btn.style.backgroundColor = '#6c757d';
          }
        } else {
          btn.innerHTML = `ADD TO BUNDLE {% render 'icon-plus' %}`;
          btn.disabled = false;
          btn.style.backgroundColor = '#28a745';
        }
      });
    },
  };

  // ============================================
  // CART API MODULE
  // ============================================
  const CartAPI = {
    async addItems(items, discountCode) {
      const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items, discount_code: discountCode }),
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`Failed to add items: ${response.status} - ${errorText}`);
      }

      return response.json();
    },

    updateCartCount(count) {
      const elements = document.querySelectorAll('.header__item-cart-number');
      elements.forEach((el) => (el.textContent = count));
    },

    async openCart() {
      if (window.CartAPI?.openCartDrawer) {
        await window.CartAPI.openCartDrawer();
      } else {
        window.location.href = '/cart';
      }
    },
  };

  // ============================================
  // MAIN BUNDLE CART MODULE
  // ============================================
  const BundleCart = {
    products: Storage.getCart(),

    addProduct(productData) {
      const productId = String(productData.id);
      const existingProduct = this.products.find((p) => String(p.id) === productId);

      if (existingProduct) {
        const maxStock = parseInt(existingProduct.stock) || 999;
        const currentQuantity = parseInt(existingProduct.quantity) || 1;
        
        if (currentQuantity < maxStock) {
          existingProduct.quantity = currentQuantity + 1;
        }
      } else {
        this.products.push(productData);
      }

      Storage.saveCart(this.products);
      this.updateUI();
    },

    removeProduct(productId) {
      this.products = this.products.filter((p) => p.id !== productId);
      Storage.saveCart(this.products);

      const element = DOM.getProductElement(productId);
      if (element) element.remove();

      this.updateUI();
    },

    updateQuantity(productId, stock, value, isInput = false) {
      const quantity = parseInt(value);
      const maxStock = parseInt(stock);
      const productIdStr = String(productId);
      const inputElement = document.querySelector(
        `.bundle-sticky-box__product-quantity-value[data-product-id="${productId}"]`
      );
      const plusButton = document.querySelector(
        `.bundle-sticky-box__product-btn-increase[data-product-id="${productId}"]`
      );
      const minusButton = document.querySelector(
        `.bundle-sticky-box__product-btn-decrease[data-product-id="${productId}"]`
      );

      const product = this.products.find((p) => p.id === productIdStr);
      if (!product) return;

      let newQuantity = product.quantity;

      if (!isInput && quantity === -1) {
        newQuantity -= 1;
      }

      if (!isInput && quantity === 1) {
        newQuantity += 1;
      }

      if (isInput) {
        newQuantity = quantity;
      }

      if (newQuantity >= maxStock) {
        plusButton.disabled = true;
      } else {
        plusButton.disabled = false;
      }

      if (newQuantity <= 1) {
        minusButton.disabled = true;
      } else {
        minusButton.disabled = false;
      }

      newQuantity = Math.max(1, Math.min(newQuantity, maxStock));

      product.quantity = newQuantity;

      inputElement.value = product.quantity;
      Storage.saveCart(this.products);
      const totals = Calculator.calculateTotals(this.products);
      UIUpdater.updatePricing(totals);
      UIUpdater.updateButtonStates();
      UIUpdater.updateProductPrices(this.products, totals.bundleDiscountPercentage);
      UIUpdater.updateCheckoutButton(this.products, totals);
      ProgressBar.update(this.products, totals);
    },

    updateUI() {
      const totals = Calculator.calculateTotals(this.products);

      ProgressBar.update(this.products, totals);
      UIUpdater.renderProducts(this.products);
      UIUpdater.updateCheckoutButton(this.products, totals);
      UIUpdater.updatePricing(totals);
      UIUpdater.updateVisibility(this.products);
      UIUpdater.updateScrollState();
      UIUpdater.updateButtonStates();
    },


    async addToCart() {
      if (this.products.length === 0) {
        alert('Your bundle is empty!');
        return;
      }

      const button = DOM.getCheckoutButton();
      if (button) {
        button.disabled = true;
        button.classList.add('loading');
      }

      try {
        const totals = Calculator.calculateTotals(this.products);
        const bundleId = Utils.generateBundleId();

        Storage.saveBundleInfo({
          bundleId,
          products: this.products,
          totals,
          timestamp: Date.now(),
        });

        const items = this.products
          .map((product) => {
            const variantId = parseInt(product.id);
            if (isNaN(variantId) || variantId <= 0) {
              console.error('Invalid variant ID:', product.id, 'for product:', product.title);
              return null;
            }
            return {
              id: variantId,
              quantity: product.quantity || 1,
              properties: { 'Bundle and Save': `Box of ${totals.totalQuantity}`, 'Bundle ID': bundleId  },
            };
          })
          .filter(Boolean);

        if (items.length === 0) {
          throw new Error('No valid items to add to cart');
        }

        try {
          await fetch(window.Shopify.routes.root + 'cart/clear', {
            method: 'GET',
          });

          const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items }),
          });

          if (!response.ok) {
            throw new Error('Failed to add items to cart');
          }
        } catch (error) {
          console.error('Error adding products to cart:', error);
        }

        CartAPI.updateCartCount(items.length);

        this.products = [];
        Storage.clearCart();
        this.updateUI();

        if (button) {
          button.disabled = true;
        }

        // await CartAPI.openCart();
        window.location.href = window.Shopify.routes.root + 'checkout';
      } catch (error) {
        console.error('Error adding products to cart:', error);
        
        // Esconder spinner em caso de erro
        if (button) {
          button.classList.remove('loading');
          button.disabled = false;
        }
      }
    },
  };

  // ============================================
  // MOBILE TOGGLE MODULE
  // ============================================
  const MobileToggle = {
    init() {
      this.container = document.querySelector('.bundle-sticky-box__container');
      this.toggleHeader = document.querySelector('.bundle-sticky-box__bundle-header');
      this.toggleHeaderContentIcon = document.querySelector('.bundle-sticky-box__bundle-header-content-icon');
      if (!this.container || !this.toggleHeader) return;

      this.isMobile = window.innerWidth <= 1200;

      if (this.isMobile) {
        this.container.classList.add('mobile-collapsed');
        this.toggleHeader.classList.remove('bundle-sticky-box__bundle-header--expanded');
        if (this.toggleHeaderContentIcon) {
          this.toggleHeaderContentIcon.classList.remove('bundle-sticky-box__bundle-header-content-icon--expanded');
        }

        this.toggleHeader.addEventListener('click', () => this.toggle());

        window.addEventListener('resize', () => this.handleResize());
      }
    },

    toggle() {
      if (!this.isMobile) return;

      const isCollapsed = this.container.classList.contains('mobile-collapsed');

      if (isCollapsed) {
        document.body.style.overflow = 'hidden';
        document.documentElement.style.overflow = 'hidden';

        this.container.classList.remove('mobile-collapsed');
        this.container.classList.add('expanded');
        this.toggleHeader.classList.add('bundle-sticky-box__bundle-header--expanded');
        if (this.toggleHeaderContentIcon) {
          this.toggleHeaderContentIcon.classList.add('bundle-sticky-box__bundle-header-content-icon--expanded');
        }
      } else {
        document.body.style.overflow = 'auto';
        document.documentElement.style.overflow = 'auto';
        this.container.classList.remove('expanded');
        this.container.classList.add('mobile-collapsed');
        this.toggleHeader.classList.remove('bundle-sticky-box__bundle-header--expanded');
        if (this.toggleHeaderContentIcon) {
          this.toggleHeaderContentIcon.classList.remove('bundle-sticky-box__bundle-header-content-icon--expanded');
        }
      }
    },

    handleResize() {
      const nowMobile = window.innerWidth <= 1200;

      if (nowMobile !== this.isMobile) {
        this.isMobile = nowMobile;

        if (this.isMobile) {
          this.container.classList.add('mobile-collapsed');
          this.toggleHeader.classList.remove('bundle-sticky-box__bundle-header--expanded');
          if (this.toggleHeaderContentIcon) {
            this.toggleHeaderContentIcon.classList.remove('bundle-sticky-box__bundle-header-content-icon--expanded');
          }
          this.toggleHeader.addEventListener('click', () => this.toggle());
        } else {
          this.container.classList.remove('mobile-collapsed', 'expanded');
          this.toggleHeader.classList.remove('bundle-sticky-box__bundle-header--expanded');
          if (this.toggleHeaderContentIcon) {
            this.toggleHeaderContentIcon.classList.remove('bundle-sticky-box__bundle-header-content-icon--expanded');
          }
          this.container.style.transform = '';
          this.container.style.position = 'sticky';
          this.container.style.top = '10px';
          this.container.style.bottom = 'auto';
        }
      }
    },
  };

  // ============================================
  // PROGRESS BAR ALIGNMENT MODULE (SIMPLIFICADO)
  // ============================================
  const ProgressBarAlignment = {
    init() {
      this.updateTextWidths();
      window.addEventListener('resize', () => this.updateTextWidths());
    },

    updateTextWidths() {
      const progressItems = document.querySelectorAll('.bundle-sticky-box__bundle-header-progress-line-item');
      const progressTexts = document.querySelectorAll('.bundle-sticky-box__bundle-header-progress-line-text');

      if (progressItems.length === 0 || progressTexts.length === 0) return;

      progressTexts.forEach((text) => {
        text.style.whiteSpace = 'nowrap';
        text.style.overflow = 'hidden';
        text.style.textOverflow = 'ellipsis';
        text.style.maxWidth = '100%';
      });

      const textContainer = document.querySelector('.bundle-sticky-box__bundle-header-progress-line-text-container');
      if (textContainer) {
        const isMobile = window.innerWidth <= 1200;
        if (isMobile && progressItems.length === 4) {
          textContainer.style.padding = '0 2px';
        } else {
          textContainer.style.padding = '';
        }
      }
    },
  };

  // ============================================
  // GLOBAL EXPORTS
  // ============================================
  window.addToBundle = (product) => {
    const cart = Storage.getCart();
    const productInCart = cart.find((p) => p.id === product.id);
    if (productInCart) {
      BundleCart.updateQuantity(product.id, product.stock, 1);
    } else {
      BundleCart.addProduct(product);
    }
  };
  window.handleATC = () => BundleCart.addToCart();

  window.handleCollectionNavItemClick = (btn, tag) => {
    document.querySelectorAll('.collection-nav-item').forEach(item => {
      item.classList.remove('collection-nav-item--active');
    });
    btn.classList.add('collection-nav-item--active');
    document.querySelectorAll('form.product-alternative-card-form').forEach(form => {
      if (form.dataset.tags.includes(tag) || tag === 'all') {
        form.classList.remove('product-alternative-card-form--hidden');
      } else {
        form.classList.add('product-alternative-card-form--hidden');
      }
    });
  };

  // ============================================
  // INITIALIZATION
  // ============================================
  document.addEventListener('DOMContentLoaded', () => {
    BundleCart.updateUI();
    MobileToggle.init();
    ProgressBarAlignment.init();
    SortModule.init();
  });
</script>
