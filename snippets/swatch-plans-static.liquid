      .subscription-frequency {
        font-size: 14px;
      }
      .plan-name {
        position: relative;
        top: 1px;
      }

      .subscription-card {
        padding: 20px 10px;
      }

      .subscrition-name {
        line-height: 1;
      }

      .subscription-note {
        font-size: 14px;
        gap: 2px;
      }
    }

    @media screen and (max-width: 480px) {
      .content {
        flex-wrap: nowrap;
        gap: 15px;
      }

      .plan-right {
        gap: 10px;
      }

      .subscription-wrapper .plan-right {
        align-items: start;
      }

      .subscription-best {
        font-size: 12px;
        padding: 3px 8px;
      }
    }
