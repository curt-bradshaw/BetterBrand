{% comment %} {% assign current_variant = product.selected_or_first_available_variant %}

{% comment %} Custom Last Option Variant ID and Selling Plan ID {% endcomment %}
{% assign last_option_variant_id = product.metafields.pdp.variant_id_with_subscription %}
{% assign last_option_selling_plan_id = product.metafields.pdp.selling_plan_id_to_show_on_pdp %}
{% assign last_option_subtitle = product.metafields.pdp.pdp_last_option_subtitle %}

{% if last_option_variant_id and last_option_selling_plan_id %}
  {% assign last_option_variant = product.variants | where: 'id', last_option_variant_id | first %}
  {% for allocation in last_option_variant.selling_plan_allocations %}
    {% if allocation.selling_plan.id == last_option_selling_plan_id %}
      {% assign last_option_allocation_to_use = allocation %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if product.variants.size > 1 %}
  <div class="plan-wrapper" id="product-plan-selector">
    <!-- VARIANTS -->
    <div class="plan-list">
      {% assign curr_idx = 1 %}
      {% for v in product.variants %}
        {% if v.metafields.pdp.hide_on_pdp %}
          {% continue %}
        {% endif %}
        {% if v.available %}
          <label
            class="plan-card {% if v.id == current_variant.id %}active{% endif %}"
            data-variant-id="{{ v.id }}"
            data-price="{{ v.price }}"
          >
            <input type="radio" hidden>

              <div class="plan-left">
                {% if v.image %}
                  <img src="{{ v.image | image_url: width: 120 }}" alt="{{ v.title }}">
                {% elsif product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ v.title }}">
                {% else %}
                  <div class="image-placeholder"></div>
                {% endif %}
              </div>

            <div class="plan-center">
              <span class="plan-name">
                {% if v.title contains '(' %}
                  {% assign title_parts = v.title | split: '(' %}
                  <strong>{{ title_parts[0] | strip }}</strong>
                  {% if title_parts.size > 1 %}
                    <span style="font-weight: normal;">({{ title_parts[1] }}</span>
                  {% endif %}
                {% else %}
                  <strong>{{ v.title }}</strong>
                {% endif %}
              </span>
            </div>

            <div class="plan-right">
              <div class="plan-badge {% unless curr_idx > 1 %}hidden{% endunless %}">
                {% case curr_idx %}
                  {% when 2 %}
                    {% assign discount = 10 %}
                  {% when 3 %}
                    {% assign discount = 15 %}
                  {% else %}
                    {% assign discount = v.compare_at_price
                      | minus: v.price
                      | times: 100
                      | divided_by: v.compare_at_price
                    %}
                {% endcase %}
                <span>SAVE {{ discount }}%</span>
              </div>
              <div class="plan-price">
                {% assign variant_title_lower = v.title | downcase %}
                {% assign items_count = 0 %}
                {% assign show_each = false %}
                
                {% if v.metafields.pdp.amount_of_items %}
                  {% assign items_count = v.metafields.pdp.amount_of_items | times: 1 %}
                  {% assign show_each = true %}
                {% endif %}
                
                {% if show_each and items_count > 0 %}
                  {% comment %} Calculate price per bottle/pack {% endcomment %}
                  {% assign total_price_cents = v.price %}
                  {% assign price_per_item_cents = total_price_cents | divided_by: items_count %}
                  {% assign price_per_item_dollars = price_per_item_cents | divided_by: 100 %}
                  {% assign cents_remainder = price_per_item_cents | modulo: 100 %}
                  ${{ price_per_item_dollars }}.{% if cents_remainder < 10 %}0{% endif %}{{ cents_remainder }}
                  <span>each</span>
                {% else %}  
                  {% assign price_dollars = v.price | divided_by: 100 %}
                  {% assign price_cents = v.price | modulo: 100 %}
                  ${{ price_dollars }}.{% if price_cents < 10 %}0{% endif %}{{ price_cents }}
                {% endif %}
              </div>
            </div>
          </label>
        {% endif %}
        {% assign curr_idx = curr_idx | plus: 1 %}
      {% endfor %}
    </div>

    <!-- SELECT REAL SHOPIFY -->
  </div>


  {% if last_option_variant and last_option_allocation_to_use and last_option_subtitle %}

    <div class="subscription-wrapper" id="subscription-options">
      <div class="subscription-group" data-variant-id="{{ last_option_variant.id }}">
        <label
          class="subscription-card"
          data-price="{{ last_option_allocation_to_use.price }}"
          data-selling-plan-id="{{ last_option_allocation_to_use.selling_plan.id }}"
          data-variant-id="{{ last_option_variant.id }}"
        >
          <input type="radio" hidden value="{{ last_option_variant.id }}">
          <span class="subscription-best">Best Value</span>
          <div class="content">
            <p class="subscrition-name">
              <span class="subscription-title">
                Subscribe & Save
              </span>
              <br>
              <span class="subscription-frequency">
                {{ last_option_subtitle }}
              </span>
            </p>
            <div class="plan-right">
              <div class="plan-price">
                {% assign show_each = false %}
                {% if last_option_variant.metafields.pdp.amount_of_items %}
                  {% assign items_count = last_option_variant.metafields.pdp.amount_of_items | times: 1 %}
                  {% assign show_each = true %}
                {% endif %}
                
                {% if show_each and items_count > 0 %}
                {% assign items_count = last_option_variant.metafields.pdp.amount_of_items | times: 1 %}
                {% assign total_price_cents = last_option_allocation_to_use.price %}
                {% assign price_per_item_cents = total_price_cents | divided_by: items_count %}
                {% assign price_per_item_dollars = price_per_item_cents | divided_by: 100 %}
                {% assign cents_remainder = price_per_item_cents | modulo: 100 %}
                ${{ price_per_item_dollars }}.{% if cents_remainder < 10 %}0{% endif %}{{ cents_remainder }}
                <span>each</span>
                {% else %}
                  {% assign price_dollars = last_option_allocation_to_use.price | divided_by: 100 %}
                  {% assign price_cents = last_option_allocation_to_use.price | modulo: 100 %}
                  ${{ price_dollars }}.{% if price_cents < 10 %}0{% endif %}{{ price_cents }}
                {% endif %}
              </div>
              <div class="plan-badge">
                <span>SAVE 20%</span>
              </div>
            </div>
          </div>
          
          <div class="subscription-note">
            <span><strong>FREE</strong> Shipping</span>
            <span>Change, Pause or Cancel Anytime</span>
          </div>
        </label>
      </div>
    </div>

    <input type="hidden" name="selling_plan" id="product-selling-plan">
  {% endif %}
{% endif %}

<select
  id="all-product-variants"
  name="id"
  class="product-variant all-variant hide"
  data-productid="{{ product.id }}"
>
  {% for v in product.variants %}
    {% if v.available %}
      <option
        value="{{ v.id }}"
        {% if v.id == current_variant.id %}
          selected
        {% endif %}
        data-available="{{ v.available }}"
        data-options="{{ v.options | join: ',' | escape }}"
        data-sku="{{ v.sku }}"
        data-price="{{ v.price }}"
        data-compare-at-price="{{ v.compare_at_price }}"
        data-variant-inventory="{{ v.inventory_management }}"
        data-inventory-policy="{{ v.inventory_policy }}"
        data-inventory="{% if v.inventory_policy == 'continue' or v.inventory_management == blank %}-1{% else %}{{ v.inventory_quantity }}{% endif %}"
        data-image="{{ v.image.src | split: '?' | first }}"
        data-image-position="{{ v.featured_media.position | default: 0 }}"
        data-items-count="{{ v.metafields.pdp.amount_of_items }}"
      >
        {{ v.title }}
      </option>
    {% endif %}
  {% endfor %}
</select>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const variantCards = document.querySelectorAll('.plan-card,.subscription-card');
    const variantSelect = document.querySelector('select[name="id"]');
    const subscriptionGroups = document.querySelectorAll('.subscription-group');
    const sellingPlanInput = document.querySelector('input[name="selling_plan"]');
    const productForm = variantSelect?.closest('form');

    if (!variantSelect || !productForm) return;

    // Initial check: show quantity only for 1-pack or 1 bottle variants
    function checkAndShowQuantity() {
      const productQuantity = document.querySelector('.product-quantity');
      if (variantCards.length > 1) {
        productQuantity.style.display = 'none';
      }
    }

    // Run initial check
    checkAndShowQuantity();

    /* ===============================
       HELPER FUNCTIONS
    =============================== */
    function formatMoney(cents) {
      const amount = (parseInt(cents) / 100).toFixed(2);
      // Simple USD format - adjust if needed for other currencies
      return `$${amount}`;
    }

    function formatMoneyWithoutCurrency(cents) {
      return (parseInt(cents) / 100).toFixed(2);
    }

    function updatePriceDisplay(priceInCents) {
      const formattedPrice = formatMoney(priceInCents);
      const priceWithoutCurrency = formatMoneyWithoutCurrency(priceInCents);

      // Update .btn-money in ATC button
      const btnMoney = document.querySelector('.btn-add-tocart .btn-money');
      if (btnMoney) {
        btnMoney.textContent = formattedPrice;
      }

      // Update .current-price (standard layout)
      const currentPrice = document.querySelector('.current-price.price');
      if (currentPrice) {
        currentPrice.textContent = formattedPrice;
      } 

      // Update .new-product-price-value (new layout - without currency symbol)
      const newPriceValue = document.querySelector('.new-product-price-value.jq-new-price');
      if (newPriceValue) {
        newPriceValue.textContent = priceWithoutCurrency;
      }

      // Update data-product-price attribute for consistency
      const priceContainer = document.querySelector('#product-price');
      if (priceContainer) {
        priceContainer.dataset.productPrice = priceInCents;
      }

      // Also update recharger-price class elements
      const rechargerPrices = document.querySelectorAll('.recharger-price');
      rechargerPrices.forEach((el) => {
        if (el.classList.contains('new-product-price-value')) {
          el.textContent = priceWithoutCurrency;
        } else {
          el.textContent = formattedPrice;
        }
      });
    }

    /* ===============================
       VARIANT CLICK
    =============================== */
    variantCards.forEach((card) => {
      card.addEventListener('click', () => {
        console.log('card clicked');
        const variantId = card.dataset.variantId;
        const variantPrice = card.dataset.price;
        const sellingPlanId = card.dataset.sellingPlanId;

        // Update real variant select
        variantSelect.value = variantId;
        variantSelect.dispatchEvent(new Event('change', { bubbles: true }));

        // Update UI
        variantCards.forEach((c) => c.classList.remove('active'));
        card.classList.add('active');

        // Remove selling plan and active subscription
        if (sellingPlanId) {
          sellingPlanInput.value = sellingPlanId;
          sellingPlanInput.dispatchEvent(new Event('change', { bubbles: true }));
        } else {
          sellingPlanInput.value = '';
          sellingPlanInput.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // Show quantity only for 1-pack or 1 bottle variants
        const selectedVariantOption = variantSelect.querySelector(`option[value="${variantId}"]`);
        const variantTitle = selectedVariantOption ? selectedVariantOption.textContent : '';
        // const is1Pack = is1PackOr1Bottle(variantTitle);
        
        const productQuantity = document.querySelector('.product-quantity');
        if (productQuantity) {
          productQuantity.style.display = 'none';
        }

        // Update price to selected variant price
        if (variantPrice) {
          updatePriceDisplay(variantPrice);
        }

        // Force theme to recalculate everything
        productForm.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });
  });
</script>

