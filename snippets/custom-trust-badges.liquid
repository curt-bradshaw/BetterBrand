<!-- start custom-trust-badges.liquid (SNIPPET) -->
<div class="trust-badges-wrapper">
    {% if block.settings.trust_badges_title != '' or block.settings.trust_badges_title != blank %}
      <h3 class="trust-badges-wrapper__title">{{ block.settings.trust_badges_title }}</h3>
    {% endif %}
  
    <div class="trust-badges">
      {% if block.settings.enable_trust_badge01 %}
        <div class="trust-badge">
          {% if block.settings.product_form_trust_badge01 != "" or block.settings.product_form_trust_badge01 != blank %}
            {{ block.settings.product_form_trust_badge01 }}
          {% elsif block.settings.product_form_trust_badge_svg01 != "" or block.settings.product_form_trust_badge_svg01 != blank %}
              {% assign trust_badge = 'icon-' | append: block.settings.product_form_trust_badge_svg01 | append: '.svg' | asset_url %}
              <img
                width="{{ block.settings.trust_badge01_width }}"
                height="{{ block.settings.trust_badge01_height }}"
                class="cart-drawer__badge"
                src="data:image/png;base64,"
                data-src="{{ trust_badge }}"
                alt="{{ block.settings.product_form_trust_badge01_text | default: 'trust badge' | escape }}"
                loading="lazy"
                data-class="LazyLoad"
              >
          {% endif %}
          <p>{{ block.settings.product_form_trust_badge01_text }}</p>
        </div>
      {% endif %}
  
      {% if block.settings.enable_trust_badge02 %}
