<!-- snippet/product-alternative-card -->
{% assign render_tag = false %}
{% assign tag_text = '' %}
{% assign tag_type = '' %}


{% if custom_product.available == false %}
  {% assign tag_text = settings.card_tag_sold_out_text | default: 'SOLD OUT' %}
  {% assign tag_type = 'sold-out' %}
  {% assign render_tag = true %}
{% elsif custom_product.compare_at_price > custom_product.price %}
  {% assign tag_text = settings.card_tag_sale_text | default: 'ON SALE' %}
  {% assign tag_type = 'sale' %}
  {% assign render_tag = true %}
{% elsif custom_product.metafields.custom.new_arrival.value == true %}
  {% assign tag_text = settings.card_tag_new_arrival_text | default: 'New Arrival' %}
  {% assign tag_type = 'new-arrival' %}
  {% assign render_tag = true %}
{% endif %}

{% for variant in custom_product.variants %}
  {% if variant.metafields.pdp.hide_on_pdp == true %}
    {% continue %}
  {% endif %}
  {% assign variant_selected = variant %}
  {% break %}
{% endfor %}

<form class="product-alternative-card-form" action="/cart/add" method="post" data-tags="{{ custom_product.tags | join: ',' }}" id="product-alternative-card-form">
  <input type="hidden" name="id" value="{{ custom_product.variants.first.id }}">
  <input type="hidden" name="quantity" value="1">
  <div class="products-offers__card-link">
    {% if render_tag == true %}
      <div class="products-offers__card-tag" data-tag="{{ tag_type }}">
        <span class="products-offers__card-tag-text">{{ tag_text }}</span>
      </div>
    {% endif %}
    <div class="products-offers__card-image-wrapper">
      {% assign exhibition_image = custom_product.metafields.custom.exhibition_image %}
      <div class="products-offers__card-image-primary">
        {% if custom_product.featured_image != blank %}
          {% render 'responsive-image',
            image: custom_product.featured_image,
            width: 540,
            height: 460,
            class: 'products-offers__card-image-primary-img'
          %}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag }}
        {% endif %}
      </div>
      {% if exhibition_image != blank %}
        <div class="products-offers__card-image-secondary">
          {% render 'responsive-image',
            image: exhibition_image.value,
            width: 540,
            height: 460,
            class: 'products-offers__card-image-secondary-img'
          %}
        </div>
      {% endif %}
    </div>
    <div class="products-offers__card-content">
    <div class="products-offers__card-title-notes-wrapper">
      <div class="product-card__item-reviews-wrapper">
        {%- render 'product-reviews' with product: custom_product, pattern: '[rating]&nbsp;([count])' -%}
        </div>
      <p class="products-offers__card-title">{{ custom_product.title }}</p>
    </div>
    <div class="product-card__item-price-wrapper">

      <div class="product-card__item-price-wrapper-inner">
    
      {% unless template.suffix == 'bundle' %}
        {%- if variant_selected.compare_at_price > variant_selected.price -%}
          <span class="product-card__item-compare-at-price">{{- variant_selected.compare_at_price | money -}}</span>
        {%- endif -%}
      {% endunless %}
        <span class="product-card__item-price">{{- variant_selected.price | money -}}</span>
      </div>

      {% if settings.enable_outofstock_label %}
        {%- unless custom_product.available -%}
          <span class="product-card__item-sold-out">
            {{- settings.unavailable_product_label | default: '(Out Of Stock)' -}}
          </span>
        {%- endunless -%}
      {% endif %}
    
    <div class="product-offers__btn">
      {% if template.suffix == 'bundle' %}
      <button type="button" class="product-btn__add-to-cart" onclick="handleAddToBundle({
          id: '{{ variant_selected.id }}',
          title: '{{ custom_product.title }}',
          image: '{{ custom_product.featured_image | image_url: width: 124, height: 124 }}',
          price: '{{ variant_selected.price }}',
          compare_at_price: '{{ variant_selected.compare_at_price }}',
          link: '{{ custom_product.url }}',
          quantity: 1,
          stock: '{{ variant_selected.inventory_quantity }}',
        }, this)">
        <span class="product-btn__spinner" style="display: none;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="animation: spin 1s linear infinite;">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" stroke-opacity="0.25"/>
            <path d="M12 2C13.3132 2 14.6136 2.25866 15.8268 2.7612C17.0401 3.26375 18.1425 4.00035 19.0711 4.92893C19.9997 5.85752 20.7362 6.95991 21.2388 8.17317C21.7413 9.38642 22 10.6868 22 12" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="btn-label">ADD TO CART +</span>
      </button>
    {% else %}
      <button type="submit" class="product-btn__add-to-cart">
        <span class="btn-label">ADD TO CART +</span>
      </button>
      {% endif %}
    </div>
  </div>
  </div>
  </div>
</form>

{% javascript %}
window.handleAddToBundle = async function (bundle_product, button) {
  if (!button) return;
  
  const spinner = button.querySelector('.product-btn__spinner');
  const label = button.querySelector('.btn-label');
  
  // Mostrar spinner e esconder label
  if (spinner) spinner.style.display = 'flex';
  if (label) label.style.display = 'none';
  button.disabled = true;
  button.classList.add('loading');
  
  try {
    if( window.addToBundle && typeof window.addToBundle === 'function') {
      await window.addToBundle(bundle_product);
    } else {
      if(window.CartAPI && typeof window.CartAPI.addItem === 'function') {
        await window.CartAPI.addItem({
          items: [{
            id: bundle_product.id,
            quantity: 1
          }]
        });
        await window.CartAPI.openCartDrawer();
        await window.CartAPI.buildCart();
      }
    }
  } catch (error) {
    console.error('Error adding to bundle:', error);
  } finally {
    // Esconder spinner e mostrar label após a conclusão
    setTimeout(() => {
      if (spinner) spinner.style.display = 'none';
      if (label) label.style.display = '';
      button.disabled = false;
      button.classList.remove('loading');
    }, 500);
  }
};

{% endjavascript %}

<style>
  .product-btn__spinner {
    display: none;
    align-items: center;
    justify-content: center;
  }

  .product-btn__spinner svg {
    width: 20px;
    height: 20px;
    color: currentColor;
  }

  .product-btn__add-to-cart.loading .product-btn__spinner {
    display: flex;
  }

  .product-btn__add-to-cart.loading .btn-label {
    display: none;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>