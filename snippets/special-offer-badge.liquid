<!-- start special-offer-badge.liquid (SNIPPET) -->
{%- assign special_offer_badge_width = block.settings.svg_special_offer_badge_size | default: 50 -%}

<div id="shopify-section-special-offer-badge" class="shopify-section special-offer-badge-wrapper">
  <div class="container-special-offer-badge">
    <div class="container-special-offer-badge-bottom">
      {%- assign image = block.settings.img_special_offer_badge -%}

      {%- if block.settings.filter_by_tags == blank -%}
        <div class="special-offer-badge-img">
          {%- if block.settings.enable_img_special_offer_badge_cart -%}
            {%- if block.settings.img_special_offer_badge.alt != blank -%}
              {%- assign image_alt = block.settings.img_special_offer_badge.alt | strip_html | escape -%}
            {%- else -%}
              {%- assign image_alt = 'Special Offer Badge' -%}
            {%- endif -%}

            {%- assign image_id_prefix = 'special-offer-badge-img' | append: forloop.index -%}

            {%- render 'responsive-image',
              id: image_id_prefix,
              image: image,
              lazyload: true,
              class: 'img-badges',
              no_wrap: true,
              alt: image_alt,
              width: special_offer_badge_width
            -%}
          {%- else -%}
            {%- if block.settings.enable_custom_special_offer_badge_svg -%}
              <div class="custom-svg">
                {%- assign special_offer_badge_svg = block.settings.custom_special_offer_badge_svg_html -%}
                {{ special_offer_badge_svg }}
              </div>
            {%- else -%}
              {%- assign image_id_prefix = 'special-offer-badge-icon' | append: forloop.index -%}
              {%- assign special_offer_badge = block.settings.svg_special_offer_badge_cart | append: '.svg' -%}
              {%- assign image_alt = block.settings.svg_special_offer_badge_cart
                | escape
                | replace: '-', ' '
                | capitalize
              -%}

              <div class="special-offer-badge__svg-image">
                <img
                  width="{{ special_offer_badge_width }}"
                  height="{{ special_offer_badge_width }}"
                  class="special-offer__image"
                  src="{{ special_offer_badge | asset_url }}"
                  alt="{{ image_alt | escape | replace: "-" , " " | capitalize | default: 'Special Offer Badge' }}"
                >
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- else -%}
        {%- assign list_filter_tags = block.settings.filter_by_tags | split: ';' -%}

        {%- for tag_temp in list_filter_tags -%}
          {%- assign contain_tag = false -%}
          {%- for tag in product.tags -%}
            {%- if tag_temp == tag -%}
              {%- assign contain_tag = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if contain_tag -%}
            <div class="special-offer-badge-img">
              {%- if block.settings.enable_img_special_offer_badge_cart -%}
                {%- if block.settings.img_special_offer_badge.alt != blank -%}
                  {%- assign image_alt = block.settings.img_special_offer_badge.alt | strip_html | escape -%}
                {%- else -%}
                  {%- assign image_alt = 'Special Offer Badge' -%}
                {%- endif -%}

                {%- assign badge_id = 'special-offer-badge-image-tag-' | append: forloop.index -%}
                {%- render 'responsive-image',
                  id: badge_id,
                  image: block.settings.img_special_offer_badge,
                  lazyload: true,
                  class: 'img-badges',
                  no_wrap: true,
                  alt: image_alt,
                  width: special_offer_badge_width
                -%}
              {%- else -%}
                {%- if block.settings.enable_custom_special_offer_badge_svg -%}
                  <div class="custom-svg">{{ block.settings.custom_special_offer_badge_svg_html }}</div>
                {%- else -%}
                  {%- assign special_offer_badge = block.settings.svg_special_offer_badge_cart | append: '.svg' -%}
                  {%- assign image_alt = block.settings.svg_special_offer_badge_cart
                    | escape
                    | replace: '-', ' '
                    | capitalize
                  -%}

                  <div class="special-offer-badge__svg-image">
                    <img
                      width="{{ special_offer_badge_width }}"
                      height="{{ special_offer_badge_width }}"
                      data-class="LazyLoad"
                      class="special-offer__image"
                      src="data:image/png;base64,"
                      data-src="{{ special_offer_badge | asset_url }}"
                      alt="{{ image_alt | escape | replace: "-" , " " | capitalize | default: 'Special Offer Badge' }}"
                    >
                  </div>
                {%- endif -%}
              {%- endif -%}
            </div>

            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style scoped>
    .shopify-section.special-offer-badge-wrapper {
      width: auto;
      position: relative;
      display: inline-block;
    }
    
    .special-offer__image {
      width: {{ special_offer_badge_width }}px;
      height: {{ special_offer_badge_width }}px;
      max-width: 100%;
      height: auto;
    }

    .special-offer-badge__svg-image {
      display: inline-block;
    }

    .container-special-offer-badge {
      margin: 10px 0;
    }
</style>
