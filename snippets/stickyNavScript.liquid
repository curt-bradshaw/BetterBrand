<script>
  window.addEventListener('scroll', function() {
      const header = document.querySelector('.header-wrapper');

      if (window.scrollY > 100) {
          header.classList.add('stickyNav');
      } else {
          header.classList.remove('stickyNav');
      }
  });
</script>

