<!-- sections/shop-by-necessity.liquid -->
<section style="--amount-of-blocks: {{ section.blocks.size }};" class="necessity-section" {{ section.shopify_attributes }}>
    <div class="necessity__header">
      <h2 class="necessity__title">{{ section.settings.heading }}</h2>
      <p class="necessity__subtitle">{{ section.settings.subheading }}</p>
    </div>
  
    <div class="necessity__grid">
      {% for block in section.blocks %}
        <div class="necessity__item-wrapper">
          <a class="necessity__item" href="{{ block.settings.link_url }}" {{ block.shopify_attributes }}>
            <div class="necessity__image-wrapper">
              <img
                src="{{ block.settings.image | img_url: '600x' }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
              />
            </div>
            <h3 class="necessity__item-title">{{ block.settings.title }}</h3>
            <p class="necessity__item-text">{{ block.settings.text }}</p>
          </a>
        </div>
      {% endfor %}
    </div>
  
    {% schema %}
    {
      "name": "Shop by Necessity",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop By Necessity" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "Lorem Ipsum Dolor Sit Amet Consectetur" }
      ],
      "blocks": [
        {
          "type": "item",
          "name": "Item",
          "settings": [
            { "type": "image_picker", "id": "image", "label": "Image" },
            { "type": "text", "id": "title", "label": "Title" },
            { "type": "text", "id": "text", "label": "Text" },
            { "type": "url", "id": "link_url", "label": "Link URL" }
          ]
        }
      ],
      "max_blocks": 6,
      "presets": [{ "name": "Shop by Necessity" }]
    }
    {% endschema %}
  
    {% style %}
    .necessity-section {
      padding: 60px 20px;
      background: #234134;
      color: #fff;
      text-align: center;
    }
  
    .necessity__title {
      font-size: 38px;
      margin-bottom: 4px;
      font-weight: 700;
      color: #FFFFFF;
      font-family: var(--bookmaniaFont);
      line-height: 1.2;
    }
  
    .necessity__subtitle {
      font-size: 20px;
      margin-bottom: 35px;
      color: #FFFFFF;
    }

    .necessity__grid {
      display: grid;
      column-gap: 32px;
      row-gap: 35px;
      grid-template-columns: repeat(min(var(--amount-of-blocks), 3), 1fr);
      max-width: 1180px;
      margin: 0 auto;
    }

    .necessity__item-wrapper {
      display: flex;
      justify-content: center;
    }
  
    .necessity__item {
      text-align: left;
      color: #fff;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: fit-content;
    }

    .necessity__item:hover {
      opacity: 0.9;
    }
  
    .necessity__image-wrapper img {
      width: 100%;
      height: auto;
      border-radius: 16px;
      display: block;
      max-width: 576px;
      object-fit: cover;
    }
  
    .necessity__item-title {
      font-size: 22px;
      font-weight: 700;
      margin: 14px 0 2px;
      color: #FFFFFF;
      width: fit-content;
    }
  
    .necessity__item-text {
      font-size: 18px;
      margin-top: 4px;
    }

    @media (max-width: 1019px) {
      .necessity__grid {
        grid-template-columns: repeat(2, 1fr);
        column-gap: 32px;
        row-gap: 32px;
      }
      .necessity__title {
        font-size: 32px;
      }
      .necessity__item-title {
        font-size: 20px;
      }

      .necessity__item {
        align-items: flex-start;
      }
      .necessity__header {
        margin-bottom: 35px;
      }

      .necessity__image-wrapper img {
        min-height: 394px;
      }
    }
  
    @media (max-width: 767px) {
      .necessity__grid {
        grid-template-columns: repeat(2, 1fr);
        column-gap: 10px;
        row-gap: 20px;
      }
      .necessity__header {
        margin-bottom: 20px;
      }
      .necessity__title {
        font-size: 24px;
      }
      .necessity__subtitle {
        font-size: 14px;
        margin-bottom: 20px;
      }
      .necessity__item-title {
        font-size: 14px;
      }
      .necessity__item-text {
        font-size: 14px;
      }

      .necessity__image-wrapper img {
        min-height: 183px;
      }
    }
    {% endstyle %}
  </section>
  