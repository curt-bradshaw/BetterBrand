    }
    .cross-sell__product-grid{
        flex-wrap: wrap;
    }
    .cross-sell__product-grid{
        border: 1px solid;
        border-color: var(--cross-sell-border-color);
    }
    .cross-sell__product-card:nth-child( 2n ) {
        border-left: 1px solid;
        border-left-color: var(--cross-sell-border-color);
    }

    .cross-sell__product-card:nth-child(-n + 2){
        border-bottom: 1px solid;
        border-bottom-color: var(--cross-sell-border-color);
    }
    .cross-sell__product-card{
        border-right:0;
    }
  }
</style>

<div class="cross-sell__wrapper {% if template contains "product" %} cross-sell__product__wrapper {% endif %}">
  {% if section.settings.enable_cross_sell_title %}
    {% if section.settings.cross_sell_title != blank %}
      <h2 class="cross-sell__title">{{ section.settings.cross_sell_title }}</h2>
    {% else %}
      <h2 class="cross-sell__title">{{ cross_sell_collection.title }}</h2>
    {% endif %}
  {% endif %}

  {% if section.settings.cross_sell_select_collection != blank %}
    <div class="wrapper cross-sell__product-grid">
      {% assign = i = 0 %}

      {%- assign cart_items_ids = '' -%}

      {%- for item in cart.items -%}
        {%- assign cart_items_ids = cart_items_ids | append: ',' | append: item.product_id -%}
      {%- endfor -%}

      {% for temp_product in cross_sell_collection.products %}
        {%- unless cart_items_ids contains temp_product.id or temp_product.available == false -%}
          <div class="cross-sell__product-card">
            {%- render 'product-card',
              prod: temp_product,
              width_mobile: width_mobile,
              width_desk: width_desk,
              max_width: image_width,
              show_price: show_price
            -%}
            <form action="/cart/add" id="cross-sell_form" class="cross-sell__product-form">
              <div class="cross-sell__product-form__swatches">
                {%- assign variants_size = temp_product.variants | size -%}
                {%- if variants_size == 1 -%}
                  <input type="hidden" name="id" value="{{ temp_product.selected_or_first_available_variant.id }}">
                {%- else -%}
                  <select name="id" class="cross-sell__product-select">
                    <option
                      value=""
                      data-image="{{ temp_product.selected_or_first_available_variant.image | img_url: '200x' }}"
                      disabled
                    >
                      Choose Variant:
                    </option>

                    {% for variant in temp_product.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-image="{{ variant.image | img_url: '200x' }}"
                        {% if cart_items contains variant.id %}
                          disabled="disabled"
                        {% endif %}
                      >
                        {{ variant.title }}
                      </option>
                    {% endfor %}
                  </select>
                {% endif %}
              </div>

              <div class="cross-sell__product-form__submit">
                <input type="hidden" name="quantity" value="1">
                <span class="cross-sell__product-form__value">{{ temp_product.selected_or_first_available_variant.price | money }}</span>
                <button type="submit" class="cross-sell__product-button cart-icon btn btn-add-tocart">
                  <span class="cross-sell__product-button-text">Add to Order</span>
                </button>
              </div>
            </form>
          </div>
          {%- assign i = i | plus: 1 -%}
          {%- if i == 4 -%}
            {%- break -%}
          {%- endif -%}
        {%- endunless -%}
      {% endfor %}
    </div>
  {% endif %}
</div>

{% if enable_lazy %}
  <script type="lazyload_int">
    setTimeout(function() {
      $('.cross-sell__product-grid').slick({
        infinite: true,
        slidesToShow: 3,
        slidesToScroll: 1,
        prevArrow: '<button type="button" class="prev-arrow"></button>',
        nextArrow: '<button type="button" class="next-arrow"></button>',
        centerMode: true,
        variableWidth: true,
        responsive: [
          {
            breakpoint: 768,
            settings: {
              slidesToShow: 1
            }
          }
        ]
      });
    });
  </script>  
{% else %}
  <script>
    window.addEventListener('DOMContentLoaded', function() {
      $('.cross-sell__product-grid').slick({
        infinite: true,
        slidesToShow: 3,
        slidesToScroll: 1,
        prevArrow: '<button type="button" class="prev-arrow"></button>',
        nextArrow: '<button type="button" class="next-arrow"></button>',
        centerMode: true,
        variableWidth: true,
        responsive: [
          {
            breakpoint: 768,
            settings: {
              slidesToShow: 1
            }
          }
        ]
      });
    });
  </script>  
{% endif %}

<script type="lazyload_int">
  setTimeout(function () {
    const methods = {
      cart: {
        /**
         * Get all cart items.
         */
        getCart() {
          return fetch('/cart.js', {
            cache: 'default',
          }).then(function (res) {
            return res.json();
          });
        },
        /**
         * Add some item into cart.
         *
         * @param {Object} data JSON object with data for to insert in cart.
         */
        addItem(data) {
          return fetch('/cart/add.js', {
            method: 'POST',
            body: data,
          }).then(function (res) {
            return res.json();
          });
        },
      },
    };
    $('.cross-sell__product-form').submit(function (e) {
      e.preventDefault();
      const form = this;
      const data = new FormData(this);

      methods.cart
        .addItem(data)
        .then(async function (item) {
          try {
            const cart = await methods.cart.getCart();
            const btn = form.querySelector('button');
            btn.disabled = 'disabled';
            location.reload();
          } catch (e) {
            console.error('[CART ERROR]', e);
          }
        })
        .catch(function (e) {
          console.error('[ADD ITEM ERROR]', e);
        });
    });
  });
</script>

{% schema %}
{
  "name": "Cross Sell",
  "class": "cross-sell",
  
  "settings": [
    {
      "type": "header",
      "content": "GENERAL"
    },
    {
      "type": "checkbox",
      "id": "enable_cross_sell_title",
      "label": "Enable Title"
    },
    {
      "type": "checkbox",
      "id": "enable_lazyload",
      "label": "Enable Lazyload",
      "default": false
    },
    {
      "type": "text",
      "id": "cross_sell_title",
      "label": "Title"
    },
    {
      "type": "range",
      "id": "title-font-size",
      "min": 10,
      "max": 50,
      "step": 1,
      "label": "Title Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "title-font-size-tablet",
      "min": 10,
      "max": 50,
      "step": 1,
      "label": "Title Font Size on Tablet",
      "default": 28
    },
    {
      "type": "collection",
      "id": "cross_sell_select_collection",
      "label": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show Price"
    },
    {
      "type": "checkbox",
      "id": "enable_product_card_border",
      "label": "Enable Product Card Border",
      "default": false
    },
    {
      "type": "range",
      "id": "product_card_border_radius",
      "label": "Product Card Border Radius",
      "info":"Only works if product card's border is enabled",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 5
    },
    {
      "type": "header",
      "content": "COLOR"
    },
    {
      "type": "color",
      "id": "title-color",
      "label": "Section Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border-color",
      "label": "Border Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "product-title-color",
      "label": "Product Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "swatch-color",
      "label": "Swatch Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "swatch-border-color",
      "label": "Swatch Border Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "price-color",
      "label": "Price Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "compare-price",
      "label": "Compare Price Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Cross Sell",
      "category": "Cross Sell"
    }
  ]
}
{% endschema %}
