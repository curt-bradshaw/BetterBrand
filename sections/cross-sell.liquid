    }

    .cross-sell__product-grid .slick-center .cross-sell__product-select {
      height: 21px;
      font-size: 15px;
      background-size: 11px;
      padding: 0 18px 0 8px;
      background-position-x: 92%;
    }

    .cross-sell__product-grid .cross-sell__product-form__submit {
      gap: 8px;
      padding-right: 0;
      padding-top: 3px;
    }

    .cross-sell__product-grid .slick-center .cross-sell__product-form__submit {
      justify-content: center;
      gap: 11px;
      padding-right: 1px;
      padding-top: 0;
    }

    .cross-sell__product-grid .slick-center .cross-sell__product-form__value {
      font-size: 21px;
      letter-spacing: -0.5px;
      padding-top: 3px;
    }

    .cross-sell__product-grid .cross-sell__product-button {
      width: 111px;
      height: 27px;
    }

    .cross-sell__product-grid .slick-center .cross-sell__product-button-text {
      padding-left: 0.7px;
    }
  }
  @media (max-width: 767px) {
    .cross-sell__product-grid {
    flex-wrap: wrap;
    }
    .cross-sell__product-card {
