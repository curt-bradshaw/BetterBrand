      flex-direction: column;
      justify-content: space-between;
      padding: 5px 0;
    }

    .cross-sell__product-grid .slick-center .cross-sell__product-form__swatches {
      width: 29.6%;
    }

    .cross-sell__product-grid .cross-sell__product-select {
      height: 17px;
      font-size: 11px;
      padding: 0 14px 1px 6px;
      background-position-x: 92%;
