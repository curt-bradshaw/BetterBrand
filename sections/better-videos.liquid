<!-- start of better-videos (section) -->
{% style %}
  .bfw-videos {
    padding: 80px 20px;
    text-align: center;
  }

  .bfw-videos__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .bfw-videos__heading {
    font-size: 38px;
    font-family: var(--bookmaniaFont);
    margin-bottom: 0;
    color: #252525;
    line-height: 1.2;
  }

  .bfw-videos__subheading {
    font-size: 20px;
    text-transform: capitalize;
    margin-bottom: 35px;
    color: #252525;
  }

  .bfw-videos__carousel-wrapper {
    position: relative;
    width: 100%;
  }

  .bfw-videos__carousel {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    padding: 10px 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    width: 100%;
  }

  .bfw-videos__carousel::-webkit-scrollbar {
    display: none;
  }

  .bfw-videos__embed {
    aspect-ratio: 9 / 16;
    border-radius: 18px;
    overflow: hidden;
    background: #000;
  }

  .bfw-videos__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: #fff;
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    cursor: pointer;
    z-index: 5;
  }

  .bfw-videos__arrow--prev { left: -30px; }
  .bfw-videos__arrow--next { right: -20px; }

  .bfw-videos__scrollbar {
    margin-top: 30px;
    padding: 0 20px;
  }

  .bfw-videos__scrollbar-track {
    width: 20%;
    margin: 0 auto;
    height: 4px;
    background: #E5E5E5;
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .bfw-videos__scrollbar-thumb {
    height: 100%;
    background: #234134;
    border-radius: 2px;
    position: absolute;
    left: 0;
    top: 0;
    transition: all 0.2s ease;
  }

  .bfw-videos__item {
    display: flex;
    justify-content: center;
    border-radius: 25px;
  }

  .bfw-videos__video-wrapper {
    max-width: 350px;
    transform: scale(0.9);
    transition: all 0.3s ease;
    border-radius: 25px;
    overflow: hidden;
    cursor: pointer;
  }

  .bfw-videos__video {
    border-radius: 25px;
  }

  .bfw-videos__item.is-active .bfw-videos__video-wrapper {
    transform: scale(1);
  }

  .bfw-videos__video-overlay {
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.43) 0%, rgba(0, 0, 0, 0.43) 100%);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .bfw-videos__video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    cursor: pointer;
  }

  .bfw-videos__video-sidebar-image {
    position: absolute;
    bottom: 20px;
    right: 15px;
    max-width: 50px;
  }

  .bfw-videos__arrow svg {
    fill: none;
    height: 0.9em;
    width: 0.9em;
  }

  .bfw-videos__arrow--next svg {
    transform: rotate(180deg);
  }

  @media (max-width: 1279px) {
    .bfw-videos .bfw-videos__arrow--prev { left: 40px; }
    .bfw-videos__arrow--next { right: 40px; }
    .bfw-videos {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  @media (max-width: 1019px) {
    .bfw-videos {
      padding: 40px 0px;
    }
    .bfw-videos__heading {
      font-size: 32px;
    }
    .bfw-videos__subheading {
      font-size: 18px;
    }
  }

  @media (max-width: 767px) {
    .bfw-videos__heading {
      font-size: 24px;
    }

    .bfw-videos .bfw-videos__arrow--prev {
      left: 20px;
    }
    .bfw-videos .bfw-videos__arrow--next {
      right: 20px;
    }

    .bfw-videos__scrollbar-track {
      width: 70%;
    }
  }
{% endstyle %}

<section class="bfw-videos" {{ section.shopify_attributes }}>
  <div class="bfw-videos__container">
    {% if section.settings.heading != blank %}
      <h2 class="bfw-videos__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="bfw-videos__subheading">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    <div class="bfw-videos__carousel-wrapper splide" id="bfw-videos-carousel-{{section.id}}">
      <div class="bfw-videos__carousel-track splide__track">
        <div class="bfw-videos__carousel-list splide__list">
          {% for block in section.blocks %}
            <div class="bfw-videos__item splide__slide" {{ block.shopify_attributes }}>
              <div class="bfw-videos__video-wrapper">
                <div class="bfw-videos__video-overlay"></div>
                <button class="bfw-videos__video-play-btn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="38" height="43" viewBox="0 0 38 43" fill="none">
                    <path d="M36.1549 18.2653C38.5355 19.6397 38.5355 23.0758 36.1549 24.4502L5.3563 42.2318C2.97573 43.6063 1.52588e-05 41.8882 1.52588e-05 39.1394V3.57618C1.52588e-05 0.827336 2.97573 -0.890699 5.3563 0.483725L36.1549 18.2653Z" fill="#D9D9D9" style="fill:#D9D9D9;fill:color(display-p3 0.8510 0.8510 0.8510);fill-opacity:1;"/>
                  </svg>
                </button>
                {% assign sidebar_index = forloop.index | modulo: 6 %}
                {% if sidebar_index == 0 %}{% assign sidebar_index = 6 %}{% endif %}
                <img src="{{ 'tiktok-sidebar-' | append: sidebar_index | append: '.png' | file_img_url: 'master' }}" class="bfw-videos__video-sidebar-image" loading="lazy">
                {{ block.settings.video | video_tag: class:'bfw-videos__video', image_size: '1000x', autoplay: false, loop: true, muted: false, controls: false, playsinline: true }}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="bfw-videos__carousel-nav splide__arrows">
        <button class="bfw-videos__arrow bfw-videos__arrow--prev splide__arrow splide__arrow--prev" aria-label="Previous">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18" fill="none">
            <path d="M1 17L9 9L0.999999 1" stroke="#1A1A1A" style="stroke:#1A1A1A;stroke:color(display-p3 0.1020 0.1020 0.1020);stroke-opacity:1;" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="bfw-videos__arrow bfw-videos__arrow--next splide__arrow splide__arrow--next" aria-label="Next">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18" fill="none">
            <path d="M9 17L1 9L9 1" stroke="#1A1A1A" style="stroke:#1A1A1A;stroke:color(display-p3 0.1020 0.1020 0.1020);stroke-opacity:1;" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="bfw-videos__scrollbar">
      <div class="bfw-videos__scrollbar-track">
        <div class="bfw-videos__scrollbar-thumb"></div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const currContainer = document.querySelector('#shopify-section-{{section.id}}');
    const sliderContainer = currContainer.querySelector('.bfw-videos__carousel-wrapper');
    const scrollbarThumb = currContainer.querySelector('.bfw-videos__scrollbar-thumb');
    const blocksQtt = {{ section.blocks.size }};
    const slider = new Splide(sliderContainer, {
      type: 'slide',
      perPage: 3,
      perMove: 1,
      start: 1,
      trimSpace: false,
      focus: 'center',
      pagination: false,
      breakpoints: {
        767: {
          perPage: 1,
          padding: '8%'
        }
      },
    });

    function updateScrollbar(newIdx, prevIdx, destIdx) {
      if (!scrollbarThumb || blocksQtt === 0) return;

      const totalCards = blocksQtt;
      const thumbWidth = 100 / totalCards;
      scrollbarThumb.style.width = `${thumbWidth * (destIdx + 1)}%`;
    }

    slider.on('moved', (newIdx, prevIdx, destIdx) => {
      updateScrollbar(newIdx, prevIdx, destIdx);
    });

    slider.on('mounted', () => {
      updateScrollbar(0, 0, 1);
    });

    slider.mount();

    const videosContainers = currContainer.querySelectorAll('.bfw-videos__video-wrapper');
    videosContainers.forEach(vContainer => {
      vContainer.addEventListener('click', () => {
        const video = vContainer.querySelector('.bfw-videos__video');
        if (video.paused) {
          videosContainers.forEach(container => {
            container.querySelector('.bfw-videos__video').pause();
            container.querySelector('.bfw-videos__video-overlay').style.display = 'block';
            container.querySelector('.bfw-videos__video-play-btn').style.display = 'block';
          });
          video.play();
          const playBtn = vContainer.querySelector('.bfw-videos__video-play-btn').style.display = 'none';
          const overlay = vContainer.querySelector('.bfw-videos__video-overlay').style.display = 'none';
        } else {
          video.pause();
          const playBtn = vContainer.querySelector('.bfw-videos__video-play-btn').style.display = 'block';
          const overlay = vContainer.querySelector('.bfw-videos__video-overlay').style.display = 'block';
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Better Videos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Better From Within"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pure Benefits Designed For Everyday Wellness"
    }
  ],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Better Videos"
    }
  ]
}
{% endschema %}
