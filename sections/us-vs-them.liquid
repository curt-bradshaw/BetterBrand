{% schema %}
  {
    "name": "US vs Them",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Title",
        "default": "US Vs. THEM"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subtitle",
        "default": "Lorem Ipsum Dolor Sit Amet Consectetur."
      },
      {
        "type": "image_picker",
        "id": "background",
        "label": "Background image"
      }
    ],
    "blocks": [
      {
        "type": "feature",
        "name": "Comparison line",
        "settings": [
          {
            "type": "text",
            "id": "label",
            "label": "Line text"
          }
        ]
      },
      {
        "type": "brand",
        "name": "Brand",
        "settings": [
          {
            "type": "image_picker",
            "id": "logo",
            "label": "Brand logo (optional)"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Brand name"
          },
          {
            "type": "select",
            "id": "highlight",
            "label": "Highlight",
            "options": [
              { "value": "false", "label": "Normal" },
              { "value": "true", "label": "Destacada" }
            ],
            "default": "false"
          },
          {
            "type": "textarea",
            "id": "values",
            "label": "Values (1 per line)",
            "info": "check | x | stars:5 | texto"
          }
        ]
      }
    ],
    "presets": [{ "name": "US vs Them" }]
  }
  {% endschema %}
  
  <section
    class="comparison"
    {% if section.settings.background %}
      style="background-image:url({{ section.settings.background | image_url: width: 2000 }});"
    {% endif %}
  >
    <div class="comparison__overlay"></div>
  
    <div class="comparison__container">
      <header class="comparison__header">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subheading }}</p>
      </header>
  
      <div class="comparison__wrapper">
        <div class="comparison__table">
          <div class="comparison__features">
            <div class="comparison__features-header"></div>
            {% for block in section.blocks %}
              {% if block.type == 'feature' %}
                {% assign label = block.settings.label | strip | downcase %}
                <div class="comparison__cell feature {% if label == 'approach' %}feature--rounded{% endif %}">
                  {{ block.settings.label }}
                </div>
              {% endif %}
            {% endfor %}
          </div>
  
          <div class="comparison__brands-container">
            {% for block in section.blocks %}
              {% if block.type == 'brand' %}
                {% assign values = block.settings.values | newline_to_br | split: '<br />' %}
                <div class="comparison__brand {% if block.settings.highlight == 'true' %}is-highlight{% endif %}">
                  <div class="comparison__brand-title">
                    {% if block.settings.logo %}
                      <img src="{{ block.settings.logo | image_url: width: 160 }}" alt="" width="" height="">
                    {% else %}
                      {{ block.settings.title }}
                    {% endif %}
                  </div>
  
                  {% for value in values %}
                    <div class="comparison__cell">
                      {% if value contains 'check' %}
                        {% if block.settings.highlight == 'true' %}
                          <span class="check-icon"> {% render 'icon-check-highlight' %} </span>
                        {% else %}
                          ✓
                        {% endif %}
                      {% elsif value == 'x' %}
                        ✕
                      {% elsif value contains 'stars' %}
                        {% assign star_count = value | split: ':' | last | plus: 0 %}
                        <span class="stars">
                          {% for i in (1..star_count) -%}
                            <span class="star">★</span>
                          {%- endfor %}
                        </span>
                      {% else %}
                        {{ value }}
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
  
        <!-- Paginador para mobile/tablet -->
        <div class="comparison__pagination">
          <span class="comparison__pagination-dot active"></span>
          <span class="comparison__pagination-dot"></span>
          <span class="comparison__pagination-dot comparison__pagination-dot-3"></span>
          <span class="comparison__pagination-dot comparison__pagination-dot-4"></span>
        </div>
      </div>
    </div>
  </section>
  
