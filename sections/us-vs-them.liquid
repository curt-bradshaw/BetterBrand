  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const paginationDots = document.querySelectorAll('.comparison__pagination-dot');
      const brandCards = document.querySelectorAll('.comparison__brand');
  
      if (paginationDots.length === 0 || brandCards.length === 0) return;
  
      let activeIndex = Array.from(paginationDots).findIndex((dot) => dot.classList.contains('active'));
      if (activeIndex === -1) activeIndex = 0;
  
      function activateBrand(index) {
        const brandsContainer = document.querySelector('.comparison__brands-container');
        if (brandsContainer) {
          brandsContainer.style.scrollSnapType = 'none';
        }
  
        paginationDots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
  
        if (brandCards[index] && brandsContainer) {
          const cardLeft = brandCards[index].offsetLeft;
          const containerLeft = brandsContainer.offsetLeft;
          const scrollLeft = cardLeft - containerLeft - 5; 
  
          brandsContainer.scrollTo({
            left: scrollLeft,
            behavior: 'smooth',
          });
  
          setTimeout(() => {
            if (brandsContainer) {
              brandsContainer.style.scrollSnapType = 'x mandatory';
            }
          }, 500);
        }
  
        activeIndex = index;
      }
  
      paginationDots.forEach((dot, index) => {
        dot.addEventListener('click', function () {
          activateBrand(index);
        });
      });
  
      const brandsContainer = document.querySelector('.comparison__brands-container');
      if (brandsContainer) {
        brandsContainer.addEventListener('scroll', function () {
          clearTimeout(brandsContainer.scrollTimeout);
          brandsContainer.scrollTimeout = setTimeout(() => {
            const scrollLeft = brandsContainer.scrollLeft;
            const cardWidth = brandCards[0]?.offsetWidth || 200;
            const gap = 5;
            const newIndex = Math.round(scrollLeft / (cardWidth + gap));
  
            if (newIndex >= 0 && newIndex < paginationDots.length && newIndex !== activeIndex) {
              paginationDots.forEach((dot, i) => {
                dot.classList.toggle('active', i === newIndex);
              });
              activeIndex = newIndex;
            }
          }, 100);
        });
      }
  
      activateBrand(activeIndex);
    });
  </script>
  