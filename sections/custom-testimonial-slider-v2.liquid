<div class="ntg-testimonial-section ntg-testimonial-section-v2">
  <div class="ntg-container">
    <div class="ntg-heading-holder">
      <h2 class="ntg-h2">{{ section.settings.heading }}</h2>
      <p>{{ section.settings['sub-heading'] }}</p>
    </div>
    <div class="ntg-testimonial-swiper-holder">
      <div class="ntg-testimonial-swiper ntg-testimonial-swiper-v2">
        <div class="sw-testmonial-v2">
          {% for block in section.blocks %}
            <div class="sw-testmonial-wrap">
              <div class="sw-testmonial-elm">
                {% if block.settings.image != blank %}
                  <div class="ntg-img-holder">
                    <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image }}">
                  </div>
                {% endif %}
                
                

                <div class="ntg-text-holder">
                   <div class="tw-top-elm">
                      <div class="tw-top-info">
                        <span class="ntg-name">{{ block.settings.review_author }}</span>
                          
                      </div>
                      <div class="tw-ver-elm">
                          <span>Verified</span>
                      </div>
                    </div>
                      <div class="tw-stars-time">
                        <ul class="ntg-star-list">
                              <li>
                                {% render 'star-v2' %}
                              </li>
                              <li>
                                {% render 'star-v2' %}
                              </li>
                              <li>
                                {% render 'star-v2' %}
                              </li>
                              <li>
                                {% render 'star-v2' %}
                              </li>
                              <li>
                                {% render 'star-v2' %}
                              </li>
                            </ul>
                            {% if block.settings.item_type != blank %}
                              <span class="ntg-small"
                                > <span class="ntg-item">{{ block.settings.item_type }}</span></span
                              >
                          {% endif %}
                      </div>

                  <h3 class="ntg-h3">{{ block.settings.review_title }}</h3>
                  {{ block.settings.review_text }}
                  
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-nav">
                    <div class="swiper-button-prev">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14.8">
                            <path d="M19.8 6.8c-.1-.1-.3-.2-.6-.2H2.7L8 1.3c.1-.1.2-.3.2-.5S8.1.4 8 .2C7.8.1 7.6 0 7.4 0c-.2 0-.4.1-.6.2L.2 6.8c-.1.2-.2.4-.2.6 0 .1 0 .2.1.3 0 .1.1.2.2.3l6.6 6.6c.1.1.2.1.3.2.1 0 .2.1.3.1.2 0 .3 0 .4-.1.1-.1.2-.2.3-.4.1-.1.1-.3 0-.5 0-.2-.1-.3-.2-.4L2.7 8.2h16.6c.2 0 .4-.1.6-.2 0-.2.1-.4.1-.6s-.1-.4-.2-.6z" fill="#231f20"/>
                        </svg>
                    </div>
                    <div class="swiper-button-next">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14.8">
                            <path d="M20 7.4c0-.2-.1-.4-.2-.6L13.2.2c-.2-.1-.4-.2-.6-.2-.2 0-.4.1-.6.2-.1.1-.2.3-.2.6 0 .2.1.4.2.6l5.3 5.3H.8c-.2 0-.4.1-.6.2-.1.1-.2.3-.2.5s.1.4.2.6c.1.1.3.2.6.2h16.6l-5.3 5.3c-.1.1-.2.2-.2.4v.5c.1.1.2.3.3.4.1.1.3.1.4.1.1 0 .2 0 .3-.1.1 0 .2-.1.3-.2L19.8 8c.1-.2.2-.4.2-.6z" fill="#231f20"/>
                        </svg>
                    </div>
                </div>
      </div>
    </div>
  </div>
</div>
<style>
      #shopify-section-{{ section.id }}{
        .ntg-testimonial-swiper-holder{
          padding:0;
        }
        @media (max-width: 990px) {
          .swiper-nav{
            display:none !important;
          }
        }

          .ntg-testimonial-swiper-v2{
              padding:0;   
          }

          .sw-testmonial-v2{
            display: flex;
            flex-direction: column;
            gap: 16px;
            padding: 5px;
          }
        .ntg-heading-holder{
          display: flex;
          flex-direction: column;
        }

        .sw-testmonial-elm {
          display: flex;
          gap:10px;

          img{
            width:54px;
            height:54px;
            border-radius:50%;
            min-width: 54px;
          }
        }

        .tw-stars-time{
          display: flex;
          gap:10px;
          margin: 10px 0;
          span.ntg-item{
            color: #091913;
            font-family: Inter;
            font-size: 11.9px;
            font-style: normal;
            font-weight: 400;
            line-height: 20px; /* 168.067% */
          }
        }

        .sw-testmonial-wrap {
            border-radius: 8px;
            background: #FFF;
            box-shadow: 0 -1px 3px -1px rgba(0, 0, 0, 0.05), 0 2px 10px -2px rgba(0, 0, 0, 0.10);
            padding:16px;
            
          }

      .ntg-text-holder  {
        .ntg-h3{
          margin:0;
          color: #233F21;
          font-family: Inter;
          font-size: 15.3px;
          font-style: normal;
          font-weight: 600;
          line-height: 28px; /* 183.007% */
        }

        p{
            color: #091913;
            font-family: Inter;
            font-size: 11.9px;
            font-style: normal;
            font-weight: 400;
            line-height: 22px; /* 184.874% */
        }

        .tw-ver-elm span{
          color: #233F21;
          font-family: Inter;
          font-size: 11.9px;
          font-style: normal;
          font-weight: 500;
          line-height: 20px; /* 168.067% */
          border-radius: 4px;
          background: #F3F9F1;
          padding:6px 12px;
          box-shadow: 0 -1px 2px -1px rgba(0, 0, 0, 0.05), 0 1px 3px -1px rgba(0, 0, 0, 0.10);
        }
        
        }

        .tw-top-elm {
          display: flex;
          justify-content: space-between;
        }

     @media (min-width: 990px) {

        .sw-testmonial-v2{
          flex-direction: row;
          gap:0;
        }


     

  .ntg-testimonial-swiper .swiper-nav{
      position: absolute;
      z-index: 2;
      -webkit-transform: translateY(-50%);
      -ms-transform: translateY(-50%);
      transform: translateY(-50%);
      -webkit-box-pack: justify;
      -ms-flex-pack: justify;
      justify-content: space-between;
      height: max-content;
      padding: 0;

       > div {
        display: flex;
        width: 36px !important;
        height: 36px !important;
        padding: 6px;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
        border-radius: 9999px;
        background: #ffffffe6 !important;
        box-shadow: 0 -1px 2px -1px #0000000d,0 2px 6px -1px #0000001a;
      }
    
  }


</style>
{% schema %}
{
  "name": "Custom Testimonial Slider",
  "class": "custom-testimonial-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dont Just Take Our Word..."
    },
    {
      "type": "text",
      "id": "sub-heading",
      "label": "Sub Heading",
      "default": "Loved by thousands across the globe"
    }
  ],
  "blocks": [
    {
      "type": "select",
      "name": "review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "review_author",
          "label": "Review Author Name"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review Title"
        },
        {
          "type": "richtext",
          "id": "review_text",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "item_type",
          "label": "Review time"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Testimonial Slider",
      "category": "Custom Sections",
      "blocks": [
        {
          "type": "select"
        },
        {
          "type": "select"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
