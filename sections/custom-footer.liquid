<footer class="ntg-footer">
    <div class="ntg-container">
        <div class="ntg-footer-block footer-social-block">
              
            {%- comment -%}
              <div class="ntg-text-holder">
                  <h2 class="ntg-h2">{{ section.settings.signup_header }}</h2>
                  {{ section.settings.signup_content }}
              </div>



              {%- form 'customer', id: 'ContactFooter', class: 'ntg-subscribe-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="ntg-form-row">
                    <div class="ntg-input-holder">
                      <input type="email" placeholder="{{ section.settings.signup_placeholder }}" name="contact[email]" 
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        {% if form.errors %}
                          autofocus
                          aria-invalid="true"
                          aria-describedby="ContactFooter-error"
                        {% elsif form.posted_successfully? %}
                          aria-describedby="ContactFooter-success"
                        {% endif %}
                        required
                      >
                    </div>
                    <input type="submit" value="{{ section.settings.signup_submit }}">
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="ContactFooter-error">
                      {%- render 'icon-error' -%}
                      {{- form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    style="color: #fff;"
                    autofocus
                  >
                    {% render 'icon-success' -%}
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}
            {%- endcomment -%}

          
