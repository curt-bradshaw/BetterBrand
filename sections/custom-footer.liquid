        </div>
        <div class="ntg-footer-area">
            <div class="accordion-container">
              {% for block in section.blocks %}
                <div class="ac">
                    <div class="ac-header">
                        <button type="button" class="ac-trigger">
                            <span class="ntg-opener-text">{{ block.settings.menu_title }}</span>
                            <span class="ntg-icon"></span>
                        </button>
                    </div>
                    <div class="ac-panel">
                        <div class="ntg-accordion-content">
                            <ul class="ntg-footer-list">
                              {% for link in linklists[block.settings.footer_menu].links -%}
                                <li><a href="{{ link.url }}"><span class="ntg-text">{{ link.title }}</span></a></li>
                              {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
              {% endfor %}
              
               
            </div>
        </div>
        <div class="ntg-copy-text">
            &copy; {{  "now" | date: '%Y' }} <a href="/">Betterbrand</a>.<br>
            {{ section.settings.footer_copyright }}
        </div>
    </div>
</footer>
<a href="#top" id="scroll" role="button" aria-label="scroll top button" style="display: none;"><span></span></a>


<script>

  // Get the scroll button element
const scrollButton = document.getElementById('scroll');

// Add scroll event listener to window
window.addEventListener('scroll', function() {

    // Get current scroll position
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    if (scrollTop > 100) {
        // Show the scroll button (fade in effect)
      scrollButton.style.display = 'block';

    } else {
        // Hide the scroll button (fade out effect)
        scrollButton.style.display = 'none';
    }
});

// Add click event listener to scroll button
scrollButton.addEventListener('click', function(e) {
    // Prevent default behavior
    e.preventDefault();
    
    // Smooth scroll to top
    window.scrollTo({
        top: 0,
        behavior: 'smooth'
    });
    
    return false;
});

// Optional: Add CSS transition for smooth fade effect
// You can add this to your CSS file:
/*
#scroll {
    transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    opacity: 0;
    visibility: hidden;
}
*/
</script>

{% schema %}
  {
    "name": "Custom Footer",
    "settings": [
      {
        "type": "header",
        "content": "Signup Form"
      },
      {
        "type": "text",
        "id": "signup_header",
        "label": "Signup form Heading",
        "default": "Sign up for 25% discount"
      },
      {
        "type": "richtext",
        "id": "signup_content",
        "label": "Signup form Textarea",
        "default": "<p>Join our newsletter and gain privileged access to exclusive offers, sneak peeks, and $20 off your first order!</p>"
      },
      {
        "type": "text",
        "id": "signup_placeholder",
        "label": "Signup form text placeholder",
        "default": "Enter your email"
      },
      {
        "type": "text",
        "id": "signup_submit",
        "label": "Signup form Submit text",
        "default": "Get My Discount Now"
      },
      {
        "type": "header",
        "content": "Footer Store loactor menu"
      },
      {
        "type": "text",
        "id": "store_menu_title",
        "label": "Store Locator menu title"
      },
      {
        "type": "link_list",
        "id": "store_link",
        "label": "Store Locator menu"
      },
      {
        "type": "richtext",
        "id": "footer_copyright",
        "label": "Footer copyright text"
      }
    ],
    "blocks": [
      {
        "type": "select",
        "name": "Footer-menu",
        "settings": [
          {
            "type": "text",
            "id": "menu_title",
            "label": "Footer menu Title"
          },
          {
            "type": "link_list",
            "id": "footer_menu",
            "label": "Footer menu"
          }
        ]
      }
    ]
  }
{% endschema %}