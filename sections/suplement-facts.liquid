{% assign section_data = product.metafields.pdp.ingredients_section.value %}
{% assign heading = section_data.heading %}
{% assign subheading = section_data.subheading %}

{% if section_data %}
<section class="supplement">
  <div class="supplement__container">
    <header class="supplement__header">
      <h2>{{ heading }}</h2>
      <p>{{ subheading }}</p>
    </header>

    <div class="supplement__grid">
      <!-- COLUNA ESQUERDA -->
      <div class="supplement__side">
        {% for i in (1..10) %}
          {% assign title = 'title_' | append: i %}
          {% assign description = 'description_' | append: i %}
          {% assign image = 'image_' | append: i %}
          {% unless section_data[image] == blank %}
            <div class="info-card">
              <img
                src="{{ section_data[image] | image_url: width: 600 }}"
                alt="{{ section_data[title] }}"
                loading="lazy"
              >

              <div class="info-card__overlay">
                <h3>{{ section_data[title] }}</h3>
                <p>{{ section_data[description] }}</p>
              </div>
            </div>
          {% endunless %}
        {% endfor %}
      </div>

      <!-- COLUNA DIREITA -->
      <div class="supplement__facts">
        <img
          src="{{ section_data.product_label | image_url: width: 900 }}"
          alt="Supplement Facts"
          loading="lazy"
        >
      </div>
    </div>
  </div>
</section>

<style>
  /* ================= WRAPPER ================= */

  .supplement {
    padding: 80px 0;
  }

  .supplement__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    align-items: center;
    display: flex;
    flex-direction: column;
  }

  .supplement__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .supplement__header h2 {
    font-family: var(--bookmaniaFont);
    font-size: 38px;
    margin-bottom: 12px;
    font-weight: 700;
    line-height: 12.6px;
  }

  .supplement__header p {
    font-size: 20px;
    max-width: 800px;
    margin: 0 auto;
    font-weight: 400;
    color: #252525;
    text-align: center;
  }

  /* ================= GRID ================= */

  .supplement__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 35px;
    align-items: stretch;
    max-width: 1180px;
  }

  /* ================= LEFT ================= */

  .supplement__side {
    display: grid;
    {% if section_data.image_2 != blank %}
      grid-template-rows: 1fr 1fr;
    {% else %}
      align-items: center;
      grid-template-rows: 1fr;
    {% endif %}
    gap: 24px;
    max-width: 395px;
  }

  .info-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    height: 100%;
    max-height: 356px;
  }

  .info-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info-card__overlay {
    position: absolute;
    inset: 0;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4));
    color: #fff;
  }

  .info-card__overlay h3 {
    font-size: 24px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 10px;
    text-align: center;
    color: #fff;
  }

  .info-card__overlay p {
    font-size: 18px;
    line-height: 1.2;
    text-align: center;
    color: #fff;
    font-weight: 400;
  }

  /* ================= RIGHT ================= */

  .supplement__facts {
    display: flex;
    align-items: start;
    justify-content: center;
    max-width: 750px;
    width: max-content;
    position: relative;
  }

  .supplement__facts img {
    width: 100%;
    height: auto;
    display: block;
    position: sticky;
    top: 10px;
  }

  /* ================= TABLET (768px - 1024px) ================= */
  @media (max-width: 1099px) {
    .supplement {
      padding: 60px 0;
    }

    .supplement__container {
      padding: 0 32px;
    }

    .supplement__header {
      margin-bottom: 40px;
    }

    .supplement__header h2 {
      font-size: 32px;
      margin-bottom: 8px;
    }

    .supplement__header p {
      font-size: 16px;
      line-height: 1.4;
    }

    .supplement__grid {
      grid-template-columns: 1fr;
      gap: 15px;
      max-width: 100%;
    }

    .supplement__side {
      {% if section_data.image_2 != blank %}
        grid-template-rows: 1fr 1fr;
      {% else %}
        align-items: center;
        grid-template-rows: 1fr;
      {% endif %}
      max-width: 100%;
    }

    .info-card {
      max-height: 300px;
    }

    .info-card__overlay {
      padding: 24px 16px;
    }

    .info-card__overlay h3 {
      font-size: 20px;
    }

    .info-card__overlay p {
      font-size: 16px;
      line-height: 1.3;
    }

    .supplement__facts {
      max-width: 100%;
      width: 100%;
    }
  }

  /* ================= MOBILE (até 768px) ================= */
  @media (max-width: 767px) {
    .supplement {
      padding: 40px 0;
    }

    .supplement__container {
      padding: 0 16px;
    }

    .supplement__header {
      margin-bottom: 32px;
      text-align: left;
    }

    .supplement__header h2 {
      font-size: 38px;
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 8px;
      text-align: center;
    }

    .supplement__header p {
      font-size: 18px;
      font-weight: 400;
      line-height: 1.3;
      margin: 0;
    }

    .supplement__grid {
      gap: 32px;
    }

    .supplement__side {
      gap: 16px;
    }

    .info-card {
      max-height: 250px;
      border-radius: 12px;
    }

    .info-card__overlay {
      padding: 20px 16px;
      background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5));
    }

    .info-card__overlay h3 {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.2;
    }

    .info-card__overlay p {
      font-size: 16px;
      line-height: 1.3;
      font-weight: 400;
    }

    .supplement__facts {
      width: 100%;
    }

    .supplement__facts img {
      max-width: 100%;
      width: 100%;
      position: relative;
    }
  }

  /* ================= SMALL MOBILE (até 480px) ================= */
  @media (max-width: 480px) {
    .supplement__header h2 {
      font-size: 24px;
    }

    .supplement__side {
      {% if section_data.image_2 != blank %}
        grid-template-rows: 1fr 1fr;
      {% else %}
        align-items: center;
        grid-template-rows: 1fr;
      {% endif %}
      gap: 15px;
    }

    .info-card {
      height: 100%;
      max-height: 293px;
    }

    .info-card__overlay {
      padding: 25px 20px;
    }

    .info-card__overlay h3 {
      font-size: 20px;
    }

    .info-card__overlay p {
      font-size: 16px;
    }

    .supplement__grid {
      gap: 15px;
    }
  }
</style>
{% endif %}

{% schema %}
  {
    "name": "Supplement Facts",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Title",
        "default": "Lorem Ipsum Dolor"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subtitle",
        "default": "Lorem Ipsum Dolor Sit Amet Consectetur"
      }
    ],
    "blocks": [
      {
        "type": "info_card",
        "name": "Card lateral",
        "settings": [
          { "type": "image_picker", "id": "image", "label": "Imagem" },
          { "type": "text", "id": "title", "label": "Título" },
          { "type": "textarea", "id": "text", "label": "Texto" }
        ]
      },
      {
        "type": "facts",
        "name": "Supplement Facts",
        "settings": [{ "type": "image_picker", "id": "image", "label": "Imagem da tabela" }]
      }
    ],
    "presets": [
      {
        "name": "Supplement Facts"
      }
    ]
  }
  {% endschema %}