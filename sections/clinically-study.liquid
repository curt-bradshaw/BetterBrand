<!-- START clinically-study.liquid -->

{% if product.metafields.pdp.show_clinically_study_section %}

<div class="clinically-study-section">
    <div class="clinically-study-title-container">
      <h2 class="clinically-study-heading">{{ section.settings.heading }}</h2>
      <p class="clinically-study-subheading">{{ section.settings.subheading }}</p>
    </div>
    <div class="clinically-study-grid">
      {% for block in section.blocks %}
        <div class="clinically-study-item">
          <div class="clinically-study-percentage-wrapper">
            <p class="clinically-study-percentage">{{ block.settings.study_percentage }}%</p>
          </div>
          <div class="clinically-study-content">
            <h3 class="clinically-study-title">{{ block.settings.study_value }}</h3>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="clinically-study-cta-wrapper">
      <a href="{{ section.settings.cta_url }}" target="_blank" class="clinically-study-cta-button">
        <span class="clinically-study-cta-text">{{- section.settings.cta_text -}}</span>
      <span class="patrol-sr-only patrol-blank-target">, opens in a new tab</span></a>
    </div>
  </div>
  
  {% style %}
  .ntg-wrapper p {
    margin: 0 0 35px;
  }

  .clinically-study-section {
    text-align: center;
    max-width: 1220px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  
  .clinically-study-heading {
    font-size: 38px;
    font-weight: 700;
    margin-bottom: 4px;
    font-family: var(--bookmaniaFont);
    color: #252525;
    line-height: 1.2;
  }
  
  .clinically-study-subheading {
    font-size: 20px;
    max-width: 700px;
    margin: 0 auto;
    text-transform: capitalize;
    color: #252525;
  }

  .clinically-study-title-container {
    margin-bottom: 35px;
  }
  
  .clinically-study-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 52px;
  }
  
  .clinically-study-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #F0FFE95C;
    border-radius: 16px;
    padding: 15px;
  }

  .clinically-study-percentage-wrapper {
    flex-shrink: 0;
    margin-bottom: 20px;
  }
  
  .clinically-study-percentage-wrapper p {
    font-size: 40px;
    font-weight: 400;
    color: #0A0A0A;
    line-height: 1.2;
  }
  
  .clinically-study-title {
    color: #252525;
    font-weight: 400;
    font-size: 18px;
    text-transform: capitalize;
    line-height: 1.2;
  }

  .clinically-study-cta-button {
    display: flex;
    padding: 25px 32px;
    align-items: center;
    border-radius: 40px;
    border: 1px solid #234134;
    margin: 0 auto;
    margin-top: 35px;
    width: fit-content;
  }

  .clinically-study-cta-text {
    color: #234134;
    text-align: center;
    font-size: 20px;
    font-weight: 400;
    line-height: 18px;
  }
  
  @media (max-width: 1019px) {
    .clinically-study-section {
      padding: 60px 20px 10px;
    }
    
    .clinically-study-grid {
      grid-template-columns: repeat(2, 256px);
      row-gap: 35px;
      column-gap: 20px;
      justify-content: center;
    }
    .clinically-study-percentage-wrapper p {
      font-size: 38px;
    }

    .clinically-study-heading {
      font-size: 38px;
    }

    .clinically-study-subheading {
      max-width: 650px;
      font-size: 18px;
    }

    .clinically-study-title {
      font-size: 16px;
    }

    .clinically-study-cta-text {
      font-size: 16px;
    }

    .clinically-study-text {
      font-size: 16px;
    }

    .ntg-wrapper p {
      margin: 0;
    }

    .clinically-study-title-container {
      margin-bottom: 35px;
    }

    .clinically-study-cta-button {
      padding: 24px 32px;
    }
  }

  @media (max-width: 767px) {
    .clinically-study-section {
      padding: 40px 20px 30px;
    }
    .clinically-study-title-container {
      max-width: 295px;
      margin: 0 auto;
    }
    .clinically-study-grid {
      grid-template-columns: repeat(1, 1fr);
      gap: 20px;
      margin-top: 35px;
    }
    .clinically-study-item {
      flex-direction: row;
      align-items: center;
      gap: 20px;
    }
    .clinically-study-content {
      text-align: left;
    }
    .clinically-study-title {
      font-size: 14px;
    }
    .clinically-study-heading {
      max-width: 280px;
      text-align: center;
      font-size: 24px;
    }
    .clinically-study-subheading {
      text-align: center;
      font-size: 18px;
    }
    .clinically-study-text {
      font-size: 14px;
    }
    .clinically-study-percentage-wrapper {
      margin-bottom: 0;
    }
    .clinically-study-percentage-wrapper p {
      font-size: 36px;
    }
  }
  {% endstyle %}
  {% endif %}

  {% schema %}

{
  "name": "Clinically Study",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinically Studied. Proven Results."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "In a 60-day clinical study, participants using our Mullein + Chlorophyll Tincture reported real results:"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "See Full Results Here"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL",
    }
  ],
  "blocks": [
    {
      "type": "study_item_value",
      "name": "Study Item Value",
      "settings": [
        {
          "type": "number",
          "id": "study_percentage",
          "label": "Study Percentage",
        },
        {
          "type": "text",
          "id": "study_value",
          "label": "Study Value",
          "default": "Study Value"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Clinically Study",
      "blocks": [
        {
          "type": "study_item_value",
          "name": "Study Item Value",
          "settings": {
            "study_percentage": 81,
            "study_value": "Experienced Less frequent coughing."
          }
        },
        {
          "type": "study_item_value",
          "name": "Study Item Value",
          "settings": {
            "study_percentage": 77,
            "study_value": "noticed clearer airways."
          }
        },
        {
          "type": "study_item_value",
          "name": "Study Item Value",
          "settings": {
            "study_percentage": 73,
            "study_value": "had easier mucus clearance."
          }
        },
        {
          "type": "study_item_value",
          "name": "Study Item Value",
          "settings": {
            "study_percentage": 68,
            "study_value": "reported improved sleep quality."
          }
        }
      ]
    }
  ]
}

{% endschema %}
  