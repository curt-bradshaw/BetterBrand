{{ 'component-rating.css' | asset_url | stylesheet_tag }}

<div class="trust-section-top">
<section
  style="padding-top:0; margin-bottom:0"
  class="BAD-how-to-use-section trust-section"
>
  <h2 style="color: {{ section.settings.text_color }};" class="BAD-howto-Header">{{ section.settings.heading }}</h2>
  <div class="BAD-how-to-use-container ">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'step' %}
          <div class="BAD-how-to-use-step BAD-how-to-use-step-{{forloop.index}} {% if forloop.first == false %} ntg-desktop-block {% endif %}">
            {% if block.settings.step_image %}
              <img
                src="{{ block.settings.step_image | img_url: 'medium' }}"
                alt="{{ block.settings.step_title }}"
                class="BAD-step-image"
              >
            {% endif %}
            <h3 class="BAD-step-title">{{ block.settings.step_title }}</h3>
            
            
            {% if forloop.first == true %}
              <div class="ntg-mobile-block" style="margin: 20px auto;">
                <div class="" style="width: 100%;display: flex;align-items: center;gap: 20px;">
                  {% for block in section.blocks %}
                    {% case block.type %}
                      {% when 'step' %}
                        {% if forloop.first == false %}
                            {% if block.settings.step_image %}
                              <img
                                src="{{ block.settings.step_image | img_url: 'medium' }}"
                                alt="{{ block.settings.step_title }}"
                                class="BAD-step-image"
                              >
                            {% endif %}
                        {% endif %}
                    {% endcase %}
                  {% endfor %}
                  </div>
              </div>
            {% endif %}


            <p class="BAD-step-description">{{ block.settings.step_description }}</p>
            {% if block.settings.txt_1 != blank %}
              <div class="img-itms-cont">
                  <div class="img-itms">
                    {% for i in (1..3) %}
                      
                        {% assign image_key = 'image_' | append: forloop.index %}
                        {% assign image = block.settings[image_key] %}

                        {% assign txt_key = 'txt_' | append: forloop.index %}
                        {% assign text = block.settings[txt_key] %}

                        {% assign width_key = 'width_' | append: forloop.index %}
                        {% assign width = block.settings[width_key] %}

                        {% if image != blank %}
                          
                            <div class="image-container">
                              <img 
                                src="{{ image | image_url: width: 400 }}" 
                                alt="Benefit {{ forloop.index }}"
                                width="{{ image.width }}" height="{{ image.height }}"
                                style="width:{{ width }}px"
                                loading="lazy"
                                class="benefit-image"
                              >
                                <p>
                                  {{ text }}
                                </p>
                            </div>
                            
                        {% endif %}
                    {% endfor %} 
                </div> 
              </div>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
 
</section>
</div>

<style>

#shopify-section-{{ section.id }}{
    padding-top: 60px !important;
    padding-bottom: 0 !important;
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }}{
      padding-top: 10px !important;
      padding-bottom: 0 !important;
  }
}

#shopify-section-{{ section.id }} {
  background: transparent;
}

#shopify-section-{{ section.id }} .BAD-how-to-use-section {
  padding: 60px 0 0;
  text-align: center;
}

#shopify-section-{{ section.id }} .BAD-how-to-use-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
  margin-top: 0;
}

#shopify-section-{{ section.id }} .BAD-howto-Header {
  color: var(--Bottle-Green, #234134);
  text-align: center;
  font-family: bookmania;
  font-size: 27px;
  font-style: normal;
  font-weight: 700;
  line-height: 23.406px; /* 93.622% */
}

#shopify-section-{{ section.id }} .BAD-how-to-use-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: unset;
  text-align: center;
}

#shopify-section-{{ section.id }} .BAD-step-image {
  width: auto;
  height: auto;
  margin-bottom: 10px;
  border-radius: 0;
  border: 1px solid var(--Bottle-Green, #234134);
}

#shopify-section-{{ section.id }} .BAD-step-title {
  font-size: 18px;
  font-weight: bold;
}

#shopify-section-{{ section.id }} .BAD-step-description {
  font-size: 14px;
  font-weight: 600;
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .ntg-wrapper .ntg-video-swiper-section {
    padding: 0;
  }

  #shopify-section-{{ section.id }} .BAD-step-title {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .BAD-how-to-use-section {
    padding: 20px;
  }

  #shopify-section-{{ section.id }} .BAD-how-to-use-container {
    flex-direction: column;
    align-items: center;
    gap: 20px 0;
  }

  #shopify-section-{{ section.id }} .BAD-howto-Header {
    font-size: 20px;
  }
}

#shopify-section-{{ section.id }} .ntg-heading-holder h2 {
  font-family: 'GrotesqueMT';
  font-weight: 400;
  font-style: Condensed;
  font-size: 38px;
  leading-trim: NONE;
  line-height: 100%;
  letter-spacing: 0%;
  text-align: center;
}

@media (min-width: 768px) {
  #shopify-section-{{ section.id }} .swiper-wrapper {
    padding-left: 25px;
  }

  #shopify-section-{{ section.id }} .swiper-slide.swiper-slide-prev {
    margin-left: -25px !important;
  }

  #shopify-section-{{ section.id }} .swiper-slide.swiper-slide-next {
    margin-right: -1px !important;
  }
}

#shopify-section-{{ section.id }} .ntg-video-btn {
  background: #234134;
  box-shadow: 5px 4px 10px rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(11px);
  border-radius: 82px;
  font-family: Suisse_Intl_Mono;
  font-weight: 700;
  font-style: Bold;
  font-size: 17px;
  leading-trim: NONE;
  line-height: 100%;
  letter-spacing: 0%;
  color: #F2CB49;
  padding: 20px;
}

#shopify-section-{{ section.id }} .ntg-video-btn:after,
#shopify-section-{{ section.id }} .ntg-video-btn:before {
  display: none;
}

#shopify-section-{{ section.id }} .trust-section h1,
#shopify-section-{{ section.id }} .trust-section h2,
#shopify-section-{{ section.id }} .trust-section h3 {
  color: #234134 !important;
}

#shopify-section-{{ section.id }} .trust-section p {
  color: #234134 !important;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-container {
  justify-content: space-between;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-container .BAD-how-to-use-step {
  justify-content: center;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 {
  justify-content: center;
  align-items: flex-start;
  text-align: left;
  position: relative;
  flex: 0 0 50%;
  max-width: 50%;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 h3 {
  color: var(--Color, #234134);
  font-family: Inter;
  font-size: 30px;
  font-style: normal;
  font-weight: 700;
  line-height: normal;
  position: relative;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 h3::before {
  position: absolute;
  content: "";
  width: 70px;
  height: 4px;
  left: 0;
  bottom: -20px;
  background: #F2CB49;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 .BAD-step-description {
  margin-bottom: 0;
  font-family: 'suisse_intl';
  font-size: 18px;
  line-height: 130%;
  max-width: 500px;
}

#shopify-section-{{ section.id }} .trust-section .BAD-step-image {
  max-width: 130px;
  border: none;
  margin: 0;
}

@media (min-width: 768px) {
  #shopify-section-{{ section.id }} .BAD-how-to-use-container {
    padding: 0 70px;
  }
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .trust-section h3::before {
    left: 50% !important;
    transform: translate(-50%, 0);
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-step-description {
    margin: 20px auto 0 !important;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .trust-section {
    padding: 0;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-container {
    flex-direction: row;
    padding-left: 0;
    justify-content: space-evenly;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 {
    padding-left: 10px;
    flex: 0 0 100%;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 h3 {
    font-size: 20px;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1::before {
    left: -8px;
    width: 12px;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-step-image {
    max-width: 100px;
  }
}
</style>


{% schema %}
{
  "name": "Trust Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How To Use"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F0FAEB"
    },
    {
      "type": "text",
      "id": "btn_txt",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Url"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step Image"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "Step description text goes here."
        },
        {
          "type": "text",
          "id": "txt_1",
          "label": "text 1",
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "range",
          "id": "width_1",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "width",
          "default": 36
        },
        {
          "type": "text",
          "id": "txt_2",
          "label": "text 2",
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "range",
          "id": "width_2",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "width",
          "default": 36
        },
        {
          "type": "text",
          "id": "txt_3",
          "label": "text 3",
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        },
        {
          "type": "range",
          "id": "width_3",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "width",
          "default": 36
        }
      
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Section",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}
{% endschema %}
