<!-- start custom-your-journey.liquid (SECTION) -->

<style>
   .container {
     display: flex;
     flex-direction: column;
     align-items: center;
     padding: 0 25px;
     margin-top: 60px;
   }
  .section_4{
   	float:left;
   	width:100%;
   	padding:10px 0 30px;
   	background: white;
   	overflow-x: clip;
    /* margin-bottom: 40px; */
   	position:relative;
   	}
   .BAD_product1{
   	position: absolute;
   		left: -230px;
   		top: -8px;
   		transform: rotate(-12deg);
   	}
   .BAD_product2{
   	position:absolute;
   	right:-410px;
   	top:480px;
   	}
   .BAD_product3{
   	position:absolute;
   	left:-425px;
   	top:890px;
   	}
   .section_4 .common_heading{ position:relative; z-index:1;}
   .sec4_mid{
   	display:inline-block;
   	vertical-align:middle;
   	width:100%;
   	max-width:1030px;
   	margin-top:30px;
     display: flex;
     flex-direction: column;
     align-items: center;
   	}
   .BAD_mid_row{
   	float:left;
   	width:100%;
   	position:relative;

   	display:-webkit-box;
   		display:-moz-box;
   		display:-ms-flexbox;
   		display:-webkit-flex;
   		display:flex;
   		flex-wrap:wrap;
   		justify-content:space-between;
   	padding:35px 0;
   	}
   .BAD_mid_row.reverse{flex-direction: row-reverse;}
   .BAD_mid_row:after{
   	position:absolute;
   	content:"";
   	border-right:3px dotted #F2CB49;
   	left:50%;
   	top:3px;
   	bottom:0;
   	margin-left:-1px;
   	}
   .BAD_mid_row:first-child:after{ top:45px;}
   .BAD_mid_row:last-child:after{ bottom:-35px;}
   .BAD_row_center_step {
     display: block !important;
   }
   .BAD_row_center_step{
   	position:absolute;
   	left:50%;
   	margin-left:-30px;
   	width:60px;
   	height:60px;
   	border-radius:50%;
   	background:  #244134;
   	border:15px solid  #bed9b1;
   	margin-top:10px;
   	z-index:1;
   	}
   .BAD_mid_week_box{
   	width:39%;
   	text-align:right;
   	margin-top:10px;
   	}
   .BAD_mid_row.reverse .BAD_mid_week_box{ text-align:left;}
   .week_heading{
   	float:left;
   	width:100%;
   	font-size:45px;
   	line-height:50px;
   	color:#234134;
   	}
   .calendar{
   	display:inline-block;
   	vertical-align:middle;
   	margin:-6px 12px 0 0;
   	}
   .BAD_row_content_box{
   	float:right;
   	width:43%;
   	border-radius:10px;
   	position:relative;
   	background:#f1fced;
   	border:2px solid #234134;
   	padding:20px 20px;
   	text-align:left;
   	}
   .BAD_row_content_box:after {
   		position: absolute;
   		content: "";
   		left:-15px;
   		top:22px;
   		border-top: 13px solid transparent;
   		border-bottom: 13px solid transparent;
   		border-right: 13px solid #234134;
   	}
   .BAD_mid_row.reverse .BAD_row_content_box:after{
   	border-right:none;
   	border-left: 13px solid #234134;
   	left:auto;
   	right:-15px;
   	}
   .BAD_row_text{
   	float:left;
   	width:100%;
   	font-size:18px;
   	line-height:22px;
   	color:#00000099;
   	font-weight: 400;
     margin-bottom: 0 !important;
   	}

   #shopify-section-{{ section.id }} .your-journey__heading {
     color: {{ section.settings.heading_color }};
     font-size: {{ section.settings.heading_font_size }}px;
     text-shadow: 0px 2px 2px rgba(242, 203, 73, 0.43);
   }

   .container .your-journey__button {
     padding: 10px 30px;
     text-align: center;
     text-transform: uppercase;
     display: inline-block;
     text-decoration: none;
     font-size: 20px;
   }

   #shopify-section-{{ section.id }} .your-journey__button {
     background-color: {{ section.settings.button_bg_color }};
     color: {{ section.settings.button_text_color }};
   }

   #shopify-section-{{ section.id }} .your-journey__button:hover {
     background-color: {{ section.settings.button_bg_color_hover }};
     color: {{ section.settings.button_text_color_hover }};
   }

   .your-journey__button-wrapper {
     margin-top: 50px;
   }

   .container .your-journey__heading {
     margin: 0;
     font-family: 'bookmania';
     font-weight: 700;
     line-height: 1.2;
     text-transform: capitalize;
     text-align: center;
   }

   .BAD_row_card_title {
     font-size: 20px;
     line-height: 22px;
     color: #37383D;
     font-family: 'suisse_intl_mono';
     margin: 10px 0;
   }

   .showDesk{display:none;}
   .showMob{display:block;}
   .hideMob{ display:none;}


   @media (max-width: 1019px) {
     #shopify-section-{{ section.id }} .your-journey__heading {
       font-size: {{ section.settings.heading_font_size_tablet }}px;
     }

   }

   @media only screen and (max-width:767px){
     .container {
       margin-top: 30px;
     }
     .section_4{ padding:0px 0 35px;}
   .BAD_product1, .BAD_product2, .BAD_product3{ display:none;}
   .sec4_mid{ margin-top:0;}
   .BAD_mid_row{ float:none; display:inline-block; vertical-align:middle; max-width:370px; padding:0 0 0; margin-top:40px;}
   .BAD_mid_row:after{ left:14px; margin:0 0 0; top:3px; z-index:1; bottom:-40px;}
   .BAD_mid_row:first-child:after{ top:1px;}
   .BAD_row_center_step{ left:0; margin:0 0 0 0; width:30px; height:30px; z-index:2; top:0; border: 8px solid #bed9b1;}
   .BAD_mid_week_box{ float:right; width:calc(100% - 55px); text-align:left; margin:0;}
   .BAD_row_content_box { width:calc(100% - 55px); float:right; margin-top:15px;border:2px solid #234134; padding:15px 15px;}
   .BAD_mid_row.reverse{ flex-direction: inherit;}
   .BAD_mid_row.reverse .BAD_row_content_box:after, .BAD_row_content_box:after { display:none; border-left: none;border-right: 13px solid #234134;right: auto;left: -15px;}
   .BAD_mid_row:last-child:after{ bottom:0;}
   .week_heading{ font-size:24px; line-height:32px;}
   .calendar{ width:25px;}
   .BAD_row_text{ font-size:15px; }
   #shopify-section-{{ section.id }} .your-journey__heading {
       font-size: {{ section.settings.heading_font_size_mobile }}px;
     }
     .BAD_row_card_title {
       font-size: 18px;
     }
     .container .your-journey__button {
       font-size: 16px;
     }


   }
</style>

<div class="section_4">
  <div class="container">
    <div class="your-journey__container-header">
      {% if section.settings.kicker_text != blank or section.settings.heading != blank %}
        <div class="your-journey__header">
          {% if section.settings.heading != blank %}
            <h2 class="your-journey__heading">{{ section.settings.heading }}</h2>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="sec4_mid">
      <div class="BAD_mid_row">
        <div class="BAD_row_center_step"></div>
        <div class="BAD_mid_week_box">
          <div class="week_heading">1 Week</div>
        </div>
        <div class="BAD_row_content_box">
          <h4 class="BAD_row_card_title">{{ section.settings.first_card_title }}</h4>
          <p class="BAD_row_text">
            {{ section.settings.first_card_description }}
          </p>
        </div>
      </div>

      <div class="BAD_mid_row reverse">
        <div class="BAD_row_center_step"></div>
        <div class="BAD_mid_week_box">
          <div class="week_heading">1 Month</div>
        </div>
        <div class="BAD_row_content_box">
          <h4 class="BAD_row_card_title">{{ section.settings.second_card_title }}</h4>
          <p class="BAD_row_text">
            {{ section.settings.second_card_description }}
          </p>
        </div>
      </div>

      <div class="BAD_mid_row">
        <div class="BAD_row_center_step"></div>
        <div class="BAD_mid_week_box">
          <div class="week_heading">3 Months</div>
        </div>
        <div class="BAD_row_content_box">
          <h4 class="BAD_row_card_title">{{ section.settings.third_card_title }}</h4>
          <p class="BAD_row_text">
            {{ section.settings.third_card_description }}
          </p>
        </div>
      </div>

      <div class="BAD_mid_row reverse">
        <div class="BAD_row_center_step"></div>
        <div class="BAD_mid_week_box">
          <div class="week_heading">6 Months</div>
        </div>
        <div class="BAD_row_content_box">
          <h4 class="BAD_row_card_title">{{ section.settings.fourth_card_title }}</h4>
          <p class="BAD_row_text">
            {{ section.settings.fourth_card_description }}
          </p>
        </div>
      </div>

      <div class="BAD_mid_row">
        <div class="BAD_row_center_step"></div>
        <div class="BAD_mid_week_box">
          <div class="week_heading">12 Months</div>
        </div>
        <div class="BAD_row_content_box">
          <h4 class="BAD_row_card_title">{{ section.settings.fifth_card_title }}</h4>
          <p class="BAD_row_text">
            {{ section.settings.fifth_card_description }}
          </p>
        </div>
      </div>

      {% comment %}
        <div class="BAD_mid_row reverse">
          <div class="BAD_row_center_step"></div>
          <div class="BAD_mid_week_box">
            <div class="week_heading">
              12
              Months
            </div>
          </div>
          <div class="BAD_row_content_box">
            <p class="BAD_row_text">
              Proteins that impact women’s health have reached optimized levels which can result in optimal menstruation
              & menstrual flow, properly balanced hormones, & less menstrual cramps & hot flashes.*
            </p>
          </div>
        </div>
      {% endcomment %}
    </div>
    {% if section.settings.button_text != blank %}
      <div class="BAD-cta-wrapper page-width">
        <a href="{{ section.settings.button_url }}" class="BAD-cta-button" style="text-align: center;">
          {{- section.settings.button_text -}}
        </a>
        <div style="display:flex;justify-content:center;padding-top: 5px;gap:10px;">
          <div style="display:flex;align-items:center;gap:5px;">
            <img src="{{ section.settings.icon_image | img_url: '600x600' }}" alt="Product Image" class="cta-icons">
            <p class="BAD-cta-info-text">{{ section.settings.cta_lower_text_1 }}</p>
          </div>
          <div style="display:flex;align-items:center;gap:5px;">
            <img src="{{ section.settings.icon_image_2 | img_url: '600x600' }}" alt="Product Image" class="cta-icons">
            <p class="BAD-cta-info-text">{{ section.settings.cta_lower_text_2 }}</p>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

