<!-- START new-banner-with-text.liquid -->

<section class="banner-with-text-section" {{ section.shopify_attributes }}>
  {% if section.settings.image or section.settings.heading or section.settings.text %}
    <div class="banner-with-text__inner">
      <figure class="banner-with-text__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | img_url: '' }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
          >
        {% endif %}
      </figure>

      <div class="banner-with-text__content">
        <h2 class="banner-with-text__heading">
          {% if section.settings.svg == true %}
            <span class="banner-with-text__stars" aria-hidden="true">
              {% for i in (1..5) %}
                {% render 'star-icon-02' %}
              {% endfor %}
            </span>
          {% else %}
            {{ section.settings.heading }}
          {% endif %}
        </h2>
        <div class="banner-with-text__text">
          {{ section.settings.text }}
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Banner with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "svg", "label": "Activate SVG" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Story" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lorem ipsum dolor sit amet.\nRisus neque vitae dignissim tellus. Fusce rhoncus lectus nibh sagittis et quis.</p>"
    },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Learn More" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    {
      "type": "header",
      "content": "Padding Settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Tablet)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Tablet)",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 20
    }
  ],
  "presets": [{ "name": "Banner with text", "category": "Image & text" }]
}
{% endschema %}

{% style %}
    .banner-with-text-section {
      padding: {{ section.settings.padding_top_desktop }}px 0 {{ section.settings.padding_bottom_desktop }}px;
    }

    .banner-with-text-section .banner-with-text__inner {
      display: flex;
      background-color: #234134;
      align-items: center;
      height: 500px;
    }

    .banner-with-text-section .banner-with-text__media {
      flex: 1 1 50%;
      min-width: 0;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    .banner-with-text-section .banner-with-text__media::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(
          50% 50% at 50% 50%,
          rgba(0, 0, 0, 0) 0%,
          rgba(10, 29, 23, 0.72) 100%
        ),
        radial-gradient(
          50% 50% at 50% 50%,
          color(display-p3 0.000 0.000 0.000 / 0) 0%,
          color(display-p3 0.059 0.114 0.090 / -0.28) 100%
        );
    }

    .banner-with-text-section .banner-with-text__media img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .banner-with-text-section .banner-with-text__content {
      flex: 1 1 50%;
      min-width: 0;

      display: flex;
      flex-direction: column;
      gap: 35px;
      height: 100%;
      justify-content: center;

      padding: 125px 146px 125px 60px;
    }

    .banner-with-text-section .banner-with-text__heading {
      margin: 0;
      font-size: 38px;
      line-height: 1.2;
      font-weight: 700;
      color: #252525;
      font-family: Bookmania, serif;
    }

    .banner-with-text-section .banner-with-text__text p {
      color: #FFFFFF;
      font-size: 20px;
      line-height: 1.2;
      font-weight: 400;
      letter-spacing: 0.2px;
    }

    .banner-with-text-section .banner-with-text__link {
      display: inline-block;
      margin-top: 6px;
      text-decoration: underline;
      font-size: 20px;
      color: #555555;
      {% if template == 'product' %}display: none{% endif %}
    }

    .banner-with-text__stars {
      display: inline-flex;
      gap: 2px;
    }

    .banner-with-text__stars svg {
      width: 22px;
      height: 22px;
      font-size: 22px;
    }


      @media (max-width: 1279px) {
        .banner-with-text-section .banner-with-text__media {
          min-width: 480px;
        }

        .banner-with-text-section .banner-with-text__content {
          padding: 57px 20px;
      }

      }

      @media (max-width: 1019px) {
        .banner-with-text-section .banner-with-text__heading {
          font-size: 32px;
        }
        .banner-with-text-section .banner-with-text__text p {
          font-size: 18px;
        }
        .banner-with-text-section .banner-with-text__link {
          font-size: 18px;
        }
        .banner-with-text__stars svg{
          font-size: 12px;
          width: 12px;
          height: 12px;
        }
        .banner-with-text-section .banner-with-text__content{
          gap: 6px;
          width: 50%;
        }

        .banner-with-text-section .banner-with-text__media{
          width: 50%;
          max-width: 100%;
          min-width: auto;
        }

  .banner-with-text-section{
        padding: 40px 0 40px;
  }

      }

      @media (max-width: 767px) {
        .banner-with-text-section .banner-with-text__heading {
          font-size: 24px;
        }
        .banner-with-text-section .banner-with-text__text p {
          font-size: 16px;
        }
        .banner-with-text-section .banner-with-text__link {
          font-size: 16px;
        }
        .banner-with-text-section .banner-with-text__inner{
          flex-direction: column-reverse;
          height: 550px;
        }
        .banner-with-text-section .banner-with-text__content{
          width: 100%;
          padding: 40px 20px 20px
        }
        .banner-with-text-section .banner-with-text__media{
          min-width: 100%;
          height: 20px;
        }
        .banner-with-text-section{
          padding-bottom: 0;
        } 
      }
{% endstyle %}
