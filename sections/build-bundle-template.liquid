<!-- sections/collection-template -->
{%- capture collection_template_css -%}
{%- comment -%} Start Shopify Id Styles {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} {
    background:#FFFFFF;
    --card-tag-sale-background-color: #3F745D80;
    --card-tag-sale-text-color: #FFFFFF;
    --card-tag-sold-out-background-color: {{ settings.card_tag_sold_out_background }};
    --card-tag-sold-out-text-color: {{ settings.card_tag_sold_out_text_color }};
    --card-tag-new-arrival-background-color: {{ settings.card_tag_new_arrival_background }};
    --card-tag-new-arrival-text-color: {{ settings.card_tag_new_arrival_text_color }};
    --card-background-color: {{ section.settings.card_background_color }};
    --card-title-color: {{ section.settings.card_title_color }};
    --card-notes-color: {{ section.settings.card_notes_color }};
  }
  
  #shopify-section-{{ section.id }} .titles {
    position: absolute;
    width: {{ section.settings.width_titles }}%;
    left:{{ section.settings.titles_position_hor }}%;
    top:{{ section.settings.titles_position_ver }}%
  }
  
  #shopify-section-{{ section.id }} .collection-description__text {
    text-align: {{ settings.announcement_description_position }};
    color: {{ settings.description_color }};
  }
  
  #shopify-section-{{ section.id }} .collection-description__text.see-more.see-more:not(.collection-description__text--opened) {
    max-height: {{ settings.description_size }}px;
  }

  #shopify-section-{{ section.id }} .collection-description__button {
    color: {{ settings.desc_seemore-color }};
  }

  #shopify-section-{{ section.id }} .grid__item-price {
    font-size: {{ settings.collection_product_price_font_size | plus: 0.0 | divided_by: 16 }}rem;
  }
      
  #shopify-section-{{ section.id }} .product-card__product-info__header {
    font-size: {{ section.settings.product_card_title_font_size_desktop }}px;
  }

  @media (max-width:1019px) {    
    #shopify-section-{{ section.id }} .product-card__item-title {
      font-size: {{ section.settings.product_card_title_font_size_tablet }}px;
    }
  }
  @media (max-width:767px) {
    #shopify-section-{{ section.id }} .product-card__item-title {
      font-size: {{ section.settings.product_card_title_font_size_mobile }}px;
      
    }
  }
</style>
{%- comment -%} End Shopify Id Styles {%- endcomment -%}

<style>
  .collection-page__content-wrapper {
    position: relative;
    padding-top: 34px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .collection-page__breadcrumb-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 5px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .collection-page__breadcrumb-and-filter-wrapper {
    padding: 0 32px 0 32px;
  }

  .collection-page__breadcrumb-wrapper * {
    font-weight: 300; !important
  }

  .collection__filter-icon-wrapper.collection__filter-icon-wrapper--desktop {
    display: none;
  }

  .collection__filter-icon-wrapper.collection__filter-icon-wrapper--desktop-center {
    text-align: center;
    align-items: center;
    justify-content: center;
  }
  

  .collection-page__breadcrumb-wrapper-inner,
  .collection__filter-icon-wrapper,
  .collection-filter__wrapper {
    flex: 0 0 33%;
  }

  .collection-page__breadcrumb-wrapper .breadcrumbs__item {
    line-height: 1;
    letter-spacing: 0.3px;
  }
  
  .collection-page__breadcrumb-wrapper .breadcrumbs__item.breadcrumbs__link {
    color: #A8A8A8;
  }

  .template-collection .breadcrumbs__separator {
    margin-left: 4px;
    margin-right: 4px;
  }

  .collection-page__breadcrumb-wrapper .breadcrumbs__separator svg {
    width: 12px;
  }

  .collection-filter__wrapper {
    display: flex;
    justify-content: flex-end;
    padding-right: 3px;
  }

  .collection-filter__wrapper .content-collection {
    width: 100%;
  }

  .products-not-found{
    margin: 0 auto;
  }

  .collection-filter {
    display: flex;
    align-items: center;
    justify-content: end;
    gap: 50px;
  }

  .collection-page__loading-more-wrapper {
    text-align: center;
    width: 100%;
    color: #FFF;
    grid-column: 1 / -1;
  }

  .collection-page__loading-more {
    width: 248px;
    height: 56px;
    color: #676767;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #676767;
    position: relative;
    overflow: hidden;
    font-size: 20px;
  }    
  .collection-page__loading-more span{
    position: absolute;
    top: 50%;
    left: 50%;
    display: block;
    width: 0;
    height: 0;
    border-radius: 50%;
    background-color: #676767;
    transition: width 0.4s ease-in-out, height 0.4s ease-in-out;
    transform: translate(-50%, -50%);
    z-index: -1;
  }    

  .collection-page__loading-more:hover span {
    width: 225%;
    height: 554px;
  }

   .collection-page__loading-more:hover {
    transition: color 0.4s ease-in-out;
    color: var(--color-secondary-buttons-text-hover);
  } 

  .loading-more__progress-wrapper {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
  }

  .loading-more__progress-label {
    margin-bottom: 5px;
  }

  .loading-more__progress-bar {
    display: block;
    width: 100%;
    height: 4px;
    background-color: #eee;
    position: relative;
    margin-bottom: 10px;
  }

  .loading-more__progress-bar-fill {
    display: block;
    height: 100%;
    background-color: #000;
    position: absolute;
    top: 0;
    left: 0;
  }

  .collection-facets--opened {
    overflow: hidden;
  }

  .collection-facets__overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    background: transparent;
    z-index: 999;
    transition: all 0.3s ease;
  }

  body.collection-facets--opened .collection-facets__overlay {
    opacity: 1;
    visibility: visible;
    background: rgba(0, 0, 0, 0.6);
  }

  .collection-page__grid-products .product-card__product-info {
    margin: 23px 0 30px;
  }

  .collection-page__wrapper {
    padding: 20px 0;
  }

  .collection-page__filter-wrapper {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) scale(0.9);
    width: 100%;
    max-width: 90vw;
    max-height: 90vh;
    background: #fff;
    z-index: 1000;
    transition: transform 0.3s ease-in-out, opacity 0.3s ease-in-out;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    background: linear-gradient(0deg, #F9F4E9, #F9F9F9);
    linear-gradient(0deg, color(display-p3 0.976 0.976 0.976), color(display-p3 0.976 0.976 0.976)),
    linear-gradient(180deg, rgba(250, 244, 232, 0) 0%, #FAF4E8 100%);
    linear-gradient(180deg, color(display-p3 0.976 0.957 0.914 / 0) 0%, color(display-p3 0.976 0.957 0.914) 100%);
  }

  .collection-page__filter-wrapper-opened {
    transform: translateX(-50%) scale(1);
    opacity: 1;
    visibility: visible;
  }
  
  .collection-page__content {
    width: 100%;
  }

  .collection-filter__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-filter__item-icon {
    border-bottom: 1px solid #E9E9E9;
    width: 52px;
    height: 47px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
  }
  .collection-filter__item-icon::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    transition: all 0.3s ease-in-out;
    background-color:rgb(160, 160, 160);
  }
  .collection-filter__item-icon:hover::after {
    width: 100%;
  }

  .collection-filter__item * {
    font-size: var(--breadcrumbFontSize, 1rem);
  }

  .collection-filter__item-label {
    letter-spacing: 0;
    color: #252525;
    margin-right: 5px;
    font-weight: 400;
    width: 60px;
  }

  .collection-filter__dropdown-wrapper {
    margin: 0 2px 0 0;
    padding: 0 17px;
    letter-spacing: 0.2px;
    font-size: var(--breadcrumbFontSize, 1rem);
    appearance: none;
    -webkit-appearance: none;
    border-radius: 4px;
  }

  .collection-filter__dropdown-wrapper-icon {
    position: relative;
  }

  .collection-filter__dropdown-wrapper-icon::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    transition: all 0.3s ease-in-out;
    background-color:rgb(160, 160, 160);
  }
  .collection-filter__dropdown-wrapper-icon:hover::after {
    width: 100%;
  }
  .collection-filter__dropdown {
    cursor: pointer;
    width:fit-content;
    height: 47px;
    font-weight: 300;
    border-bottom: 1px solid #E9E9E9;
    width: 200px;
    color: #000;
    background-color: transparent;
    border: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    font-family: inherit;
    background-image: url('data:image/svg+xml;utf8,<svg fill="black" height="16" viewBox="0 0 20 20" width="16" xmlns="http://www.w3.org/2000/svg"><path d="M5.516 7.548a.625.625 0 0 1 .884-.032L10 11.016l3.6-3.5a.625.625 0 1 1 .852.914l-4 3.889a.625.625 0 0 1-.852 0l-4-3.889a.625.625 0 0 1-.032-.884z"/></svg>');
    background-repeat: no-repeat;
    background-position: right 10px center;
    background-size: 16px 16px;
    padding-left: 10px;
  }

  .collection__filter-icon-wrapper {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .spinner-widget {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 0;
    margin: 0 auto;
    width: 100%;
  }

  .spinner-widget__spinner {
    display: block;
    width: 50px;
    height: 50px;
    border: 3px solid #eee;
    border-bottom-color: transparent;
    border-radius: 100%;
    margin-bottom: 5px;
    animation: linear 0.45s 0s infinite spinner;
  }

  .spinner-widget__text {
    text-transform: uppercase;
  }

  @keyframes spinner {
    0% {
      transform: rotate(0deg);
    }

    100% {
      transform: rotate(360deg);
    }
  }

  /* product grid */
  .collection-page__wrapper {
    display: grid;
    grid-template-columns: 1fr minmax(0, 437px);
  }

  .collection-page__grid-products {
    display: grid;
    justify-content: flex-start;
  }

  .collection-page__wrapper {
    padding: 40px 135px;
    justify-content: space-between;
  }

  .collection-page__grid-products.grid-uniform--s4 {
    gap: 30px 2%;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .collection-page__grid-products.grid-uniform--s3 {
    gap: 50px 2%;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .collection-page__grid-products.grid-uniform--s2 {
    gap: 30px 3%;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding-right: 50px;
  }

  /* Garantir que os cards alternativos sempre tenham 2 colunas */
  .collection-page__grid-products.grid-uniform--s2 #product-alternative-card-form,
  .collection-page__grid-products.grid-uniform--s2 form[id="product-alternative-card-form"] {
    width: 100%;
    max-width: 100%;
  }

  .collection-page__grid-products + .collection-page__grid-products {
    margin-top: 30px;
  }

  .collection-page__grid-products .product-card__grid-item-fullsize {
    background-color: #FFFFFF;
  }


  .collection-page__grid-products .product-card__item-price {
    font-size: 25px;
    font-weight: 700;
    font-family: 'SuisseIntlMono', sans-serif;
    line-height: 1.2;
}

.product-card__item-price {
  color: var(--color-price, #234134);
}

.product-card__item-compare-at-price {
  margin-right: 10px;
