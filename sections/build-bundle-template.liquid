<div class="collection-template-wrapper">
{%- if settings.breadcrumb_position == 'above' and settings.enable_breadcrumbs -%}
<div class="collection-page__breadcrumb-wrapper wrapper">
  {%- render 'breadcrumb' -%}
</div>
{% endif %}

{% comment %} {%- render 'collection-banner' -%} {% endcomment %}

<div class="collection-page__content-wrapper">
<div class="collection-page__breadcrumb-and-filter-wrapper  ">
  {%- if settings.breadcrumb_position == 'below' and settings.enable_breadcrumbs -%}
    <div class="collection-page__breadcrumb-wrapper">
      <div class="collection-page__breadcrumb-wrapper-inner">
        {%- render 'breadcrumb' -%}
        <div class="collection__filter-icon-wrapper collection__filter-icon-wrapper--mobile">
          {%- if settings.enable_qtd_product -%}
            {%- render 'breadcrumb-product-count' -%}
          {%- endif -%}
        </div>
      </div>

      <div class="collection__filter-icon-wrapper collection__filter-icon-wrapper--desktop-center">
        {%- if settings.enable_qtd_product -%}
          {%- render 'breadcrumb-product-count' -%}
        {%- endif -%}
      </div>

      <div class="collection-filter__wrapper">
        {%- render 'collection-filter' -%}
        {% comment %} {%- render 'collection-filter-icon' -%} {% endcomment %}
      </div>
      <div class="collection__filter-icon-wrapper collection__filter-icon-wrapper--desktop">
        {%- if settings.enable_qtd_product -%}
          {%- render 'breadcrumb-product-count' -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <hr class="collection-page__divider">
</div>

<div class="collection-facets__overlay"></div>

<div class="collection-page__filter-wrapper wrapper">
  {%- render 'collection-facets' -%}
</div>

<div class="collection-page__wrapper ">
  <div class="collection-page__content">
    {% render 'collection-items', custom_desktop_items_per_row_desktop: 2 %}
  </div>
  {%  assign buy_box_block = section.blocks | where: 'type', 'buy_box' | first  %}
  {% render 'bundle-sticky-buy-box', 
    config: buy_box_block.settings,
  %}
</div>
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
const filterOpener = document.querySelector('.collection-filter__item-icon');
const filter = document.querySelector('.collection-page__filter-wrapper');
const overlay = document.querySelector('.collection-facets__overlay');
const closeButton = document.querySelector('.collection-facets__close-button');
const body = document.body;

function openFilter() {
  filter.classList.add('collection-page__filter-wrapper-opened');
  body.classList.add('collection-facets--opened');
}

function closeFilter() {
  filter.classList.remove('collection-page__filter-wrapper-opened');
  body.classList.remove('collection-facets--opened');
}

if (filterOpener) {
  filterOpener.addEventListener('click', function () {
    openFilter();
  });
}

if (overlay) {
  overlay.addEventListener('click', function () {
    closeFilter();
  });
}

if (closeButton) {
  closeButton.addEventListener('click', function () {
    closeFilter();
  });
}

// Fechar com a tecla ESC
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && body.classList.contains('collection-facets--opened')) {
    closeFilter();
  }
});
});
</script>

