{% assign extra_classes = '' %}
{% if section.settings.enable_slider_recently_viewed_product == false %}
  {% assign extra_classes = 'recently-viewed-products__list-no-slider' %}
{% endif %}

<div class="recently-viewed__top-wrapper wrapper">
  <h2 class="recently-viewed-produts__title">{{ section.settings.title_recently_viewed_products }}</h2>
  <div id="recently-viewed__loader" class="recently-viewed__loader-wrapper wrapper">
    {% render 'skeleton-cards' %}
  </div>
</div>
<div class="shopify-section recently-viewed-products" data-section-type="recently-viewed-products">
  <div class="recently-viewed--wrapper wrapper">
    <div id="recently-viewed-products__list" class="recently-viewed-products__list-class recently-wrapper {{ extra_classes }}"></div>
  </div>
</div>

<script>
  function addToCart(event, button) {
    console.log('addToCart', event, button);
    event.preventDefault(); 
    event.stopPropagation();
    if (button.hasAttribute('loading') || button.getAttribute('available') === 'false') return;

    const variantId = button.dataset.variantId;
    const soldOut = document.querySelector(`.product-card__item-sold-out[data-variant-id="${variantId}"]`);
    button.setAttribute('disabled', '');
    button.setAttribute('loading', '');

    try {
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1
        }),
      }).then(() => {
        window.AMP_API.OPEN_CART();
      }).catch((error) => {
        console.error(error);
      });
    } catch (error) {
      console.error(error);
    } finally {
      setTimeout(() => {
        button.removeAttribute('disabled');
        button.removeAttribute('loading');
      }, 800);
    }
  }
</script>
  <script>
    document.addEventListener('DOMContentLoaded', initRecentlyViewed);

    async function initRecentlyViewed() {
      const selectors = {
        wrapper: '.recently-viewed-products',
        list: '#recently-viewed-products__list',
        top: '.recently-viewed__top-wrapper',
        loader: '.recently-viewed__loader-wrapper',
      };

      const elements = Object.fromEntries(
        Object.entries(selectors).map(([key, sel]) => [key, document.querySelector(sel)])
      );

      const MAX_ITEMS = {{ section.settings.recently_viewed_amount }};
      const currentPath = location.pathname.replace(/(.*)\/products/, '/products');
      const storedHandles = getHandles();
      updateHandles(storedHandles, currentPath, MAX_ITEMS);

      const handles = getHandles();
      if (!handles.length) {
        toggleUI(elements, false);
        return;
      }

      prepareUI(elements, handles.length);
      const products = await fetchProducts(handles);
      renderProducts(elements.list, products);
      toggleUI(elements, true);
    }

    /* -------------------- helpers -------------------- */

    function getHandles() {
      try {
        return JSON.parse(localStorage.getItem('@handles')) || [];
      } catch (err) {
        console.error('Failed to parse handles', err);
        return [];
      }
    }

    function updateHandles(handles, current, limit) {
      if (!current.includes('/products')) return;
      const filtered = handles.filter(h => h !== current && !h.includes('bundle-save'));
      filtered.unshift(current);
      localStorage.setItem('@handles', JSON.stringify(filtered.slice(0, limit)));
    }

    function toggleUI({ wrapper, loader, top }, show) {
      if (wrapper) wrapper.hidden = !show;
      if (top) top.hidden = !show;
      if (loader) loader.style.display = show ? 'none' : 'none'; // escondido por padrão
    }

    function prepareUI({ list, loader }, count) {
      document.documentElement.style.setProperty(
        '--items-per-row-recently-viewed-products',
        Math.min(count, 4)
      );
      if (list) list.innerHTML = '';
      if (loader) loader.style.display = 'flex';
    }

    async function fetchProducts(urls) {
      const parser = new DOMParser();
      const fetches = urls.map(url =>
        fetch(`${url}?view=ajax`)
          .then(r => (r.ok ? r.text() : null))
          .catch(() => null)
      );

      const results = await Promise.allSettled(fetches);
      return results
        .filter(r => r.status === 'fulfilled' && r.value)
        .map(r => parser.parseFromString(r.value, 'text/html'))
        .map(doc => doc.querySelector('#recently-viewed-products__product-item'))
        .filter(Boolean);
    }

    function renderProducts(container, items) {
      if (!container || !items.length) return;
      const fragment = document.createDocumentFragment();
      items.forEach(item => fragment.appendChild(item));
      container.appendChild(fragment);
    }
  </script>

{% schema %}
