<!-- sections/collection-template -->
{%- capture collection_template_css -%}
{%- comment -%} Start Shopify Id Styles {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }};
  }

  #shopify-section-{{ section.id }} {
    background:#FFFFFF;
    --card-tag-sale-background-color: #3F745D80;
    --card-tag-sale-text-color: #FFFFFF;
    --card-tag-sold-out-background-color: {{ settings.card_tag_sold_out_background }};
    --card-tag-sold-out-text-color: {{ settings.card_tag_sold_out_text_color }};
    --card-tag-new-arrival-background-color: {{ settings.card_tag_new_arrival_background }};
    --card-tag-new-arrival-text-color: {{ settings.card_tag_new_arrival_text_color }};
    --card-background-color: {{ section.settings.card_background_color }};
    --card-title-color: {{ section.settings.card_title_color }};
    --card-notes-color: {{ section.settings.card_notes_color }};
  }
  
  #shopify-section-{{ section.id }} .titles {
    position: absolute;
    width: {{ section.settings.width_titles }}%;
    left:{{ section.settings.titles_position_hor }}%;
    top:{{ section.settings.titles_position_ver }}%
  }
  
  #shopify-section-{{ section.id }} .collection-description__text {
    text-align: {{ settings.announcement_description_position }};
    color: {{ settings.description_color }};
  }
  
  #shopify-section-{{ section.id }} .collection-description__text.see-more.see-more:not(.collection-description__text--opened) {
    max-height: {{ settings.description_size }}px;
  }

  #shopify-section-{{ section.id }} .collection-description__button {
    color: {{ settings.desc_seemore-color }};
  }

  #shopify-section-{{ section.id }} .grid__item-price {
    font-size: {{ settings.collection_product_price_font_size | plus: 0.0 | divided_by: 16 }}rem;
  }
      
  #shopify-section-{{ section.id }} .product-card__item-title {
    font-size: {{ section.settings.product_card_title_font_size_desktop }}px;
  }

  @media (max-width:1019px) {    
    #shopify-section-{{ section.id }} .product-card__item-title {
      font-size: {{ section.settings.product_card_title_font_size_tablet }}px;
    }
  }
  @media (max-width:767px) {
    #shopify-section-{{ section.id }} .product-card__item-title {
      font-size: {{ section.settings.product_card_title_font_size_mobile }}px;
      
    }
  }
</style>
{%- comment -%} End Shopify Id Styles {%- endcomment -%}

<style>
  .collection-page__breadcrumb-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 5px;
    margin: 34px auto 10px;
    padding: 0 25px;
  }

  .collection-page__breadcrumb-wrapper .breadcrumbs {
    margin-bottom: 0;
  }

  .collection-page__breadcrumb-wrapper .breadcrumbs__item {
    line-height: 1.1;
    font-weight: 400;
  }

  {% comment %} .template-collection .breadcrumbs__separator {
    margin-left: 4px;
    margin-right: 4px;
  } {% endcomment %}

  .collection-page__breadcrumb-wrapper .breadcrumbs__separator svg {
    width: 12px;
  }

  .collection-filter__wrapper {
    display: flex;
    justify-content: flex-end;
    padding-right: 3px;
  }

  .collection-filter__wrapper .content-collection {
    width: 100%;
  }

  .products-not-found{
    margin: 0 auto;
  }

  .collection-page__loading-more-wrapper {
    text-align: center;
    width: 100%;
    color: #FFF;
    position: absolute;
    bottom: -40px;
  }

  .product-alternative-card-form--hidden {
    display: none;
  }

  .collection-page__loading-more {
    width: 158px;
    height: 44px;
    color: #234134;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #234134;
    padding: 6.5px 10px 6.5px 6px;
    border-radius: 40px;
  }    

  .collection-page__loading-more:hover {
    background: var(--color-secondary-buttons-hover);
    color: var(--color-secondary-buttons-text-hover);
  }

  .loading-more__progress-wrapper {
    width: 100%;
    justify-content: center;
    display: flex;
    margin-top: 10px;
  }

  .loading-more__progress-label {
    margin-bottom: 5px;
  }

  .loading-more__progress-bar {
    display: none;
    width: 100%;
    height: 4px;
    background-color: #eee;
    position: relative;
    margin-bottom: 10px;
  }

  .loading-more__progress-bar-fill {
    display: block;
    height: 100%;
    background-color: #000;
    position: absolute;
    top: 0;
    left: 0;
  }

  .collection-facets--opened {
    overflow: hidden;
  }

  {% comment %} .collection-page__wrapper > div:not(.collection-page__filter-wrapper):not(.collection-page__content) {
    display: none;
  } {% endcomment %}

  .collection-page__wrapper {
    padding: 20px 0;
  }

  .collection-page__filter-wrapper {
    width: 18%;
    margin-left: 2px;
  }
  
  .collection-page__content {
    width: 77%;
    margin-right: 6px;
  }

  .collection-filter__item-label {
    font-size: var(--breadcrumbFontSize, 16px);
    color: #252525;
    margin-right: 10px;
  }

  .collection-nav-item-wrapper::webkit-scrollbar {
    display: none;
  }

  .collection-nav-item-wrapper {
    overflow-x: scroll;
    scrollbar-width: none;
    border-top: 1px solid #CFCFCF;
    -ms-overflow-style: none;
    padding-top: 25px;
    margin-top: 15px;
  }

  .collection-nav-item-wrapper-inner {
    display: flex;
    align-items: center;
    justify-content: start;
    width: fit-content;
    white-space: nowrap;
  }

  .collection-nav-item {
    display: flex;
    padding: 20px 47px;
    justify-content: center;
    width: fit-content;
    align-items: center;
    gap: 10px;
    border-radius: 72px;
    background: #fff;
    border: 1px solid #234134;
    margin-right: 20px;
    transition: all 0.3s ease;
    z-index: 2;
    cursor: pointer;
  }

  .collection-nav-item__title {
    color: #234134;
    text-align: center;
    font-size: 18px;
    text-transform: capitalize;
    font-weight: 400;
  }

  .collection-nav-item:hover,
  .collection-nav-item--active {
    background: #234134;
  }

  .collection-nav-item:hover .collection-nav-item__title,
  .collection-nav-item--active .collection-nav-item__title {
    color: #FFF;
    font-weight: 700;
  }

  .collection-filter__dropdown {
    width: 247px;
    height: 47px;
    margin: 0 2px 0 0;
    padding: 0 17px;
    letter-spacing: 0.2px;
    font-size: var(--breadcrumbFontSize, 16px);
    appearance: none;
    -webkit-appearance: none;
    background-color: transparent;
    background-image: url("{{ 'icon-arrow-down.svg' | asset_url }}");
    background-size: 8px;
    background-position: 94% 54%;
    background-repeat: no-repeat;
    border-radius: 4px;
    border: 1px solid #5B734E;
    color: #5B734E;
    cursor: pointer;
  }

  .collection-filter__dropdown option:hover {
    cursor: pointer;
  }

  .collection__filter-icon-wrapper {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .spinner-widget {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 0;
    margin: 0 auto;
    width: 100%;
  }

  .spinner-widget__spinner {
    display: block;
    width: 50px;
    height: 50px;
    border: 3px solid #eee;
    border-bottom-color: transparent;
    border-radius: 100%;
    margin-bottom: 5px;
    animation: linear 0.45s 0s infinite spinner;
  }

  .spinner-widget__text {
    text-transform: uppercase;
  }

  @keyframes spinner {
    0% {
      transform: rotate(0deg);
    }

    100% {
      transform: rotate(360deg);
    }
  }

  /* product grid */

  .collection-page__wrapper,
  .collection-page__grid-products {
    display: flex;
  }

  .collection-page__wrapper {    
    padding: 24px 25px 20px 25px;
    justify-content: space-between;
    gap: 42px;
  }

  .collection-page__grid-products {
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 25px; 
    grid-template-columns: repeat(2, minmax(0, 1fr));
    display: grid;
    margin-bottom: 40px;
  }

  .collection-page__grid-products .product-card__grid-item {
    flex: 1 1 calc(25% - 2%); 
    min-width: calc(25% - 2%);
    max-width: calc(25% - 2%);
    transition: all 0.3s ease;
  }

  .grid-uniform--s3 .product-card__grid-item {
    flex: 1 1 calc(33.333% - 1.8%);
    min-width: calc(33.333% - 1.8%);
    max-width: calc(33.333% - 1.8%);
  }

  .grid-uniform--s2 .product-card__grid-item {
    flex: 1 1 calc(50% - 12.5px);
    min-width: calc(50% - 12.5px);
    max-width: calc(50% - 12.5px);
  }

  /* Forçar 2 produtos por linha em todas as resoluções */
  #shopify-section-{{ section.id }} .collection-page__grid-products .product-card__grid-item {
    flex: 1 1 calc(50% - 12.5px) !important;
    min-width: calc(50% - 12.5px) !important;
    max-width: calc(50% - 12.5px) !important;
  }

  .collection-page__grid-products .soft-banner {
    flex: 1 1 calc(25% - 2%);
    min-width: calc(25% - 2%);
    max-width: calc(25% - 2%);
  }

  .grid-uniform--s3 .soft-banner {
    flex: 1 1 calc(33.333% - 1.8%);
    min-width: calc(33.333% - 1.8%);
    max-width: calc(33.333% - 1.8%);
  }

  .grid-uniform--s2 .soft-banner {
    flex: 1 1 calc(50% - 25px);
    min-width: calc(50% - 227px);
    max-width: calc(50% - 168px);
  }

  @media (max-width: 1300px) {
    {% comment %} .collection-page__grid-products .product-card__grid-item {
      flex: 1 1 calc(25% - 2%);
      min-width: calc(20% - 2%);
      max-width: calc(33% - 1.9%);
    } {% endcomment %}
    
    .grid-uniform--s3 .product-card__grid-item {
      flex: 1 1 calc(33.333% - 1.8%);
      min-width: calc(33.333% - 1.8%);
      max-width: calc(33.333% - 1.8%);
    }
    
    {% comment %} .grid-uniform--s2 .product-card__grid-item {
      flex: 1 1 calc(50% - 25px);
      min-width: calc(50% - 25px);
      max-width: calc(50% - 25px);
    } {% endcomment %}
  }

  @media (max-width: 1200px) {
    .collection-page__grid-products {
      gap: 25px;
    }
    
    .collection-page__grid-products .product-card__grid-item {
      flex: 1 1 calc(25% - 1.8%);
      min-width: calc(33% - 2%);
    }
  }

  @media (max-width: 1100px) {
    
    {% comment %} .collection-page__grid-products .product-card__grid-item {
      flex: 1 1 calc(25% - 1.5%);
      min-width: calc(25% - 1.5%);
    } {% endcomment %}
    
    .grid-uniform--s3 .product-card__grid-item {
      flex: 1 1 calc(33.333% - 1.5%);
      min-width: calc(33.333% - 1.5%);
      max-width: calc(33.333% - 1.5%);
    }
  }

  .collection-page__grid-products + .collection-page__grid-products {
    margin-top: 30px;
  }

  .collection-page__grid-products .product-card__grid-item-fullsize {
    background-color: #F0FFE9A3;
  }

  .collection-page__grid-products .product-card__item-title-wrapper .product-card__item-title {
    margin-top: 13px;
    padding: 0 13px;
  }

  .collection-page__grid-products .product-card__item-price {
    font-size: 25px;
    font-weight: 700;
    font-family: 'SuisseIntlMono', sans-serif;
    line-height: 1.2;
    color: #234134;
    width: 100%;
  }

  .collection-page__grid-products .product-card__item-title {
    padding: 0 ;
    margin: 0;
  }

  .product-offers__btn{
    width: 100%;
    margin-top: auto;
  }

  .product-card__item-compare-at-price {
    color: var(--color-sale, #969696);
    text-decoration-line: line-through;
    font-size: var(--collectionProductComparePriceSize);
    margin-left: 0;
    font-weight: 400;
  }

  .product-card__item-price-wrapper-inner{
    width: 100%;
    gap: 10px;
    display: flex;
    align-items: center;   
    margin-bottom: 10px;
  }

  .collection-page__grid-products .product-card__item-price-wrapper {
    margin: 0;
    padding: 0 ;
    display: flex;
    align-items: center;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    height: 100%;
    padding-bottom: 10px;
  }

  .collection-page__grid-products .product-card__reviews {
    display: flex;
    align-items: flex-start;
    gap: 4.5px;
    padding: 0 10px;
    margin: 0;
    font-size: 12px;
    flex-direction: column;
  }

  .product-card__review{
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .product-card__stars{
    width: 79px;
  display: flex;
  flex-direction: row;
  gap: 3px;
  }

  .products-offers__card-tag {
    position: absolute;
    top: 0;
    right: 0;
    padding: 10px 23px;
    z-index: 3;
  }

  .products-offers__card-tag-text {
    color: inherit;
    font-weight: 400;
    font-size: 21px;
    line-height: 120%;
    letter-spacing: 0;
    text-align: center;
    font-family: "SuisseIntlMono", sans-serif;
  }

  .products-offers__card-tag[data-tag="sale"] {
    background-color: var(--card-tag-sale-background-color);
    color: var(--card-tag-sale-text-color);
    border-bottom-left-radius: 16px;
  }

  .products-offers__card-tag[data-tag="sold-out"] {
    background-color: var(--card-tag-sold-out-background-color);
    color: var(--card-tag-sold-out-text-color);
  }

  .products-offers__card-tag[data-tag="new-arrival"] {
    background-color: var(--card-tag-new-arrival-background-color);
    color: var(--card-tag-new-arrival-text-color);
  }

  .collection-page__grid-products .product-card__reviews svg {
    width: 40.8%;
    height: auto;
  }

  .collection-page__grid-products .product-card__reviews svg path {
    fill: {{ section.settings.review_stars_color }};
  }

  body .collection-banner .collection-page__title {
    font-size: 30px;
  }

  .collection-description__text,
  .collection-description__text * {
    font-size: 18px;
  }

  .collection-template-wrapper .product-card__grid-item-image-wrapper {
    padding-top: 109%;
    border-radius: 0;
  }

  .products-offers__card-image-primary img{
    width: 100%;
  }
  .products-amount-span{
    font-weight: 400;
  }

  @media (max-width: 1200px) {
    .collection-page__breadcrumb-wrapper {
      margin: 44px auto 10px;
      padding: 0 20px;
    }

    .collection-page__breadcrumb-wrapper .breadcrumbs {
      width: auto;
      display: flex;
      align-items: center;
      gap: 3px;
    }

    .collection-page__breadcrumb-wrapper .breadcrumbs__item {
      padding-left: 0px;
    }

    .collection-page__wrapper{    
      padding: 20px 20px;
    } 

    .products-amount-span{
      font-size: 12px;
      margin-right: 20px;

    }


    .collection-page__grid-products {
      gap: 30px; 
    }
    
    /* Forçar 2 produtos por linha em tablet */
    #shopify-section-{{ section.id }} .collection-page__grid-products .product-card__grid-item {
      flex: 1 1 calc(50% - 15px) !important;
      min-width: calc(50% - 15px) !important;
      max-width: calc(50% - 15px) !important;
    }
    
    .grid-uniform--st2 .product-card__grid-item {
      flex: 1 1 calc(50% - 3%);
      min-width: calc(50% - 1.6%);
      max-width: calc(50% - 3%);
    }
    
    .grid-uniform--st3 .product-card__grid-item {
      flex: 1 1 calc(33.333% - 1.5%);
      min-width: calc(33.333% - 1.5%);
      max-width: calc(33.333% - 1.5%);
    }
    
    /* Soft Banner tablet */
    .grid-uniform--st2 .soft-banner {
      flex: 1 1 calc(50% - 3%);
      min-width: calc(50% - 1.6%);
      max-width: calc(50% - 3%);
    }
    
    .grid-uniform--st3 .soft-banner {
      flex: 1 1 calc(33.333% - 1.5%);
      min-width: calc(33.333% - 1.5%);
      max-width: calc(33.333% - 1.5%);
    }

    @media (max-width: 980px) {
      
      .grid-uniform--st3 .product-card__grid-item {
        flex: 1 1 calc(33.333% - 2.5%);
        min-width: calc(33.333% - 2.5%);
        max-width: calc(33.333% - 2.5%);
      }

      .grid-uniform--st2 .product-card__grid-item {
      flex: 1 1 calc(50% - 3%);
      min-width: calc(50% - 1.8%);
      max-width: calc(50% - 3%);
    }

    .grid-uniform--st2 .soft-banner {
      flex: 1 1 calc(50% - 3%);
      min-width: calc(50% - 1.8%);
