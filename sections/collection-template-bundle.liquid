    }
    .collection-template-wrapper .breadcrumbs {
      gap: 2px;
      margin: 0;
      z-index: 10;
    }

    .template-collection .breadcrumbs__separator {
      margin: 4px 3px 0 1px;
    }

    .collection-page__grid-products {
      gap: 5px; 
    }
    
    /* Forçar 2 produtos por linha em mobile */
    #shopify-section-{{ section.id }} .collection-page__grid-products .product-card__grid-item {
      flex: 1 1 calc(50% - 2.5px) !important;
      min-width: calc(50% - 2.5px) !important;
      max-width: calc(50% - 2.5px) !important;
    }
    
    .grid-uniform--sm1 .product-card__grid-item {
      flex: 1 1 100%;
      min-width: calc(50% - 3px);
      max-width: calc(50% - 8px);
    }
    
    .grid-uniform--sm2 .product-card__grid-item {
      flex: 1 1 calc(50% - 8px);
      min-width: calc(50% - 8px);
      max-width: calc(50% - 8px);
    }
    
    .grid-uniform--sm1 .soft-banner {
      flex: 1 1 100%;
    }
    
    .grid-uniform--sm2 .soft-banner {
      flex: 1 1 calc(50% - 8px);
      min-width: calc(50% - 8px);
      max-width: calc(50% - 8px);
    }
    

    @media (max-width: 600px) {
      
      
      .grid-uniform--sm2 .product-card__grid-item {
        flex: 1 1 calc(50% - 6px);
        min-width: calc(50% - 6px);
        max-width: calc(50% - 6px);
      }
    }
    
    @media (max-width: 520px) {
      
      .grid-uniform--sm2 .product-card__grid-item {
        flex: 1 1 calc(50% - 4px);
        min-width: calc(50% - 4px);
        max-width: calc(50% - 4px);
      }

      .collection-template-wrapper .breadcrumbs {
      gap: 2px;
      margin: 0;
      width: 200px;
    }
      
      
      @media (max-width: 360px) {
        /* Manter 2 produtos por linha mesmo em telas muito pequenas */
        #shopify-section-{{ section.id }} .collection-page__grid-products .product-card__grid-item {
          flex: 1 1 calc(50% - 2px) !important;
          min-width: calc(50% - 2px) !important;
          max-width: calc(50% - 2px) !important;
        }
        
        .grid-uniform--sm2 .product-card__grid-item {
          flex: 1 1 calc(50% - 2px);
          min-width: calc(50% - 2px);
          max-width: calc(50% - 2px);
        }
        
