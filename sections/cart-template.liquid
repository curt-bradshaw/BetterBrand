  }

  .cart__head,
  .cart-items__item-details {
    justify-content: space-between;
  }

  .cart-items__item-details {
    padding: 1px 17px 0 0;
  }

  .cart-items__line-details--out-of-stock {
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-evenly;
  }
  
  .cart__total-subtotal-text {
    margin-right: 5px;
    font-size: 22px;
    letter-spacing: 0;
    color: #969696;
  }

  .cart__total-price {
    letter-spacing: 0;
    font-weight: 400;
  }

  .cart__total-freeshipping-text {
    font-weight: 400;
    font-size: 24px;
    color: #234134;
  }

  .cart__footer {
    margin-bottom: 18px;
    text-align: right;
  }

  .cart__continue-shopping--link {
    text-decoration: underline;
    margin-bottom: 23px;
    font-size: 16px;
    margin-left: 3px;
  }

  .cart__continue-shopping--button {
    display: inline-block;
    padding: 8px 15px;
    border-width: 1px;
    border-style: solid;
  }

  .cart__head {
    flex-direction: row-reverse;
    margin-bottom: 30px;
  }

  .cart__footer-wrapper {
    margin-bottom: 30px;
  }

  .cart-items__item-price,
  .cart__total-price-wrapper {
    font-size: 20px;
  }

  .cart-items__item-price {
    font-weight: 400;
  }

  .cart__coupon {
    margin-bottom: 10px;
  }

  .cart__coupon-day {
    font-weight: bold;
  }

  .cart__empty {
    display: block;
    margin: 60px auto;
    width: 300px;
    text-align: center;
    color: #FFF;
  }

  .cart-page__badges-list.cart-page__badges-list--s6:not(.no--desktop) {
