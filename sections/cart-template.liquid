    line-height: 1;
    letter-spacing: 0;
    text-align: right;
    color: #000;
  }

  .cart-items__form {
    width: 100%;
    margin: 0 auto;
  }

  .cart__proceed-to-checkout,
  .cart-items__item-details,
  .cart__footer-wrapper,
  .cart-items__list-header,
  .cart__head {
    align-items: center;
  }

  .cart__proceed-to-checkout {
