    justify-content: flex-start;
    gap: 10px;
  }

  .cart-page__badges-list .cart-drawer__badge-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
  }
  
  .cart-page__badges-list .cart-drawer__badge-wrapper svg {
    padding-top: 0;
    fill: {{ section.settings.color_trust_badges }};
  }

  .cart-page__badges-list div.cart-drawer__badge-title {
    font-size: 16px;
    letter-spacing: 0px;
    text-align: center;
