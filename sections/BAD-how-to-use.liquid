{% schema %}

{
  "name": "BAD How To Use Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How To Use"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F0FAEB"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step Image"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "Step description text goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BAD How To Use Section",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}

{% endschema %}

<section
  style="background-color: {{ section.settings.background_color }};"
  class="BAD-how-to-use-section"
>
  <h2 style="color: {{ section.settings.text_color }};" class="BAD-howto-Header">{{ section.settings.heading }}</h2>
  <div class="BAD-how-to-use-container">
    {% for block in section.blocks %}
      <div class="BAD-how-to-use-step">
        {% if block.settings.step_image %}
          <img
            src="{{ block.settings.step_image | img_url: 'medium' }}"
            alt="{{ block.settings.step_image.alt | escape }}"
            class="BAD-step-image"
          >
        {% endif %}
        <h3 class="BAD-step-title">{{ block.settings.step_title }}</h3>
        <p class="BAD-step-description">{{ block.settings.step_description }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .BAD-how-to-use-section {
    padding: 40px; text-align: center;
  }

  .BAD-how-to-use-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
  }

  .BAD-howto-Header {
    color: var(--Bottle-Green, #234134);
    text-align: center;
    font-family: bookmania;
    font-size: 27px;
    font-style: normal;
    font-weight: 700;
    line-height: 23.406px; /* 93.622% */
  }
  .BAD-how-to-use-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 300px;
    text-align: center;
  }
  .BAD-step-image {
    width: auto;
    height: 300px;
    margin-bottom: 10px;
    border-radius: 20px;
    border: 1px solid var(--Bottle-Green, #234134);
  }
  .BAD-step-title {
    font-size: 18px;
    font-weight: bold;
  }
  .BAD-step-description {
    font-size: 14px;
  }
  @media (max-width: 768px) {

      .BAD-how-to-use-section {
    padding: 20px;
  }
    .BAD-how-to-use-container {
      flex-direction: column;
      align-items:  center;
    }

    .BAD-howto-Header {
      font-size: 20px;
    }
  }
</style>
