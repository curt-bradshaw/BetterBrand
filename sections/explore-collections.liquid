<!-- START explore-collections.liquid -->

<div class="explore-collections">
  <div class="ec-header">
    <h2>{{ section.settings.heading }}</h2>
    <a href="{{ section.settings.see_all_link }}" class="ec-see-all">
      {{ section.settings.see_all_text }}
      {% render 'see-all-vector' %}
    </a>
  </div>

  <div class="ec-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="ec-item">
        <div class="ec-image-wrapper">
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.title }}"
            width="800"
            height="800"
          >
          <p class="ec-title">{{ block.settings.title }}</p>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% style %}
  .explore-collections {
    max-width: 1220px;
    margin: 80px auto;
    padding: 0 20px;
  }

  .ec-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 35px;
  }

  .ec-header h2 {
    font-family: var(--bookmaniaFont);
    font-size: 38px;
    font-weight: 700;
    margin: 0;
    max-width: 450px;
    color: #252525;
    line-height: 1.2;
  }

  .ec-see-all {
    font-size: 20px;
    color: #5b734e;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ec-see-all:hover {
    text-decoration: underline;
  }

  .ec-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(4, 1fr);
  }

  .ec-item {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ec-image-wrapper {
    width: 100%;
    height: 342px;
    overflow: hidden;
    border-radius: 12px;
    position: relative;
  }

  .ec-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.38) 100%);
  }

  .ec-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    border-radius: 12px;
  }

  .ec-item:hover img {
    transform: scale(1.05);
  }

  .ec-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    font-family: var(--bookmaniaFont);
    font-size: 30px;
    font-weight: 700;
    color: white;
    padding: 30px 15px;
    margin: 0;
    z-index: 1;
  }

  @media (max-width: 1019px) {
    .explore-collections {
      margin: 50px auto;
    }

    .ec-header h2 {
      font-size: 28px;
    }
    .ec-image-wrapper {
      height: auto;
    }
    .ec-title {
      font-size: 18px;
      padding: 18px 10px;
    }
  }

  @media (max-width: 767px) {
    .ec-title {
      padding: 12px 10px;
    }
    .ec-header h2 {
      font-size: 24px;
    }
    .ec-grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 7px;
      row-gap: 8px;
    }
    .ec-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
    .ec-see-all {
      font-size: 14px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Explore Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Our Collections"
    },
    {
      "type": "text",
      "id": "see_all_text",
      "label": "See All Text",
      "default": "See All"
    },
    {
      "type": "url",
      "id": "see_all_link",
      "label": "See All Link",
      "default": "/collections"
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Tincture"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Explore Collections"
    }
  ]
}
{% endschema %}
