{% comment %}
  BetterLungs Pre-lander — Shopify Liquid Page Template
  Template: page.betterlungs-prelander.liquid
  
  SETUP INSTRUCTIONS:
  1. Upload all files from the /assets/ folder to your Shopify theme's Assets directory.
  2. In Shopify Admin → Online Store → Themes → Edit Code, create this file under Templates.
  3. Create a new Page in Shopify Admin, then assign this template to it.
  4. Update PRODUCT_URL below to your exact product variant URL.
  
  ASSETS REQUIRED (upload all to Shopify Assets):
    bl-betterbrand-logo.png
    bl-hero-man.webp
    bl-dr-chris-branded.webp
    bl-mullein-in-wild.webp
    bl-tinc-with-dropper.webp
    bl-mullein-over-glass.webp
    bl-mullein-store-shelf.webp
    bl-mullein-table-flatlay.webp
    bl-avatar-dennis.webp
    bl-avatar-laura.webp
    bl-avatar-terry.webp
    bl-avatar-jon.webp
    bl-avatar-wilma.webp
    bl-avatar-lecount.webp
    bl-avatar-gary.webp
    bl-avatar-susan.webp
    bl-avatar-rachel.webp
{% endcomment %}

{% assign product_url = "https://www.trybetterbrand.com/products/betterlungs%C2%AE-mullein-chlorophyll?variant=50211235922219" %}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ============================================================
       BETTERLUNGS PRE-LANDER — INLINE STYLES
       Design: Newspaper advertorial (Rejuvacare-inspired)
       - Georgia serif body, Merriweather headlines
       - Teal masthead (#1a5276), white content, green CTAs (#27ae60)
       - Two-column layout: 70% article + 30% sticky sidebar
       - Skimmable: short paragraphs, bold callouts, images every 3-4 paragraphs
       ============================================================ */

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #f5f5f5;
      font-family: Georgia, 'Times New Roman', serif;
      color: #222;
      line-height: 1.8;
    }

    /* ---- MASTHEAD ---- */
    .bl-header {
      background: #1a5276;
      border-bottom: 2px solid #148f77;
    }
    .bl-header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 40px;
    }
    .bl-header-left {
      display: flex;
      align-items: center;
      gap: 18px;
      overflow: hidden;
    }
    .bl-publication-name {
      font-size: 18px;
      font-weight: 700;
      color: white;
      font-family: 'Inter', Arial, sans-serif;
      letter-spacing: -0.3px;
      line-height: 1;
      white-space: nowrap;
    }
    .bl-header-divider {
      width: 1px;
      height: 16px;
      background: rgba(255,255,255,0.3);
      flex-shrink: 0;
    }
    .bl-header-nav {
      display: flex;
      gap: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .bl-header-nav a {
      color: rgba(255,255,255,0.72);
      font-size: 12px;
      font-family: 'Inter', Arial, sans-serif;
      font-weight: 500;
      padding: 0 10px;
      text-decoration: none;
      white-space: nowrap;
      line-height: 40px;
    }
    .bl-advertorial-label {
      font-size: 10px;
      font-family: 'Inter', Arial, sans-serif;
      font-weight: 600;
      color: rgba(255,255,255,0.5);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* ---- MAIN CONTENT ---- */
    .bl-main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .bl-breadcrumb {
      padding: 10px 0;
      font-size: 12px;
      color: #666;
      font-family: Arial, sans-serif;
      border-bottom: 1px solid #ddd;
    }

    /* ---- TWO-COLUMN GRID ---- */
    .bl-article-grid {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 32px;
      padding-top: 24px;
    }
    @media (max-width: 768px) {
      .bl-article-grid {
        grid-template-columns: 1fr;
      }
      .bl-sidebar {
        display: none;
      }
    }

    /* ---- ARTICLE ---- */
    .bl-article { min-width: 0; }

    .bl-headline {
      font-family: 'Merriweather', Georgia, serif;
      font-size: clamp(22px, 4vw, 34px);
      font-weight: 900;
      line-height: 1.25;
      color: #1a1a1a;
      margin-bottom: 12px;
    }
    .bl-subheadline {
      font-size: 17px;
      color: #444;
      font-style: italic;
      border-left: 4px solid #1a5276;
      padding-left: 14px;
      margin-bottom: 16px;
      line-height: 1.6;
    }

    /* ---- BYLINE ---- */
    .bl-byline {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 0;
      border-top: 1px solid #ddd;
      border-bottom: 1px solid #ddd;
      margin-bottom: 20px;
    }
    .bl-byline-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .bl-byline-name {
      font-weight: 700;
      font-size: 13px;
      font-family: Arial, sans-serif;
      color: #1a1a1a;
    }
    .bl-byline-meta {
      font-size: 12px;
      color: #666;
      font-family: Arial, sans-serif;
    }
    .bl-social-icons {
      margin-left: auto;
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }
    .bl-social-icon {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 12px;
      font-weight: 700;
      font-family: Arial, sans-serif;
      cursor: pointer;
      text-decoration: none;
    }

    /* ---- HERO IMAGE ---- */
    .bl-hero-figure { margin: 0 0 24px 0; }
    .bl-hero-img {
      width: 100%;
      height: auto;
      max-height: 420px;
      object-fit: cover;
      object-position: center top;
      display: block;
      border-radius: 4px;
    }
    .bl-figcaption {
      font-size: 12px;
      color: #666;
      font-family: Arial, sans-serif;
      margin-top: 6px;
      font-style: italic;
    }

    /* ---- ARTICLE BODY ---- */
    .bl-body { font-size: 17px; line-height: 1.8; color: #222; }
    .bl-body p { margin-bottom: 14px; }

    /* ---- PULL QUOTE ---- */
    .bl-pullquote {
      background: #f0f7ff;
      border-left: 5px solid #1a5276;
      margin: 24px 0;
      padding: 18px 20px;
      font-style: italic;
      font-size: 19px;
      color: #1a3a5c;
      line-height: 1.6;
      border-radius: 0 4px 4px 0;
    }
    .bl-pullquote footer {
      font-size: 14px;
      margin-top: 10px;
      color: #555;
      font-style: normal;
      font-weight: 700;
    }

    /* ---- SECTION HEADERS ---- */
    .bl-section-header {
      font-family: 'Merriweather', Georgia, serif;
      font-size: 22px;
      font-weight: 800;
      color: #1a1a1a;
      margin: 28px 0 14px;
      padding-bottom: 8px;
      border-bottom: 2px solid #1a5276;
      clear: both;
    }

    /* ---- FLOAT IMAGE (Dr. Chris) ---- */
    .bl-float-right {
      float: right;
      margin: 0 0 16px 20px;
      max-width: 260px;
      width: 40%;
    }
    .bl-float-right img {
      width: 100%;
      height: auto;
      object-fit: cover;
      border-radius: 4px;
      display: block;
    }
    @media (max-width: 480px) {
      .bl-float-right {
        float: none;
        width: 100%;
        max-width: 100%;
        margin: 0 0 16px 0;
      }
    }

    /* ---- FULL-WIDTH FIGURE ---- */
    .bl-figure { margin: 0 0 20px 0; }
    .bl-figure img {
      width: 100%;
      height: auto;
      max-height: 360px;
      object-fit: cover;
      object-position: center;
      display: block;
      border-radius: 4px;
    }
    .bl-figure-center { margin: 0 0 20px 0; text-align: center; }
    .bl-figure-center img {
      width: auto;
      height: 340px;
      max-width: 100%;
      object-fit: contain;
      display: inline-block;
      border-radius: 4px;
    }

    /* ---- CALLOUT BOX: KEY FACTS ---- */
    .bl-callout-facts {
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-radius: 6px;
      padding: 20px 22px;
      margin: 24px 0;
    }
    .bl-callout-label {
      font-family: Arial, sans-serif;
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 1px;
      color: #1a5276;
      margin-bottom: 14px;
      text-transform: uppercase;
    }
    .bl-callout-facts ul {
      margin: 0;
      padding: 0 0 0 18px;
      font-family: Arial, sans-serif;
      font-size: 14px;
      color: #333;
      line-height: 1.8;
    }

    /* ---- TIMELINE CALLOUT ---- */
    .bl-timeline {
      background: linear-gradient(135deg, #1a5276 0%, #148f77 100%);
      border-radius: 8px;
      padding: 22px 24px;
      margin: 24px 0;
      color: white;
    }
    .bl-timeline-label {
      font-family: Arial, sans-serif;
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 1px;
      margin-bottom: 16px;
      text-transform: uppercase;
      opacity: 0.85;
    }
    .bl-timeline-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 14px;
    }
    .bl-timeline-item {
      background: rgba(255,255,255,0.12);
      border-radius: 6px;
      padding: 12px 14px;
    }
    .bl-timeline-week {
      font-weight: 800;
      font-size: 13px;
      font-family: Arial, sans-serif;
      margin-bottom: 4px;
    }
    .bl-timeline-desc {
      font-size: 12px;
      font-family: Arial, sans-serif;
      opacity: 0.85;
      line-height: 1.5;
    }

    /* ---- CLINICAL STUDY BOX ---- */
    .bl-clinical-box {
      background: #fff;
      border: 2px solid #1a5276;
      border-radius: 8px;
      padding: 22px 24px;
      margin: 24px 0;
    }
    .bl-clinical-title {
      font-family: Arial, sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 1px;
      color: #1a5276;
      margin-bottom: 18px;
      text-transform: uppercase;
      text-align: center;
    }
    .bl-stat-row { margin-bottom: 14px; }
    .bl-stat-labels {
      display: flex;
      justify-content: space-between;
      margin-bottom: 5px;
      font-family: Arial, sans-serif;
      font-size: 13px;
      color: #333;
    }
    .bl-stat-ratio { font-weight: 700; color: #148f77; }
    .bl-stat-bar-bg {
      background: #e8f5e9;
      border-radius: 4px;
      height: 10px;
      overflow: hidden;
    }
    .bl-stat-bar-fill {
      background: linear-gradient(90deg, #148f77, #1a5276);
      height: 100%;
      border-radius: 4px;
    }
    .bl-stat-note {
      font-size: 11px;
      color: #888;
      font-family: Arial, sans-serif;
      margin-top: 3px;
    }

    /* ---- CTA BOXES ---- */
    .bl-cta-box {
      background: linear-gradient(135deg, #1a5276 0%, #148f77 100%);
      border-radius: 8px;
      padding: 24px;
      margin: 28px 0;
      text-align: center;
    }
    .bl-cta-title {
      color: white;
      font-family: 'Merriweather', Georgia, serif;
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .bl-cta-subtitle {
      color: rgba(255,255,255,0.85);
      font-family: Arial, sans-serif;
      font-size: 14px;
      margin-bottom: 18px;
    }
    .bl-cta-btn {
      display: inline-block;
      background: #27ae60;
      color: white;
      font-family: Arial, sans-serif;
      font-weight: 800;
      font-size: 16px;
      padding: 14px 32px;
      border-radius: 4px;
      text-decoration: none;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .bl-cta-btn:hover { background: #219a52; }
    .bl-cta-note {
      color: rgba(255,255,255,0.7);
      font-family: Arial, sans-serif;
      font-size: 12px;
      margin-top: 10px;
    }
    .bl-cta-box-final { padding: 28px 24px; }
    .bl-cta-box-final .bl-cta-title { font-size: 22px; }
    .bl-cta-box-final .bl-cta-btn { font-size: 18px; padding: 16px 40px; }

    /* ---- TESTIMONIALS ---- */
    .bl-testimonial {
      background: #f9f9f9;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      padding: 18px 20px;
      margin-bottom: 16px;
    }
    .bl-testimonial-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }
    .bl-testimonial-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .bl-testimonial-name {
      font-weight: 700;
      font-family: Arial, sans-serif;
      font-size: 14px;
      color: #1a1a1a;
    }
    .bl-testimonial-stars { color: #f39c12; font-size: 14px; }
    .bl-verified-badge {
      margin-left: auto;
      font-size: 11px;
      color: #27ae60;
      font-family: Arial, sans-serif;
      font-weight: 700;
      background: #e8f5e9;
      padding: 3px 8px;
      border-radius: 3px;
    }
    .bl-testimonial-text {
      font-family: Arial, sans-serif;
      font-size: 14px;
      color: #333;
      line-height: 1.6;
    }

    /* ---- FACEBOOK-STYLE COMMENTS ---- */
    .bl-comments-section {
      margin: 32px 0 0;
      background: #e9ebee;
      border-radius: 8px;
      padding: 20px 18px 10px;
      border: 1px solid #d8dadf;
    }
    .bl-comments-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid #d8dadf;
    }
    .bl-comments-title {
      font-family: Arial, sans-serif;
      font-weight: 700;
      font-size: 15px;
      color: #1a1a1a;
    }
    .bl-comments-count {
      font-family: Arial, sans-serif;
      font-size: 13px;
      color: #65676b;
    }
    .bl-comment-input-row {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
      align-items: center;
    }
    .bl-comment-input-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #e4e6ea;
      flex-shrink: 0;
    }
    .bl-comment-input-box {
      flex: 1;
      background: #f0f2f5;
      border-radius: 20px;
      padding: 8px 16px;
      font-family: Arial, sans-serif;
      font-size: 14px;
      color: #65676b;
      cursor: text;
      border: none;
      outline: none;
    }
    /* Single comment */
    .bl-comment { margin-bottom: 16px; }
    .bl-comment-row {
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }
    .bl-comment-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .bl-comment-bubble {
      background: #f0f2f5;
      border-radius: 18px;
      padding: 10px 14px;
      display: inline-block;
      max-width: 100%;
    }
    .bl-comment-name {
      font-weight: 700;
      font-size: 14px;
      color: #050505;
      font-family: Arial, sans-serif;
    }
    .bl-comment-text {
      font-size: 14px;
      color: #050505;
      font-family: Arial, sans-serif;
      line-height: 1.5;
      margin-top: 2px;
    }
    .bl-comment-actions {
      display: flex;
      gap: 12px;
      margin-top: 4px;
      padding-left: 12px;
      align-items: center;
    }
    .bl-comment-action {
      font-size: 12px;
      font-weight: 600;
      color: #65676b;
      cursor: pointer;
      font-family: Arial, sans-serif;
      text-decoration: none;
    }
    .bl-comment-likes {
      display: flex;
      align-items: center;
      gap: 3px;
      font-size: 12px;
      color: #65676b;
      font-family: Arial, sans-serif;
    }
    .bl-like-badge {
      background: #1877f2;
      border-radius: 50%;
      width: 16px;
      height: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: white;
    }
    .bl-comment-time {
      font-size: 12px;
      color: #65676b;
      font-family: Arial, sans-serif;
    }
    /* Replies */
    .bl-replies { margin-left: 50px; margin-top: 8px; }
    .bl-reply-row {
      display: flex;
      gap: 8px;
      align-items: flex-start;
      margin-bottom: 8px;
    }
    .bl-reply-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .bl-reply-bubble {
      background: #f0f2f5;
      border-radius: 18px;
      padding: 8px 12px;
      display: inline-block;
      max-width: 100%;
    }
    .bl-reply-name {
      font-weight: 700;
      font-size: 13px;
      color: #050505;
      font-family: Arial, sans-serif;
    }
    .bl-reply-text {
      font-size: 13px;
      color: #050505;
      font-family: Arial, sans-serif;
      line-height: 1.5;
      margin-top: 2px;
    }
    .bl-view-more {
      text-align: center;
      padding: 12px 0;
      border-top: 1px solid #e4e6ea;
      margin-top: 8px;
    }
    .bl-view-more a {
      color: #1877f2;
      font-family: Arial, sans-serif;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
    }

    /* ---- DISCLAIMER ---- */
    .bl-disclaimer {
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-radius: 4px;
      padding: 16px 18px;
      margin: 24px 0;
      font-size: 11px;
      color: #666;
      font-family: Arial, sans-serif;
      line-height: 1.6;
    }

    /* ---- SIDEBAR ---- */
    .bl-sidebar {
      align-self: flex-start;
      position: sticky;
      top: 20px;
    }
    .bl-sidebar-card {
      background: white;
      border: 1px solid #ddd;
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .bl-sidebar-card-header {
      color: white;
      padding: 10px 14px;
      font-family: Arial, sans-serif;
      font-weight: 800;
      font-size: 12px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .bl-sidebar-card-header.teal { background: #1a5276; }
    .bl-sidebar-card-header.green { background: #148f77; }
    .bl-sidebar-product-img {
      width: 100%;
      height: 200px;
      object-fit: contain;
      background: #fafafa;
      padding: 10px;
      display: block;
    }
    .bl-sidebar-card-body { padding: 14px; }
    .bl-sidebar-product-name {
      font-family: 'Merriweather', Georgia, serif;
      font-weight: 800;
      font-size: 15px;
      color: #1a1a1a;
      margin-bottom: 6px;
      line-height: 1.3;
    }
    .bl-sidebar-stars { color: #f39c12; font-size: 14px; margin-bottom: 6px; }
    .bl-sidebar-product-desc {
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #555;
      margin-bottom: 14px;
      line-height: 1.5;
    }
    .bl-sidebar-btn {
      display: block;
      background: #27ae60;
      color: white;
      font-family: Arial, sans-serif;
      font-weight: 800;
      font-size: 13px;
      padding: 11px 16px;
      border-radius: 4px;
      text-decoration: none;
      text-align: center;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .bl-sidebar-btn:hover { background: #219a52; }
    /* Sidebar stat rows */
    .bl-sidebar-stat { margin-bottom: 12px; }
    .bl-sidebar-stat-labels {
      display: flex;
      justify-content: space-between;
      margin-bottom: 4px;
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #333;
    }
    .bl-sidebar-stat-ratio { font-weight: 700; color: #148f77; }
    .bl-sidebar-stat-bar-bg {
      background: #e8f5e9;
      border-radius: 3px;
      height: 8px;
      overflow: hidden;
    }
    .bl-sidebar-stat-bar-fill {
      background: linear-gradient(90deg, #148f77, #1a5276);
      height: 100%;
      border-radius: 3px;
    }
    .bl-sidebar-stat-note {
      font-size: 10px;
      color: #999;
      font-family: Arial, sans-serif;
      margin-top: 8px;
    }
    /* Sidebar mini testimonials */
    .bl-sidebar-mini-testimonial {
      display: flex;
      gap: 10px;
      margin-bottom: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid #f0f0f0;
    }
    .bl-sidebar-mini-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .bl-sidebar-mini-name {
      font-weight: 700;
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #1a1a1a;
