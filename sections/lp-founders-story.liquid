<script>
  (function() {
    /* Hide shipping bar, header, and footer by their Shopify section IDs */
    var hideIds = [
      'shopify-section-sections--26199536337195__shipping_bar_4LRaz',
      'shopify-section-sections--26199536337195__header',
      'shopify-section-sections--26199536304427__footer'
    ];
    /* Also hide by class patterns */
    var hideClasses = ['shipping-bar', 'section-header', 'shopify-section-header-sticky', 'ntg-footer'];

    function hideChrome() {
      hideIds.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.style.setProperty('display', 'none', 'important');
      });
      hideClasses.forEach(function(cls) {
        document.querySelectorAll('.' + cls).forEach(function(el) {
          /* Only hide if it's a shopify-section wrapper (not our own elements) */
          if (el.id && el.id.indexOf('shopify-section') === 0) {
            el.style.setProperty('display', 'none', 'important');
          }
        });
      });
      /* Also hide Just Uno / Klaviyo */
      var popupSelectors = [
        '[iswrapper="true"]', '[justunologo]', '#inob',
        '[id*="justuno"]', '[class*="justuno"]', '#ju-root',
        '[id*="klaviyo-modal"]', '[class*="kl-private"]'
      ];
      popupSelectors.forEach(function(sel) {
        document.querySelectorAll(sel).forEach(function(el) { el.remove(); });
      });
    }

    hideChrome();
    document.addEventListener('DOMContentLoaded', hideChrome);

    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        m.addedNodes.forEach(function(node) {
          if (node.nodeType !== 1) return;
          /* Hide shipping bar / header if they appear after load */
          if (node.id && hideIds.indexOf(node.id) > -1) {
            node.style.setProperty('display', 'none', 'important');
          }
          /* Hide Just Uno */
          var isJU = node.hasAttribute && (
            node.hasAttribute('iswrapper') ||
            node.hasAttribute('justunologo') ||
            (node.id && node.id.toLowerCase().indexOf('justuno') > -1) ||
            (node.id && node.id === 'inob')
          );
          if (isJU) node.remove();
        });
      });
    });
    observer.observe(document.documentElement, { childList: true, subtree: true });
  })();
</script>

