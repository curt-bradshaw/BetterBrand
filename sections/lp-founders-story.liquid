  <img id="prl-lb-img" src="" alt="" />
</div>

<script>
(function() {
  /* ── Sticky CTA scroll trigger (fires after 25% page scroll) ── */
  var bar = document.getElementById('prl-sticky-cta');
  if (bar) {
    var shown = false;
    function checkScroll() {
      var scrolled = window.scrollY || document.documentElement.scrollTop;
      var docHeight = Math.max(
        document.body.scrollHeight, document.documentElement.scrollHeight,
        document.body.offsetHeight, document.documentElement.offsetHeight
      ) - window.innerHeight;
      var pct = docHeight > 0 ? scrolled / docHeight : 0;
      if (!shown && pct >= 0.25) {
        bar.classList.add('prl-visible');
        shown = true;
        window.removeEventListener('scroll', checkScroll, { passive: true });
      }
    }
    window.addEventListener('scroll', checkScroll, { passive: true });
    /* Do NOT call checkScroll() on load — only trigger on actual scroll */
  }

  /* ── Image lightbox ── */
  var overlay = document.getElementById('prl-lb-overlay');
  var lbImg   = document.getElementById('prl-lb-img');
  if (overlay && lbImg) {
    document.querySelectorAll('.prl-img-block img').forEach(function(img) {
      img.addEventListener('click', function() {
        lbImg.src = img.src;
        lbImg.alt = img.alt;
        overlay.classList.add('prl-active');
        document.body.style.overflow = 'hidden';
      });
    });
    overlay.addEventListener('click', function() {
      overlay.classList.remove('prl-active');
      document.body.style.overflow = '';
      lbImg.src = '';
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        overlay.classList.remove('prl-active');
        document.body.style.overflow = '';
        lbImg.src = '';
      }
    });
  }
})();
</script>

