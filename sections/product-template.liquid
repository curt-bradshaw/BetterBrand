{{- css | strip_newlines | replace: ' ', ' ' | replace: ' ', ' ' | replace: ' ', ' ' -}}

<section id="product" class="product-page" data-section-type="product-template">
  <div
    class="wrapper product-mobile-wrapper"
  >
    <div class="products-info">
      <div
        class="desktop product-half half-img {% if settings.enable_sticky_product_slider %}product-slider-sticky{% endif %}"
      >
        {% if section.settings.enable_custom_product_image_view %}
          {%- render 'custom-product-images-desktop-slider' -%}
          {%- render 'custom-product-images-desktop' -%}
        {% else %}
          {%- render 'product-sliders' -%}
        {% endif %}
      </div>

      <div class="product-half rte">
        {% if settings.enable_product_breadcrumbs %}
          {% render 'breadcrumb' %}
        {% endif %}
        {% assign benefits_from_metafields = product.metafields.pdp.benefits.value %}
        {% assign all_benefits_rendered = false %}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {% when 'product_images' %}
              <div
                class="no-desktop product-half half-img {% if settings.enable_sticky_product_slider %}product-slider-sticky{% endif %}"
              >
                {%- render 'product-sliders' -%}
              </div>
            {%- when 'title' -%}
              {%- render 'product-title' with block: block, product_title: product.title -%}
            {% when 'reviews' %}
              {%- render 'product-reviews' with block: block, pattern: '([rating] of [count] reviews)' -%}
            {%- when 'price' -%}
              {%- render 'product-price-new-layout' with block: block -%}
            {%- when 'product_info' -%}
              {% unless product.metafields.custom.hide_product_benefits_on_pdp == true %}
                {% if benefits_from_metafields == blank %} 
                  {% render 'product-info' with block: block %}
                {% elsif benefits_from_metafields and all_benefits_rendered == false %}
                  {% for item in benefits_from_metafields %}
                    {% render 'product-info' with item: item %}
                  {% endfor %}
                  {% assign all_benefits_rendered = true %}
                {% endif %}
              {% endunless %}
            {%- when 'description' -%}
              {%- render 'product-description' with product: product, block: block -%}
            {%- when 'product_form' -%}
              {%- render 'product-form' with settings: settings, product: product, section.id: section.id, block: block -%}
            {% when 'product_badges' %}
              {%- render 'product-badges' with block: block -%}
            {%- when 'product_upsell' -%}
              <div class="product-page__upsell-wrapper">
                <div class="new-product-page-upsell-carousel-title">Customers Also Bought</div>
                {%- render 'product-page-upsell' with block:block -%}
              </div>
            {%- when 'container-reviews' -%}
              {%- render 'container-reviews' with block:block -%}
          {%- endcase -%}
        {%- endfor -%}

        {%- if section.settings.enabled_videos -%}
          {%- render 'product-video' with settings: settings, product: product, section.id: section.id -%}
        {%- endif -%}

        {%- if section.settings.enabled_tabs -%}
          {%-
            render 'product-tabs-accordion' with
            first_tab_index: first_tab_index,
            tab_index:forloop.index,
            block: block,
            settings: settings,
            product: product,
            section.id: section.id
          -%}
        {%- endif -%}
        {% if section.settings.enable_review_container %}
          {% render 'container-reviews' %}
        {% endif %}
      </div>

      {%- if settings.enabled_social_share and settings.social_share_position == 'below' -%}
        {%- render 'social-sharing' -%}
      {%- endif -%}
    </div>
  </div>
</section>

{%- if settings.app_review != 'none' -%}
  {%- if settings.product_enabled_app_reviews_slider -%}
    <div class="wrapper">
      {%- render 'all-reviews' -%}
    </div>
  {%- else -%}
    {%- render 'all-reviews' -%}
  {%- endif -%}
{%- endif -%}

