{% comment %} Start Block Counter {% endcomment %}
{% assign first_tab_index = 0 %}
{% assign num_of_trust_badges = 0 %}
{% for block in section.blocks %}
  {% if block.type == 'tab-richtext' %}
    {% assign first_tab_index = forloop.index %}
    {% break %}
  {% endif %}

  {% if block.type == 'trust_bagde' %}
    {% if block.settings.enable_trust_badge01 %}
      {% assign num_of_trust_badges = num_of_trust_badges | plus: 1 %}
    {% endif %}

    {% if block.settings.enable_trust_badge02 %}
      {% assign num_of_trust_badges = num_of_trust_badges | plus: 1 %}
    {% endif %}

    {% if block.settings.enable_trust_badge03 %}
      {% assign num_of_trust_badges = num_of_trust_badges | plus: 1 %}
    {% endif %}

    {% if block.settings.enable_trust_badge04 %}
      {% assign num_of_trust_badges = num_of_trust_badges | plus: 1 %}
    {% endif %}
  {% endif %}
{% endfor %}
{% comment %} End Block Counter {% endcomment %}

