  <h2 style="color: {{ section.settings.text_color }};" class="BAD-howto-Header">{{ section.settings.heading }}</h2>


<section
  style="background-color: {{ section.settings.background_color }};"
  class="BAD-how-to-use-section how-to-use-section-v2 how-to-use-seasonal"
>
  <div class="BAD-how-to-use-container">
    {% for block in section.blocks %}
      <div class="BAD-how-to-use-step how-to-use-step-seasonal">
        {% if block.settings.step_image %}
            <div class="step-header">
                <h3 class="BAD-step-title">0{{ forloop.index }}</h3>
                <img
                    src="{{ block.settings.step_image | img_url: 'medium' }}"
                    alt="{{ block.settings.step_description }}"
                    class="BAD-step-image"
                >
            </div>
            
        {% endif %}
        <div class="step-wrap">
          <p class="BAD-step-description">{{ block.settings.step_description }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
</section>






<style>
  #shopify-section-{{section.id}}{

    
    padding: 20px;

    @media (min-width: 1200px) {
      max-width: 1390px;
      margin-right: auto;
      margin-left: auto;
      padding: 0;
       margin: 40px auto;
    }

    .BAD-how-to-use-section {
      padding: 40px; 
      text-align: center;
      border-radius: 8px;
      box-shadow: 5px 3px 16px #0000002e;
    }

    .BAD-how-to-use-step {
      box-shadow: 0 -1px 3px -1px rgba(0, 0, 0, 0.05), 0 2px 10px -2px rgba(0, 0, 0, 0.10);
      padding: 16px;
    }


     .step-wrap {
      width: 100%;
      display: flex;
      gap: 10px;
      text-align: left;
      align-items: flex-start;

      p{
        font-weight: 350;
        line-height: 145%;
      }

     strong {
        color: #233F21;
        font-family: Suisse_Intl_Mono !important;
        font-size: 17px;
        font-style: normal;
        font-weight: 700;
        line-height: 25px; /* 208.333% */
        display: block;
        position:relative;
      }
      strong:after{
        position: absolute;
        content: "";
        width: 100%;
        height: 1px;
        bottom: -14px;
        background: #000;
        left: 0;

      }


          @media (min-width: 1200px) {
             strong {
               font-size: 20px;
            }
            
           
          }
    }
  


  .BAD-how-to-use-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 36px;
    margin-top: 20px;
  }

  .BAD-howto-Header {
    color: #234134 !important;
    text-align: center;
    font-family: Inter;
    font-size: 30px;
    font-style: normal;
    font-weight: 700;
    line-height: 36px;
    text-align:center;
  }
  .BAD-how-to-use-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }

 

  .BAD-step-title {
    color: #234134;
    font-family: Bookmania !important;
    font-size: 32px;
    font-style: normal;
    font-weight: 900;
    line-height: normal;
    margin:0;
  }

  .BAD-step-description {
    color: #233F21;
    font-family: Inter;
    font-size: 15.6px;
    font-style: normal;
    font-weight: 500;
    line-height: 24px; /* 176.471% */
    margin:0;
    margin-top:4px;

    
  }
  @media (min-width: 1024px) {

    .BAD-how-to-use-container{
      gap:140px;
      .BAD-how-to-use-step {
        width: calc((100% / 3) - (((3 - 1) / 3) * 141px));
        max-width: calc((100% / 3) - (((3 - 1) / 3) * 141px));
      }

      .BAD-howto-Header{
        max-width: 750px;
				margin-right: auto !important;
				margin-left: auto !important;
      }
    }

    
  
}

  @media (max-width: 768px) {
      .BAD-how-to-use-section {
        padding: 20px;
      }
    .BAD-how-to-use-container {
      flex-direction: column;
      align-items:  center;
    }

    .BAD-howto-Header {
      text-align: center;
      font-size: 29px;
      font-weight: 700;
      line-height: 1.12;
      color: #234134;
      
    }
  }

  }
</style>


{% schema %}
{
  "name": "How To Use v2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How To Use"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F0FAEB"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step Image"
        },
        {
          "type": "richtext",
          "id": "step_description",
          "label": "Step Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To Use v2",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}
{% endschema %}
