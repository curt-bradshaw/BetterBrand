<div class="ntg-post-swiper-section{% if section.settings.slider_nav == 'dots_on_desktop' %} ntg-small-spacing{% endif %}">
  <div class="ntg-container">
    <div class="ntg-heading-holder">
      <h2 class="ntg-h2">{{ section.settings.heading }}</h2>
    </div>
    <div class="ntg-post-swiper-holder">
      <div class="ntg-post-swiper{% if section.settings.slider_nav == 'scroll_on_desktop' %} ntg-scrollbar{% elsif section.settings.slider_nav == 'dots_on_desktop' %} ntg-with-pagination{% else %}{% endif %}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% assign prod = block.settings.product %}
            <div class="swiper-slide ntg-max">
              <div class="ntg-slide-box">
                <div class="ntg-img-holder">
                  <a href="{{ prod.url }}">
                    {% if block.settings.alter_image != blank %}
                      <img
                        src="{{ block.settings.alter_image | img_url: 'master' }}"
                        alt="{{ prod.title }}"
                        width="265"
                        height="265"
                      >
                    {% else %}
                      <img
                        src="{{ prod.featured_image | img_url: '265x265' }}"
                        alt="{{ prod.title }}"
                        width="265"
                        height="265"
                      >
                    {% endif %}
                  </a>
                </div>

                <div class="ntg-text-holder">
                  <h3 class="ntg-h3">
                    <a href="{{ prod.url }}" style="color: inherit;">{{ prod.title }}</a>
                  </h3>
                  <p>{{ block.settings.prod_tagline }}</p>
                  <span class="ntg-price">{{ prod.price | money }}</span>
                </div>
                <div class="ntg-btn-holder">
                  {%- form 'product',
                    prod,
                    class: 'ntg-add-form',
                    novalidate: 'novalidate',
                    data-type: 'add-to-cart-form',
                    data-loop-product-id: product.id
                  -%}
                    <input
                      type="hidden"
                      name="id"
                      value="{{ prod.selected_or_first_available_variant.id }}"
                      class="product-variant-id"
                      {% if prod.selected_or_first_available_variant.available == false %}
                        disabled
                      {% endif %}
                    >
                    <button
                      type="submit"
                      name="add"
                      class="ntg-btn"
                      {% if prod.selected_or_first_available_variant.available == false %}
                        disabled
                      {% endif %}
                      style="border: none; font-family: inherit;"
                    >
                      {%- if prod.selected_or_first_available_variant.available -%}
                        ADD TO CART
                      {%- else -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- endif -%}
                    </button>
                  {%- endform -%}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-nav">
          <div class="swiper-button-prev">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14.8">
              <path d="M19.8 6.8c-.1-.1-.3-.2-.6-.2H2.7L8 1.3c.1-.1.2-.3.2-.5S8.1.4 8 .2C7.8.1 7.6 0 7.4 0c-.2 0-.4.1-.6.2L.2 6.8c-.1.2-.2.4-.2.6 0 .1 0 .2.1.3 0 .1.1.2.2.3l6.6 6.6c.1.1.2.1.3.2.1 0 .2.1.3.1.2 0 .3 0 .4-.1.1-.1.2-.2.3-.4.1-.1.1-.3 0-.5 0-.2-.1-.3-.2-.4L2.7 8.2h16.6c.2 0 .4-.1.6-.2 0-.2.1-.4.1-.6s-.1-.4-.2-.6z" fill="#231f20"/>
            </svg>
          </div>
          <div class="swiper-button-next">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14.8">
              <path d="M20 7.4c0-.2-.1-.4-.2-.6L13.2.2c-.2-.1-.4-.2-.6-.2-.2 0-.4.1-.6.2-.1.1-.2.3-.2.6 0 .2.1.4.2.6l5.3 5.3H.8c-.2 0-.4.1-.6.2-.1.1-.2.3-.2.5s.1.4.2.6c.1.1.3.2.6.2h16.6l-5.3 5.3c-.1.1-.2.2-.2.4v.5c.1.1.2.3.3.4.1.1.3.1.4.1.1 0 .2 0 .3-.1.1 0 .2-.1.3-.2L19.8 8c.1-.2.2-.4.2-.6z" fill="#231f20"/>
            </svg>
          </div>
        </div>
        <div class="swiper-scrollbar"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Current Favourites",
  "class": "custom-product-add",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Current Favourites"
    },
    {
      "type": "select",
      "id": "slider_nav",
      "label": "Slider nav",
      "options": [
        {
          "value": "default",
          "label": "default"
        },
        {
          "value": "scroll_on_desktop",
          "label": "Scrollbar on desktop"
        },
        {
          "value": "dots_on_desktop",
          "label": "Dots on desktop"
        }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "select",
      "name": "product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "alter_image",
          "label": "Alternate Product Image"
        },
        {
          "type": "text",
          "id": "prod_tagline",
          "label": "Product Tagline",
          "default": "#1 Lung Health Support"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Current Favourites",
      "category": "Custom Sections",
      "blocks": [
        {
          "type": "select"
        },
        {
          "type": "select"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
