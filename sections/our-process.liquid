<!-- START our-process.liquid -->
<style>
  #shopify-section-{{ section.id }} .our-process__section {
    padding: 80px 20px;
    background-color: {{ section.settings.background_color }};
    {% if section.settings.show_background_image %}
      background-image: url('{{ 'our-process-bg.png' | file_img_url: 'master' }}');
    {% endif %}
    background-size: cover;
    background-position: bottom;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .our-process__wrapper{
    max-width: 1200px;
    margin: 0 auto;
  }
  

  @media (min-width: 2300px) {
    .our-process__section {
      background-position: 100% 85%;
    }
  }


  #shopify-section-{{ section.id }} .our-process__section .new-lander-section-title > * {
    {% if section.settings.white_version %}
      color: #252525;
    {% else %}
      color: #FFFFFF;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .our-process__timeline-item-container-card-title > * {
    font-weight: 700;
    {% if section.settings.white_version %}
      color: #252525;
    {% else %}
      color: #FFFFFF;
    {% endif %}
  }

  .our-process__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    {% comment %} gap: 40px; {% endcomment %}
    align-self: stretch;
  }

  .our-process__timeline-item-container-card-title{
    font-size: 30px;
    font-weight: 700;
  }

  .our-process__title{
    font-size: 38px;
  }

  .our-process__title p,
  .our-process__subtitle p{
    margin-bottom: 0 !important;
  }

  .our-process__subtitle{
    margin-bottom: 35px;
    color: #252525;
  }

  .our-process__subtitle *{
    font-size: 22px;
  }

  .our-process__title,
  .our-process__timeline-item-container-card-title *{
    font-family: var(--bookmaniaFont);
  }

  .our-process__timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    align-self: stretch;
    overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ section.id }} .our-process__timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    align-self: stretch;
    position: relative;
    {% if section.settings.show_history_images %}
      padding-bottom: 70px;
    {% else %}
      padding-bottom: 40px;
    {% endif %}
  }

  {% if section.settings.hide_timeline_last_line %}
    #shopify-section-{{ section.id }} .our-process__timeline-item:last-child {
      padding-bottom: 0px;
    }
  {% endif %}

  .our-process__timeline-item.our-process__timeline-item--reverse {
    flex-direction: row-reverse;
  }

  {% if section.settings.show_history_images %}
    #shopify-section-{{ section.id }} .our-process__timeline-item.our-process__timeline-item--reverse .our-process__timeline-item-container--third {
      display: flex;
      justify-content: end;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .our-process__timeline-item-container-card:not(.our-process__timeline-item-container-card--reverse) {
    align-items: flex-start;
  }
  #shopify-section-{{ section.id }} .our-process__timeline-item-container-card {
    display: flex;
    padding: 20px;
    flex-direction: column;
    gap: 16px;
    border-radius: 12px;
  }

  .our-process__timeline-item-container--first,
  .our-process__timeline-item-container--third {
    width: 45%;
  }

  .our-process__timeline-item-container--second {
    width: 6%;
    flex-shrink: 0;
    flex-grow: 0;
    display: flex;
    justify-content: center;
  }
  
  #shopify-section-{{ section.id }} .our-process__timeline-item-container--bullet-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    z-index: 1;
    position: relative;
    transition: border 0.2s ease-in-out, background 0.2s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 29px;
  }

  .our-process__timeline-item-container--bullet-circle--active .our-process__timeline-item-container--bullet-circle-icon .bullet-circle-icon {
    opacity: 1;
  }
  
  #shopify-section-{{ section.id }} .our-process__timeline-line::before {
    content: "";
    position: absolute;
    {% if section.settings.hide_timeline_last_line %}
      height: calc(var(--timeline-max-height) - var(--timeline-line-height));
    {% else %}
      height: 100%;
    {% endif %}
    top: var(--timeline-line-height);
    transform: translateX(-50%);
    {% if section.settings.white_version %}
      border: 5px solid #C2DEB4;
    {% else %}
      border: 5px solid #C2DEB4;
    {% endif %}
    z-index: 0;
  }


  .our-process__timeline::after {
    bottom: 2px;
    left: 50.2%;
    transform: translateX(-50%) rotate(135deg);
  }

  .our-process__timeline-item-container--bullet-circle::before {
    top: -5px;
    left: 13px;
    transform: translateX(-50%) rotate(45deg);
  }

  .our-process__timeline-item-container--bullet-circle::after {
    top: -5px;
    left: 17px;
    transform: translateX(-50%) rotate(135deg);
  }

  .our-process__timeline-item-container--bullet-circle--first::before,
  .our-process__timeline-item-container--bullet-circle--first::after {
    content: none;
  }

  .our-process__timeline-item-container-card-subtext > * {
    color: #555555;
    font-size: 20px;
  }

  .our-process__timeline-item-container--history-image {
    margin-bottom: 16px;
  }

  .our-process__timeline-item-container--history-image img {
    width: 100%;
    min-height: 130px;
  }

  .our-process__section-image-1{
    position: relative;
  }
  .our-process__section-image-2{
    position: relative;
  }

  .our-process__section-image-1 img {
    position: absolute;
    top: -120px;
    right: 20px;
    transform: rotate(90deg);
    max-width: 268px;
  }

  .our-process__section-image-2 img {
    position: absolute;
    bottom: -50px;
    left: -82px;
    transform: rotate(32deg);
    max-height: 345px;
    width: auto;
  }

  .our-process__timeline-item-container-card-header *{
    margin-bottom: 0 !important;
    height: fit-content;
  }
  .our-process__timeline-item-container-card-header{
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .reverse-desktop-order{
    flex-direction: row-reverse;
  }

  .our-process__timeline-item-container-card-title p{
    height: fit-content;
    margin-top: 10px !important;
  }
  .our-process__timeline-item-container-card-number{
    color: #F0FFE9;
    background-color: #234134;
    border-radius: 50%;
    padding: 2px 10px;
  }

  .our-process__timeline-item-container-card-number * {
    font-size: 20px;
  }

  .our-process__timeline-item-container-card.our-process__timeline-item-container-card--reverse{
    align-items: flex-end;
  }

  .our-process__timeline-item-container-card.our-process__timeline-item-container-card--reverse .our-process__timeline-item-container-card-subtext{
    text-align: end;
  }

  @media (max-width: 1024px) {
    .our-process__section {
      background-image: none;
      padding-top: 40px;
    }

  }

  @media (max-width: 1019px) {

    .our-process__section-image-1 img {
      max-width: 224px;
      top: 20px;

    }

    .our-process__section-image-2 img {
      bottom: -85px;
      transform: rotate(18deg);
      max-height: 260px;
      left: -75px !important;
    }

    #shopify-section-{{ section.id }} .our-process__timeline-item-container-card {
      padding: 0px;
    }

    #shopify-section-{{ section.id }} .our-process__timeline-item-container--bullet-circle {
      margin-top: 4px;
    }

    #shopify-section-{{ section.id }} .our-process__timeline-item {
        padding-bottom: 0px;
    }

    #shopify-section-{{ section.id }} .our-process__timeline-item-container-card {
      gap: 10px;
    }

    .our-process__title *{
      font-size: 28px;
    }

    .our-process__subtitle{
      margin-top: 10px;
    }
    .our-process__subtitle *{
      font-size: 20px;
    }

    .our-process__timeline-item-container-card-title{
      font-size: 28px;
    }

    .our-process__timeline-item-container-card-subtext > * {
      font-size: 18px;
      line-height: 26px;
    }
  }

  @media (max-width: 767px) {

    #shopify-section-{{ section.id }} .our-process__timeline-line::before {
      height: 94%;
    }

    #shopify-section-{{ section.id }} .our-process__section {
      padding: 40px 20px;
    }
    #shopify-section-{{ section.id }} .our-process__timeline-item {
        padding-bottom: 40px;
    }

    .our-process__section-image-2 img {
      display: none;
    }

    #shopify-section-{{ section.id }} .our-process__timeline-item {
      gap: 15px !important;
    }

    #shopify-section-{{ section.id }} .our-process__timeline-item-container--bullet-circle{
      margin-left: 2px;
    }

    .our-process__timeline-item-container-card-title *{
      font-size: 24px;
    }

    .our-process__section-image-1 img {
      top: -95px;
      right: -56px;
      max-width: 146px;
    }

    .our-process__title {
      margin-top: 5px;
    }

    .our-process__title *{
      font-size: 24px;
    }

    .our-process__subtitle *{
      font-size: 16px;
    }

    .reverse-desktop-order{
      flex-direction: row !important;
    }

    .our-process__timeline-item-container-card--reverse{
      align-items: flex-start !important;
    }

    .our-process__timeline-item-container-card--reverse .our-process__timeline-item-container-card-subtext{
      text-align: start !important;
    }

    .new-lander-hide-mobile{
      display: none !important;
    }

    .our-process__timeline-item {
      flex-direction: row-reverse;
      justify-content: start;
    }

    .our-process__timeline-item-container-card-subtext > * {
      font-size: 16px;
      line-height: 26px;
    }

    .our-process__title.reduce-title-size > * {
      font-size: 28px;
      line-height: 36px;
    }

    .our-process__timeline-item-container--first {
      width: 100%;
    }

    .our-process__timeline-item-container--second {
      width: 10%;
    }

    .our-process__timeline-line::before,
    .our-process__timeline-line::after {
      left: 5%;
    }

    .our-process__timeline-item {
      gap: 16px;
      padding-bottom: 50px;
    }

    .our-process__timeline::before {
      left: 4.3%;
    }
  
    .our-process__timeline::after {
      left: 5.7%;
    }

    {% comment %} .our-process__timeline-item-container--second{
      transform: translateX(-150%);
    } {% endcomment %}

    #shopify-section-{{ section.id }} .our-process__timeline-line::before {
      transform: translateX(-46%);
      top: 35px;
    }
    
  }

</style>


<section class="our-process__section">
  {% if section.settings.section_image_1 %}
    <div class="our-process__section-image-1">
      <img src="{{ section.settings.section_image_1 | image_url: width: 1000 }}" alt="{{ section.settings.section_image_1.alt }}" width="268" height="180">
    </div>
  {% endif %}
  <div class="our-process__wrapper new-lander-wrapper">
    
    <div class="our-process__container">
      <div class="our-process__title new-lander-section-title orange-strong {% if section.settings.reduce_title_size %}reduce-title-size{% endif %}">
        {{ section.settings.title }}
      </div>
      <div class="our-process__subtitle">
        {{ section.settings.subtitle }}
      </div>
      <div class="our-process__timeline">
        <div class="our-process__timeline-line">
        </div>
        {% for block in section.blocks %}
          {% assign is_odd = forloop.index | modulo: 2 %}
          <div class="our-process__timeline-item {% if is_odd == 0 %}our-process__timeline-item--reverse{% endif %}">
            <div class="our-process__timeline-item-container--first">
              {% if section.settings.show_history_images %}
                <div class="our-process__timeline-item-container--history-image hide-desktop">
                  {% case forloop.index %}
                    {% when 1 %}
                      <img src="{{ 'history-img1.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% when 2 %}
                      <img src="{{ 'history-img2.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% when 3 %}
                      <img src="{{ 'history-img3.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% when 4 %}
                      <img src="{{ 'history-img4.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% when 5 %}
                      <img src="{{ 'history-img5.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% when 6 %}
                      <img src="{{ 'history-img6.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% when 7 %}
                      <img src="{{ 'history-img7.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                    {% else %}
                      <img src="{{ 'custom-last-image.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% endcase %}
                </div>
              {% endif %}
              <div class="our-process__timeline-item-container-card {% if block.settings.reverse_order %}our-process__timeline-item-container-card--reverse{% endif %}">
                <div class="our-process__timeline-item-container-card-header">
                    <div class="our-process__timeline-item-container-card-number new-lander-section-paragraph text-white obvia-font">
                      {{ block.settings.item_number }}
                    </div>
                    <div class="our-process__timeline-item-container-card-title new-lander-section-paragraph text-white obvia-font">
                      {{ block.settings.text }}
                    </div>
                </div>
                <div class="our-process__timeline-item-container-card-subtext new-lander-section-paragraph text-white">
                  {{ block.settings.subtext }} 
                </div>
              </div> 
            </div>
            <div class="our-process__timeline-item-container--second">
              <div class="our-process__timeline-item-container--bullet-circle {% if forloop.first %}our-process__timeline-item-container--bullet-circle--first{% endif %}">
                <span class="our-process__timeline-item-container--bullet-circle-icon">
                  {% if section.settings.white_version %}
                    {% render 'bullet-circle-icon' %}
                  {% else %}
                    <img src="{{ 'orange-check-icon.png' | file_img_url: 'master' }}" width="18" height="18" loading="lazy" >
                  {% endif %}
                </span>
              </div> 
            </div>
            <div class="our-process__timeline-item-container--third new-lander-hide-mobile">
              {% if section.settings.show_history_images %}
                {% case forloop.index %}
                  {% when 1 %}
                    <img src="{{ 'history-img1.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% when 2 %}
                    <img src="{{ 'history-img2.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% when 3 %}
                    <img src="{{ 'history-img3.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% when 4 %}
                    <img src="{{ 'history-img4.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% when 5 %}
                    <img src="{{ 'history-img5.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% when 6 %}
                    <img src="{{ 'history-img6.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% when 7 %}
                    <img src="{{ 'history-img7.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% else %}
                    <img src="{{ 'custom-last-image.png' | file_img_url: '660x270' }}" width="230" height="135" loading="lazy" >
                  {% endcase %}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div> 
  {% if section.settings.section_image_2 %}
    <div class="our-process__section-image-2">
      <img src="{{ section.settings.section_image_2 | image_url: width: 1000 }}" width="391" height="388" alt="{{ section.settings.section_image_2.alt }}">
    </div>
  {% endif %}
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const timeline = document.querySelector('#shopify-section-{{ section.id }} .our-process__timeline');
    const timelineItemContainers = document.querySelectorAll('#shopify-section-{{ section.id }} .our-process__timeline-item-container');
    const timelineSteps = Array.from(document.querySelectorAll('#shopify-section-{{ section.id }} .our-process__timeline-item-container--bullet-circle'));

    function distanceCalculation(div1, div2) {
      // Get the dimensions and positions of the divs
      const rect1 = div1.getBoundingClientRect();
      const rect2 = div2.getBoundingClientRect();
  
      // Calculate the center of each div
      const center1 = {
        x: rect1.left + rect1.width / 2,
        y: rect1.top + rect1.height / 2,
      };
  
      const center2 = {
        x: rect2.left + rect2.width / 2,
        y: rect2.top + rect2.height / 2,
      };
  
      // Calculate the distance using the Pythagorean theorem
      const distance = Math.sqrt(Math.pow(center2.x - center1.x, 2) + Math.pow(center2.y - center1.y, 2));
  
      return distance;
    }

    let distanceBetweenSteps = distanceCalculation(timelineSteps[0], timelineSteps[1]);
    const stepPositions = timelineSteps.map((step, index, arr) => {
      return {
        distance: distanceCalculation(arr[0], step),
        step: step,
      }
    });

    {% if section.settings.hide_timeline_last_line %}
      const maxHeight = stepPositions[stepPositions.length - 1].distance;
      timeline.style.setProperty('--timeline-max-height', `${maxHeight}px`);
    {% endif %}

    function flagStep(step) {
      setTimeout(() => {
        step.classList.add('our-process__timeline-item-container--bullet-circle--active');
      }, 200);
    }

    function unflagStep(step) {
      setTimeout(() => {
        step.classList.remove('our-process__timeline-item-container--bullet-circle--active');
      }, 200);
    }

    window.addEventListener('scroll', () => {
      const sectionRect = timeline.getBoundingClientRect();

      // Skip update if section is not visible
      if (sectionRect.bottom < 0 || sectionRect.top > window.innerHeight) {
        return;
      }

      const viewportMiddle = window.innerHeight * 0.4
      const distanceFromMiddle = sectionRect.top - viewportMiddle;
      const sectionHeight = sectionRect.height;

      let newHeight;

      // If we haven't scrolled to the section yet (section is below viewport middle)
      if (distanceFromMiddle > 0) {
        newHeight = 0;
        stepPositions.forEach((step) => {
          unflagStep(step.step);
        });
      }
      // If we've scrolled past the entire section
      else if (distanceFromMiddle <= -sectionHeight) {
        newHeight = sectionHeight;
        stepPositions.forEach((step) => {
          flagStep(step.step);
        });
      }
      // If we're currently scrolling through the section
      else {
        // Calculate progress (0 to 1) based on how far we've scrolled through the section
        const scrollProgress = Math.min(Math.abs(distanceFromMiddle) / sectionHeight, 1);
        // Set timeline height proportional to scroll progress
        newHeight = scrollProgress * sectionHeight;
        stepPositions.forEach((step) => {
          if (step.distance <= newHeight) {
            flagStep(step.step);
          } else {
            unflagStep(step.step);
          }
        });
      }

      {% if section.settings.hide_timeline_last_line %}
        if (newHeight > maxHeight) {
          newHeight = maxHeight;
        }
      {% endif %}

      {% comment %} timeline.style.setProperty('--timeline-line-height', `${newHeight}px`); {% endcomment %}

    });
  });
</script>

{% schema %}

{
  "name": "Our Process Timeline",
  "class": "our-process-timeline",
  "settings": [
    {
      "type": "image_picker",
      "id": "section_image_1",
      "label": "Section Image 1",
    },
    {
      "type": "image_picker",
      "id": "section_image_2",
      "label": "Section Image 2",
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<h2>What to Expect</h2>"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>What to Expect</p>"
    },
    {
      "type": "checkbox",
      "id": "white_version",
      "label": "White Version",
      "default": false,
    },
    {
      "type": "checkbox",
      "id": "show_history_images",
      "label": "Show History Images",
      "default": false,
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#010101"
    },
    {
      "type": "checkbox",
      "id": "show_background_image",
      "label": "Show Background Image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "reduce_title_size",
      "label": "Reduce Title Size",
      "default": false,
    },
    {
      "type": "checkbox",
      "id": "hide_timeline_last_line",
      "label": "Hide Timeline Last Line",
      "default": false,
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL",
      },
  ],
  "blocks": [
    {
      "type": "timeline-item",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<h3>Day 1</h3>"
        },
        {
          "type": "richtext",
          "id": "item_number",
          "label": "Item Number",
          "default": "<p>1</p>"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Subtext",
          "default": "<p>You’ll put it on and get a “Damn, you lift?” even if you don’t.</p>"
        },
        {
          "type": "checkbox",
          "id": "reverse_order",
          "label": "Reverse Order",
          "default": false,
          },
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Process Timeline",
      "blocks": [
        {
          "type": "timeline-item",
          "settings": {
            "reverse_order": false,
            "text": "<h3>Day 1</h3>",
            "subtext": "<p>You’ll put it on and get a “Damn, you lift?” even if you don’t.</p>"
          }
        },
        {
          "type": "timeline-item",
          "settings": {
            "reverse_order": false,
            "text": "<h3>Week 1:</h3>",
            "subtext": "<p>It’s your go-to. No stink. No sag. Compliments incoming.</p>"
          }
        },
        {
          "type": "timeline-item",
          "settings": {
            "reverse_order": false,
            "text": "<h3>Month 1:</h3>",
            "subtext": "<p>You’ve washed it 5x. Still looks brand new. You’ve thrown out 4 cotton shirts.</p>"
          }
        },
        {
          "type": "timeline-item",
