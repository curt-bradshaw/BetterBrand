{{ 'component-rating.css' | asset_url | stylesheet_tag }}

<section
  style="padding-top:0;background: linear-gradient(0deg, rgba(240, 255, 233, 0.81) 0%, rgba(240, 255, 233, 0.70) 23.56%, rgba(255, 255, 255, 0.81) 100%);"
  class="BAD-how-to-use-section trust-section"
>
  <h2 style="color: {{ section.settings.text_color }};" class="BAD-howto-Header">{{ section.settings.heading }}</h2>
  <div class="BAD-how-to-use-container ">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'step' %}
          <div class="BAD-how-to-use-step BAD-how-to-use-step-{{forloop.index}} {% if forloop.first == false %} ntg-desktop-block {% endif %}">
            {% if block.settings.step_image %}
              <img
                src="{{ block.settings.step_image | img_url: 'master' }}"
                alt="{{ block.settings.step_title }}"
                class="BAD-step-image"
              >
            {% endif %}
            <h3 class="BAD-step-title">{{ block.settings.step_title }}</h3>
            
            
            {% if forloop.first == true %}
              <div class="ntg-mobile-block" style="margin: 0 auto;">
                <div class="" style="width: 100%;display: flex;align-items: center;gap: 20px;">
                  {% for block in section.blocks %}
                    {% case block.type %}
                      {% when 'step' %}
                        {% if forloop.first == false %}
                            {% if block.settings.step_image %}
                              <img
                                src="{{ block.settings.step_image | img_url: 'master' }}"
                                alt="{{ block.settings.step_title }}"
                                class="BAD-step-image"
                              >
                            {% endif %}
                        {% endif %}
                    {% endcase %}
                  {% endfor %}
                  </div>
              </div>
            {% endif %}


            <p class="BAD-step-description">{{ block.settings.step_description }}</p>
            {% if block.settings.txt_1 != blank %}
              <div class="img-itms-cont">
                  <div class="img-itms">
                    {% for i in (1..3) %}
                      
                        {% assign image_key = 'image_' | append: forloop.index %}
                        {% assign image = block.settings[image_key] %}

                        {% assign txt_key = 'txt_' | append: forloop.index %}
                        {% assign text = block.settings[txt_key] %}

                        {% assign width_key = 'width_' | append: forloop.index %}
                        {% assign width = block.settings[width_key] %}

                        {% if image != blank %}
                          
                            <div class="image-container">
                              <img 
                                src="{{ image | image_url: width: 400 }}" 
                                alt="Benefit {{ forloop.index }}"
                                width="{{ image.width }}" height="{{ image.height }}"
                                style="width:{{ width }}px"
                                loading="lazy"
                                class="benefit-image"
                              >
                                <p>
                                  {{ text }}
                                </p>
                            </div>
                            
                        {% endif %}
                    {% endfor %} 
                </div> 
              </div>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
  <div class="ntg-video-swiper-section">
    <div class="ntg-container">
      <div class="ntg-heading-holder">
        <h2 class="ntg-h2">{{ section.settings.heading }}</h2>
      </div>
      <div class="ntg-video-swiper-holder ">
        <div class="ntg-video-swiper">
          <div class="swiper-wrapper">
            {% assign n_length = 0 %}
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'select' %}
                  {% assign n_length = n_length | plus: 1 %}
              {% endcase %}
            {% endfor %}

            {% assign n_count = 0 %}
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'select' %}
                  {% assign n_count = n_count | plus: 1 %}
                  <div class="swiper-slide">
                    <div class="ntg-slide-box">
                      <div class="num_vid">{{ n_count }}/{{ n_length }}</div>

                      <div class="review-info">
                        <div class="review-info-txt">
                          {{ block.settings.name }}
                        </div>
                        {% liquid
                          assign rating_decimal = 0
                          assign decimal = block.settings.rate_n | modulo: 1
                          if decimal >= 0.3 and decimal <= 0.7
                            assign rating_decimal = 0.5
                          elsif decimal > 0.7
                            assign rating_decimal = 1
                          endif
                        %}
                        <div
                          class="rating color-{{ section.settings.color_scheme }} gradient"
                          style="background:transparent !important"
                          role="img"
                          aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: block.settings.rate_n, rating_max: 5 }}"
                        >
                          <span
                            aria-hidden="true"
                            class="rating-star"
                            style="--rating: {{ block.settings.rate_n | floor }}; --rating-max: 5; --rating-decimal: {{ rating_decimal }};"
                          ></span>
                          <p class="rating-count caption">
                            <span class="visually-hidden">
                              {{- block.settings.rate_n }}
                              {{ 'accessibility.total_reviews' | t -}}
                            </span>
                          </p>
                        </div>
                      </div>
                      {{
                        block.settings.video
                        | video_tag:
                          class: 'slide-video',
                          image_size: '1000x',
                          autoplay: false,
                          loop: true,
                          muted: false,
                          controls: false,
                          playsinline: true
                      }}
                      <!--
                        <video src="{{ block.settings.video.sources[0].video_source }}" poster="" width="1080" height="1920" autoplay loop muted playsinline></video>
                      -->
                      <div class="video-controls">
                        <button class="play-pause-btn">
                          <svg
                            class="play-icon"
                            width="61"
                            height="61"
                            viewBox="0 0 61 61"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M30.4997 55.9166C44.5369 55.9166 55.9163 44.5372 55.9163 30.4999C55.9163 16.4627 44.5369 5.08325 30.4997 5.08325C16.4624 5.08325 5.08301 16.4627 5.08301 30.4999C5.08301 44.5372 16.4624 55.9166 30.4997 55.9166Z" stroke="#EBFFEE" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M25.4163 20.3333L40.6663 30.4999L25.4163 40.6666V20.3333Z" stroke="#EBFFEE" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                          <svg class="pause-icon" viewBox="0 0 24 24" style="display:none;">
                            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
          {% comment %} <div class="swiper-pagination"></div> {% endcomment %}
          <div class="swiper-nav-vid">
            <div class="swiper-button-prev">
              <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 28.5V7.5L7.5 18L24 28.5Z" fill="#234134"/>
              </svg>
            </div>
            <div class="swiper-button-next">
              <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 28.5V7.5L28.5 18L12 28.5Z" fill="#234134"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
      {% if section.settings.button_label != blank %}
        <div class="center">
          {%- assign  product_custom =  section.settings.product-%}
          {%- assign  button_label =  section.settings.button_label-%}

                  {%- assign product_form_id = 'product-form-' | append: section.id | append:  '-' | append: product_custom.id -%}

                <div class="ntg-cus-add-wrap">
                      <div class="ntg-btn-add">
                        {%- render 'custom-buy-buttons-nynm',
                          button_label: button_label,
                          product: product_custom,
                          product_form_id: product_form_id,
                          section_id: section.id,
                          show_pickup_availability: true
                        -%}
                      </div>
                </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>


<style>
/* Base BAD section */

#shopify-section-{{ section.id }} .trust-section{
    padding-top: 0 !important;
    padding-bottom: 60px !important;
    margin-bottom: 60px;
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .trust-section{
      padding-top: 0 !important;
      padding-bottom: 24px !important;
      margin-bottom: 10px;
  }
}

#shopify-section-{{ section.id }} .BAD-how-to-use-section {
  padding: 60px 0;
  text-align: center;
}

#shopify-section-{{ section.id }} .BAD-how-to-use-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
  margin-top: 0;
}

#shopify-section-{{ section.id }} .BAD-howto-Header {
  color: var(--Bottle-Green, #234134);
  text-align: center;
  font-family: bookmania;
  font-size: 27px;
  font-style: normal;
  font-weight: 700;
  line-height: 23.406px; /* 93.622% */
}

#shopify-section-{{ section.id }} .BAD-how-to-use-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

#shopify-section-{{ section.id }} .BAD-step-image {
  width: auto;
  height: auto;
  margin-bottom: 10px;
  border-radius: 0;
  border: 1px solid var(--Bottle-Green, #234134);
}

#shopify-section-{{ section.id }} .BAD-step-title {
  font-size: 18px;
  font-weight: bold;
}

#shopify-section-{{ section.id }} .BAD-step-description {
  font-size: 14px;
  font-weight: 600;
}


@media (min-width: 1024px) {
  #shopify-section-{{ section.id }} .ntg-video-swiper-section {
    padding: 0;
  }
}

/* Mobile BAD section tweaks */
@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .ntg-video-swiper-section {
    padding: 0;
  }

  #shopify-section-{{ section.id }} .BAD-step-title {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .BAD-how-to-use-section {
    padding: 20px;
  }

  #shopify-section-{{ section.id }} .BAD-how-to-use-container {
    flex-direction: column;
    align-items: center;
    gap: 20px 0;
  }

  #shopify-section-{{ section.id }} .BAD-howto-Header {
    font-size: 20px;
  }
}

/* Section wrapper background */
#shopify-section-{{ section.id }} {
  background: transparent;
}

/* Heading */
#shopify-section-{{ section.id }} .ntg-heading-holder h2 {
  font-family: 'GrotesqueMT';
  font-weight: 400;
  font-style: Condensed;
  font-size: 38px;
  leading-trim: NONE;
  line-height: 100%;
  letter-spacing: 0%;
  text-align: center;
}

/* Review info */
#shopify-section-{{ section.id }} .review-info-txt {
  color: white;
  text-align: center;
}

#shopify-section-{{ section.id }} .rating-star {
  --letter-spacing: 0.7;
  --font-size: 2.4;
}

#shopify-section-{{ section.id }} .review-info {
  position: absolute;
  z-index: 7;
  bottom: 20px;
  left: 50%;
  transform: translate(-50%, 0);
}

/* Video controls */
#shopify-section-{{ section.id }} .video-controls {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 6;
  filter: drop-shadow(3px 3px 14px rgba(0, 0, 0, 0.72));
  border-radius: 14px;
}

/* Swiper arrows */
#shopify-section-{{ section.id }} .swiper-button-prev:after,
#shopify-section-{{ section.id }} .swiper-button-next:after {
  display: none;
}

#shopify-section-{{ section.id }} .swiper-button-prev,
#shopify-section-{{ section.id }} .swiper-button-next {
  width: max-content;
  z-index: 2;
}

#shopify-section-{{ section.id }} .swiper-button-prev {
  left: -44px;
}

#shopify-section-{{ section.id }} .swiper-button-next {
  right: -44px;
}

/* Play / pause button */
#shopify-section-{{ section.id }} .play-pause-btn {
  border: none;
  color: #fff;
  cursor: pointer;
  transition: all .3s ease;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  background: transparent;
  pointer-events: none;
}

#shopify-section-{{ section.id }} .play-pause-btn:hover {
  transform: scale(1.1);
}

#shopify-section-{{ section.id }} .play-pause-btn.playing {
  display: none;
}

#shopify-section-{{ section.id }} .play-pause-btn.playing .pause-icon {
  display: block;
}

#shopify-section-{{ section.id }} .play-pause-btn:not(.playing) .play-icon {
  display: block;
}

#shopify-section-{{ section.id }} .play-pause-btn:not(.playing) .pause-icon {
  display: none;
}

/* Swiper slides */
#shopify-section-{{ section.id }} .swiper-slide:not(.swiper-slide-active):not(.swiper-slide-prev):not(.swiper-slide-next) {
  transform: scale(0.9);
  filter: brightness(0.5);
  z-index: 0;
}

#shopify-section-{{ section.id }} .swiper-slide {
  opacity: 0.7;
  transform: scale(1.1);
  z-index: 1;
  filter: brightness(0.7);
  transition: all 0.5s ease-in-out;
}

#shopify-section-{{ section.id }} .swiper-slide.swiper-slide-active {
  transform: scale(1.2) !important;
  z-index: 10;
  opacity: 1 !important;
  {% comment %} filter: drop-shadow(3px 3px 3px rgba(157, 157, 157, 0.72)); {% endcomment %}
  border-radius: 60px;
  background: transparent;
}

#shopify-section-{{ section.id }} .swiper-slide.swiper-slide-active .play-pause-btn {
  pointer-events: all;
}

/* Desktop swiper spacing */
@media (min-width: 768px) {
  #shopify-section-{{ section.id }} .swiper-wrapper {
    padding-left: 25px;
  }

  #shopify-section-{{ section.id }} .swiper-slide.swiper-slide-prev {
    margin-left: -25px !important;
  }

  #shopify-section-{{ section.id }} .swiper-slide.swiper-slide-next {
    margin-right: -1px !important;
  }
}

/* CTA button */
#shopify-section-{{ section.id }} .ntg-video-btn {
  background: #234134;
  box-shadow: 5px 4px 10px rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(11px);
  border-radius: 82px;
  font-family: Suisse_Intl_Mono;
  font-weight: 700;
  font-style: Bold;
  font-size: 17px;
  leading-trim: NONE;
  line-height: 100%;
  letter-spacing: 0%;
  color: #F2CB49;
  padding: 20px;
}

#shopify-section-{{ section.id }} .ntg-video-btn:after,
#shopify-section-{{ section.id }} .ntg-video-btn:before {
  display: none;
}

/* Trust section colors */
#shopify-section-{{ section.id }} .trust-section h1,
#shopify-section-{{ section.id }} .trust-section h2,
#shopify-section-{{ section.id }} .trust-section h3 {
  color: #234134 !important;
}

#shopify-section-{{ section.id }} .trust-section p {
  color: #234134 !important;
}

/* Trust section layout */
#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-container {
  justify-content: space-between;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-container .BAD-how-to-use-step {
  justify-content: center;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step {
  justify-content: flex-start;
  align-items: flex-start;
  text-align: left;
  position: relative;
  flex: 0 0 calc(50% - 10px); /* 20px gap / 2 items = 10px */
  max-width: calc(50% - 10px);
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 h3 {
  color: var(--Color, #234134);
  font-family: Inter;
  font-size: 30px;
  font-style: normal;
  font-weight: 700;
  line-height: normal;
  position: relative;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 h3::before {
  position: absolute;
  content: "";
  width: 70px;
  height: 4px;
  left: 0;
  bottom: -20px;
  background: #F2CB49;
}

#shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 .BAD-step-description {
  
  max-width: 500px;
  color: var(--Color, #234134);
  text-align: center;
  font-family: Inter;
  font-size: 30px;
  font-style: normal;
  font-weight: 500;
  line-height: 23px; /* 76.667% */
}

#shopify-section-{{ section.id }} .trust-section .BAD-step-image {
  border: none;
  margin: 0;
}

/* Desktop BAD container padding */
@media (min-width: 768px) {
  #shopify-section-{{ section.id }} .BAD-how-to-use-container {
    padding: 0 70px;
  }
}

/* Mobile trust section adjustments */
@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .trust-section h3::before {
    left: 50% !important;
    transform: translate(-50%, 0);
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 .BAD-step-description {
    margin: 20px auto 0 !important;
    text-align: center;
    color: var(--Color, #234134);
    text-align: center;
    font-family: Inter;
    font-size: 17px !important;
    font-style: normal;
    font-weight: 600;
    line-height: 23px; /* 135.294% */
  }

  #shopify-section-{{ section.id }} .trust-section {
    padding: 0;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-container {
    flex-direction: row;
    padding-left: 0;
    justify-content: space-evenly;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 {
    padding-left: 0;
    flex: 0 0 100%;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1 h3 {
    font-size: 20px;
  }

  #shopify-section-{{ section.id }} .trust-section .BAD-how-to-use-step.BAD-how-to-use-step-1::before {
    left: -8px;
    width: 12px;
  }

  
}
</style>


{% schema %}
{
  "name": "Trust Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How To Use"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F0FAEB"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step Image"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "Step description text goes here."
        },
        {
          "type": "text",
          "id": "txt_1",
          "label": "text 1",
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "range",
          "id": "width_1",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "width",
          "default": 36
        },
        {
          "type": "text",
          "id": "txt_2",
          "label": "text 2",
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "range",
          "id": "width_2",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "width",
          "default": 36
        },
        {
          "type": "text",
          "id": "txt_3",
          "label": "text 3",
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        },
        {
          "type": "range",
          "id": "width_3",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "width",
          "default": 36
        }
      
      ]
    },
    {
      "type": "select",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name"
        },
        {
          "type": "range",
          "id": "rate_n",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "unit": "rt",
          "label": "stars"
        },
        {
          "type": "video",
          "id": "video",
          "label": "A Shopify-hosted video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Section",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}
{% endschema %}
