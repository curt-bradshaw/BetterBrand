<!-- START new-our-story.liquid -->

<section class="our-story-section" {{ section.shopify_attributes }}>
  {% if section.settings.image or section.settings.heading or section.settings.text %}
    <div class="our-story__inner">
      <figure class="our-story__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | img_url: '800x' }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
          >
        {% endif %}
      </figure>

      <div class="our-story__content">
        <h2 class="our-story__heading">{{ section.settings.heading }}</h2>
        <div class="our-story__text">
          {{ section.settings.text }}
        </div>
        {% comment %} {% if section.settings.link_text != blank %}
          <a class="our-story__link" href="{{ section.settings.link_url }}">{{ section.settings.link_text }}</a>
        {% endif %} {% endcomment %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Our story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Story" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lorem ipsum dolor sit amet.\nRisus neque vitae dignissim tellus. Fusce rhoncus lectus nibh sagittis et quis.</p>"
    },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Learn More" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    {
      "type": "header",
      "content": "Padding Settings"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Tablet)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Tablet)",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 20
    }
  ],
  "presets": [{ "name": "Our story", "category": "Image & text" }]
}
{% endschema %}

{% style %}
  .our-story-section {
    padding: {{ section.settings.padding_top_desktop }}px 20px {{ section.settings.padding_bottom_desktop }}px;
  }

  .our-story-section .our-story__inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 108px;
    align-items: center;
  }

  .our-story-section .our-story__media {
    margin: 0;
    min-width: 512px;
  }

  .our-story-section .our-story__media img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    object-fit: cover;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  }

  .our-story-section .our-story__content {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .our-story-section .our-story__heading {
    margin: 0;
    font-size: 38px;
    line-height: 1.2;
    font-weight: 700;
    color: #252525;
    text-align: center;
    font-family: Bookmania, serif;
  }

  .our-story-section .our-story__text p {
    color: #555555;
    font-size: 20px;
    line-height: 1.2;
  }

  .our-story-section .our-story__link {
    display: inline-block;
    margin-top: 6px;
    text-decoration: underline;
    font-size: 20px;
    color: #555555;
    {% if template == 'product' %}display: none{% endif %}
  }


  @media (max-width: 1279px) {
    .our-story-section .our-story__media {
      min-width: 480px;
    }

    .our-story-section .our-story__inner {
      gap: 40px;
    }
  }

  @media (max-width: 1019px) {
    .our-story-section {
      padding: {{ section.settings.padding_top_tablet }}px 20px {{ section.settings.padding_bottom_tablet }}px;
    }
    .our-story-section .our-story__heading {
      font-size: 32px;
    }
    .our-story-section .our-story__text p {
      font-size: 18px;
    }
    .our-story-section .our-story__link {
      font-size: 18px;
    }
    .our-story-section .our-story__inner {
      display: flex;
      flex-direction: column-reverse;
      gap: 20px;
    }
  }

  @media (max-width: 767px) {
    .our-story-section {
      padding: {{ section.settings.padding_top_mobile }}px 20px {{ section.settings.padding_bottom_mobile }}px;
    }
    .our-story-section .our-story__heading {
      font-size: 24px;
    }
    .our-story-section .our-story__media {
      min-width: 100%;
    }
    .our-story-section .our-story__text p {
      font-size: 16px;
    }
    .our-story-section .our-story__link {
      font-size: 16px;
    }
  }
{% endstyle %}
