        <ul class="ntg-menu">
          {%- for link in section.settings.menu.links -%}
            {%- if link.links != blank -%}
              <li class="ntg-drill-down">
                  <a role="button" aria-label="Perform action" tabindex="0" href="#">{{ link.title }}</a>
                  <ul class="ntg-drill-down-menu">
                      <li class="ntg-drill-down-back">
                          <button>{{ link.title }}</button>
                      </li>
                      {%- for childlink in link.links -%}
                        {%- if childlink.links != blank -%}
                          <li class="ntg-drill-down">
                              <a href="#">
                                {% if childlink.object.featured_image != blank %}
                                  <span class="ntg-img"><img src="{{ childlink.object.featured_image | img_url: '350x350' | crop: 'center' }}" alt="" width="65" height="65"></span>
                                {% endif %}
                                  <span class="ntg-text">{{ childlink.title }}</span>
                              </a>
                              <ul class="ntg-drill-down-menu">
                                  <li class="ntg-drill-down-back">
                                      <a href="#">{{ childlink.title }}</a>
                                  </li>
                                  {%- for grandchildlink in childlink.links -%}
                                  <li><a href="{{ grandchildlink.url }}"><span class="ntg-text">{{ grandchildlink.title }}</span></a></li>
                                  {% endfor %}
                              </ul>
                          </li>
                        {% else %}
                          <li>
                            <a href="{{ childlink.url }}">
                                {% if childlink.object.featured_image != blank %}
                                  <span class="ntg-img"><img src="{{ childlink.object.featured_image | img_url: '350x350' | crop: 'center' }}" alt="" width="65" height="65"></span>
                                {% endif %}
                                <span class="ntg-text">{{ childlink.title }}</span>
                            </a>
                          </li>
                        {% endif %}
                      {% endfor %}
                  </ul>
              </li>
            {% else %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
    </div>
    <div class="ntg-drop-bottom">
        <img src="{{ 'header-logos.svg' | asset_url }}" alt="logos" width="253" height="50">
    </div>
</div>

