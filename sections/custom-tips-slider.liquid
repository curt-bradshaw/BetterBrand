<div class="ntg-tips-section">
    <div class="ntg-container">
        <div class="ntg-heading-holder">
            <h2 class="ntg-h2">{{ section.settings.heading }}</h2>
        </div>
        <div class="ntg-tips-swiper-holder">
            <div class="ntg-tips-swiper">
                <div class="swiper-wrapper">
                  {% for block in section.blocks %}
                    <div class="swiper-slide">
                        <div class="ntg-swiper-box">
                            <div class="ntg-img-holder">
                                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
                            </div>
                            <div class="ntg-text-holder">
                                <div class="ntg-title">{{ block.settings.title }}</div>
                                {{ block.settings.text }}
                            </div>
                        </div>
                    </div>
                  {% endfor %}
                </div>
                <div class="swiper-pagination"></div>
                <div class="swiper-nav">
                    <div class="swiper-button-prev">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14.8">
                            <path d="M19.8 6.8c-.1-.1-.3-.2-.6-.2H2.7L8 1.3c.1-.1.2-.3.2-.5S8.1.4 8 .2C7.8.1 7.6 0 7.4 0c-.2 0-.4.1-.6.2L.2 6.8c-.1.2-.2.4-.2.6 0 .1 0 .2.1.3 0 .1.1.2.2.3l6.6 6.6c.1.1.2.1.3.2.1 0 .2.1.3.1.2 0 .3 0 .4-.1.1-.1.2-.2.3-.4.1-.1.1-.3 0-.5 0-.2-.1-.3-.2-.4L2.7 8.2h16.6c.2 0 .4-.1.6-.2 0-.2.1-.4.1-.6s-.1-.4-.2-.6z" fill="#231f20"/>
                        </svg>
                    </div>
                    <div class="swiper-button-next">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14.8">
                            <path d="M20 7.4c0-.2-.1-.4-.2-.6L13.2.2c-.2-.1-.4-.2-.6-.2-.2 0-.4.1-.6.2-.1.1-.2.3-.2.6 0 .2.1.4.2.6l5.3 5.3H.8c-.2 0-.4.1-.6.2-.1.1-.2.3-.2.5s.1.4.2.6c.1.1.3.2.6.2h16.6l-5.3 5.3c-.1.1-.2.2-.2.4v.5c.1.1.2.3.3.4.1.1.3.1.4.1.1 0 .2 0 .3-.1.1 0 .2-.1.3-.2L19.8 8c.1-.2.2-.4.2-.6z" fill="#231f20"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Custom Tips Slider",
  "class": "custom-tips-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quick Tips for Healthier Lungs"
    }
  ],
  "blocks": [
    {
      "type": "select",
      "name": "block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Tips Slider",
      "category": "Custom Sections",
      "blocks": [
        { 
          "type": "select"
        },
        {
          "type": "select"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}