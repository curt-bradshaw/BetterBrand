      }

      .collection-page__loading-more-wrapper {
        text-align: center;
        margin-top: 20px;
        width: 100%;
      }

      {% comment %} .loading-more__progress-wrapper {
        display: block;
        margin: 12px auto 19px;
        width: 106px;
        height: 37px;
      } {% endcomment %}

      .collection-page__loading-more {
        font-size: 16px;
      }
    }

     @media (max-width: 790px) {
      .grid-uniform--st2 .product-card__grid-item {
