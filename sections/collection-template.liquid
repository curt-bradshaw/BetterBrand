    /* Soft Banner Styles */
    .soft-banner {
      display: flex !important;
      align-items: center;
      justify-content: center;
    }

    .soft-banner__content {
      height: 100%;
      display: flex !important;
      flex-direction: column;
    }

    .soft-banner .soft-banner__content {
      padding: 15px 20px !important;
      min-height: 200px;
      justify-content: center;

    }

    .soft-banner__text {
      font-size: 38px !important;
      font-weight: 750 !important;
      margin-bottom: 0px !important;
      font-family: Bookmania, serif;
      line-height: 1.2 !important;
    }

    .soft-banner__subtext {
      font-size: 38px !important;
      line-height: 1.2 !important;
      font-weight: 750 !important;
      font-family: Bookmania, serif;
    }

    .soft-banner__button {
      margin-top: 15px !important;
      min-width: 120px;
    }

    /* Responsive adjustments */
    @media (max-width: 1019px) {
      .soft-banner .soft-banner__content {
        padding: 12px 15px !important;
        min-height: 180px;
      }
      
      .soft-banner__text {
        font-size: 44px !important;
      }
      
      .soft-banner__subtext {
        font-size: 44px !important;
      }
      
      .soft-banner__button {
        padding: 8px 16px !important;
        font-size: 13px !important;
        min-width: 110px;
      }
    }

    @media (max-width: 767px) {
      .soft-banner .soft-banner__content {
        padding: 10px 12px !important;
        min-height: 160px;
      }
      
      .soft-banner__text {
        font-size: 22px !important;
        margin-bottom: 8px !important;
      }
      
      .soft-banner__subtext {
        font-size: 22px !important;
        margin-bottom: 12px !important;
      }
      
      .soft-banner__button {
        padding: 6px 12px !important;
        font-size: 12px !important;
        min-width: 100px;
        margin-top: 10px !important;
      }
    }

    /* Ajustes específicos para diferentes layouts de grid */
    .grid-uniform--s2 .soft-banner,
    .grid-uniform--st2 .soft-banner,
    .grid-uniform--sm2 .soft-banner {
      aspect-ratio: 1/1.4;
    }

    .grid-uniform--s3 .soft-banner,
    .grid-uniform--st3 .soft-banner,
    .grid-uniform--sm3 .soft-banner {
      aspect-ratio: 1/1.4;
    }

    .grid-uniform--s4 .soft-banner,
    .grid-uniform--st4 .soft-banner,
    .grid-uniform--sm4 .soft-banner {
      aspect-ratio: 1/1.4;
    }

    /* Garantir que o banner respeite o mesmo padding interno dos cards */
    .collection-page__grid-products .soft-banner .product-card__product-info {
      padding: 20px !important;
    }

    @media (max-width: 1019px) {
      .collection-page__grid-products .soft-banner .product-card__product-info {
        padding: 15px !important;
      }
    }

    @media (max-width: 767px) {
      .collection-page__grid-products .soft-banner .product-card__product-info {
        padding: 12px !important;
      }
    }
  </style>
{%- endcapture -%}

{{- collection_template_css | strip_newlines | replace: '    ', ' ' | replace: '   ', ' ' | replace: '  ', ' ' -}}

{%- assign items_per_row = settings.products_per_row -%}
{%- assign grid_uniform_class_desktop = 'grid-uniform--s' | append: items_per_row -%}
{%- assign grid_uniform_class_tablet = 'grid-uniform--st' | append: settings.products_per_rows_collection_tablet -%}
{%- assign grid_uniform_class_mobile = 'grid-uniform--sm' | append: settings.products_per_rows_collection_mobile -%}

<div class="collection-template-wrapper">
  {%- if settings.breadcrumb_position == 'above' and settings.enable_breadcrumbs -%}
    <div class="collection-page__breadcrumb-wrapper wrapper">
      {%- render 'breadcrumb' -%}
    </div>
  {% endif %}

  {%- render 'collection-banner' -%}

  {%- if settings.breadcrumb_position == 'below' and settings.enable_breadcrumbs -%}
    <div class="collection-page__breadcrumb-wrapper wrapper">
      {%- render 'breadcrumb' -%}

      <div class="collection__filter-icon-wrapper">
        {%- if settings.enable_qtd_product -%}
          {%- render 'breadcrumb-product-count' -%}
        {%- endif -%}
      </div>

      <div class="collection-filter__wrapper">
        {%- render 'collection-filter' -%}
        {%- render 'collection-filter-icon' -%}
      </div>
    </div>
  {%- endif -%}

  <div class="collection-facets__overlay"></div>

  <div class="collection-page__wrapper wrapper">
    {% if settings.filter_collection == 'sidebar' %}
      <div class="collection-page__filter-wrapper">
        {%- render 'collection-facets' -%}
      </div>
    {% endif %}

    <div class="collection-page__content">
      {% render 'collection-items',
        enable_soft_banner_param: section.settings.enable_soft_banner,
        banner_position_param: section.settings.banner_position,
        banner_text_param: section.settings.banner_text,
        banner_subtext_param: section.settings.banner_subtext,
        button_text_param: section.settings.button_text,
        button_link_param: section.settings.button_link
      %}
    </div>
  </div>
</div>
{% if collection.products.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ collection.title | json }},
  "description": {{ collection.description | strip_html | json }},
  "url": "{{ shop.url }}{{ collection.url }}",
  "numberOfItems": {{ collection.products.size }},
  "itemListElement": [
    {% for product in collection.products limit: 20 %}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "url": "{{ shop.url }}{{ product.url }}",
        "name": {{ product.title | json }},
        "image": "https:{{ product.featured_image | image_url: width: 800 }}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
{% endif %}
