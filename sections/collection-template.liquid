      .grid-uniform--st2 .soft-banner {
        flex: 1 1 calc(50% - 3%);
        min-width: calc(50% - 1.9%);
        max-width: calc(50% - 3%);
      }
      }

       @media (max-width: 875px) {
        .grid-uniform--st2 .product-card__grid-item {
        flex: 1 1 calc(50% - 3%);
        min-width: calc(50% - 2%);
        max-width: calc(50% - 3%);
      }

      .grid-uniform--st2 .soft-banner {
