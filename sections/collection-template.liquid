<!-- sections/collection-template -->
{%- capture collection_template_css -%}
  {%- comment -%} Start Shopify Id Styles {%- endcomment -%}
  <style>
    #shopify-section-{{ section.id }} {
      background-color: {{ section.settings.section_background_color }};
    }
    
    #shopify-section-{{ section.id }} .titles {
      position: absolute;
      width: {{ section.settings.width_titles }}%;
      left:{{ section.settings.titles_position_hor }}%;
      top:{{ section.settings.titles_position_ver }}%
    }
    
    #shopify-section-{{ section.id }} .collection-description__text {
      text-align: {{ settings.announcement_description_position }};
      color: {{ settings.description_color }};
    }
    
    #shopify-section-{{ section.id }} .collection-description__text.see-more.see-more:not(.collection-description__text--opened) {
      max-height: {{ settings.description_size }}px;
    }

    #shopify-section-{{ section.id }} .collection-description__button {
      color: {{ settings.desc_seemore-color }};
    }

    #shopify-section-{{ section.id }} .grid__item-price {
      font-size: {{ settings.collection_product_price_font_size | plus: 0.0 | divided_by: 16 }}rem;
    }
        
    #shopify-section-{{ section.id }} .product-card__item-title {
      font-size: {{ section.settings.product_card_title_font_size_desktop }}px;
    }

    @media (max-width:1019px) {    
      #shopify-section-{{ section.id }} .product-card__item-title {
        font-size: {{ section.settings.product_card_title_font_size_tablet }}px;
      }
    }
    @media (max-width:767px) {
      #shopify-section-{{ section.id }} .product-card__item-title {
        font-size: {{ section.settings.product_card_title_font_size_mobile }}px;
        
      }
    }
  </style>
  {%- comment -%} End Shopify Id Styles {%- endcomment -%}

  <style>
    .collection-page__breadcrumb-wrapper {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 5px;
      margin: 34px auto 10px;
      padding: 0 23px 0 23px;
    }

    .collection-page__breadcrumb-wrapper .breadcrumbs {
      margin-bottom: 0;
    }

    {% if settings.filter_collection == "sidebar" %}
      .collection-page__breadcrumb-wrapper .breadcrumbs {
        width: 22%;
        display: flex;
        align-items: center;
      }
    {% endif %}

    .collection-page__breadcrumb-wrapper .breadcrumbs__item {
      line-height: 1.1;
      font-weight: 400;
    }

    {% comment %} .template-collection .breadcrumbs__separator {
      margin-left: 4px;
      margin-right: 4px;
    } {% endcomment %}

    .collection-page__breadcrumb-wrapper .breadcrumbs__separator svg {
      width: 12px;
    }

    .collection-filter__wrapper {
      display: flex;
      justify-content: flex-end;
      padding-right: 3px;
      {% if settings.filter_collection == "sidebar" %}
        flex: 1;
      {% endif %}
    }

    {% if settings.filter_collection == "dropdown" %}
      .collection-filter__wrapper .content-collection {
        width: 100%;
      }
    {% endif %}

    .products-not-found{
      margin: 0 auto;
    }

    .collection-page__loading-more-wrapper {
      text-align: center;
      width: 100%;
      color: #FFF;
    }

    .collection-page__loading-more {
      width: 158px;
      height: 44px;
      color: #234134;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #234134;
      padding: 6.5px 10px 6.5px 6px;
      border-radius: 40px;
    }    

    .collection-page__loading-more:hover {
      background: var(--color-secondary-buttons-hover);
      color: var(--color-secondary-buttons-text-hover);
    }

    .loading-more__progress-wrapper {
      width: 100%;
      justify-content: center;
      display: flex;
      margin-top: 10px;
    }

    .loading-more__progress-label {
      margin-bottom: 5px;
    }

    .loading-more__progress-bar {
      display: none;
      width: 100%;
      height: 4px;
      background-color: #eee;
      position: relative;
      margin-bottom: 10px;
    }

    .loading-more__progress-bar-fill {
      display: block;
      height: 100%;
      background-color: #000;
      position: absolute;
      top: 0;
      left: 0;
    }

    .collection-facets--opened {
      overflow: hidden;
    }

    .collection-page__wrapper > div:not(.collection-page__filter-wrapper):not(.collection-page__content) {
      display: none;
    }

    .collection-page__wrapper {
      padding: 20px 0;
    }

    .collection-page__filter-wrapper {
      width: 18%;
      margin-left: 2px;
    }
    
    .collection-page__content {
      width: 77%;
      margin-right: 6px;
    }

    .collection-filter__item-label {
      font-size: var(--breadcrumbFontSize, 1rem);
      color: #252525;
      margin-right: 10px;
    }

    .collection-filter__dropdown {
      width: 247px;
      height: 47px;
      margin: 0 2px 0 0;
      padding: 0 17px;
      letter-spacing: 0.2px;
      font-size: var(--breadcrumbFontSize, 1rem);
      appearance: none;
      -webkit-appearance: none;
      background-color: transparent;
      background-image: url("{{ 'icon-arrow-down.svg' | asset_url }}");
      background-size: 8px;
      background-position: 94% 54%;
      background-repeat: no-repeat;
      border-radius: 4px;
      border: 1px solid #5B734E;
      color: #5B734E;
      cursor: pointer;
    }

    .collection-filter__dropdown option:hover {
      cursor: pointer;
    }

    .collection__filter-icon-wrapper {
      display: flex;
      align-items: center;
      gap: 30px;
    }

    .spinner-widget {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 30px 0;
      margin: 0 auto;
      width: 100%;
    }

    .spinner-widget__spinner {
      display: block;
      width: 50px;
      height: 50px;
      border: 3px solid #eee;
      border-bottom-color: transparent;
      border-radius: 100%;
      margin-bottom: 5px;
      animation: linear 0.45s 0s infinite spinner;
    }

    .spinner-widget__text {
      text-transform: uppercase;
    }

    @keyframes spinner {
      0% {
        transform: rotate(0deg);
      }

      100% {
        transform: rotate(360deg);
      }
    }

    /* product grid */

    .collection-page__wrapper,
    .collection-page__grid-products {
      display: flex;
    }

    .collection-page__wrapper {
      padding: 24px 20px 20px 23px;
      justify-content: space-between;
    }

    .collection-page__grid-products {
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 25px; 
    }

    .collection-page__grid-products .product-card__grid-item {
      flex: 1 1 calc(25% - 2%); 
      min-width: calc(25% - 2%);
      max-width: calc(25% - 2%);
      transition: all 0.3s ease;
    }

    .grid-uniform--s3 .product-card__grid-item {
      flex: 1 1 calc(33.333% - 1.8%);
      min-width: calc(33.333% - 1.8%);
      max-width: calc(33.333% - 1.8%);
    }

    .grid-uniform--s2 .product-card__grid-item {
      flex: 1 1 calc(50% - 25px);
      min-width: calc(50% - 227px);
      max-width: calc(50% - 168px);
    }

    .collection-page__grid-products .soft-banner {
      flex: 1 1 calc(25% - 2%);
      min-width: calc(25% - 2%);
      max-width: calc(25% - 2%);
    }

    .grid-uniform--s3 .soft-banner {
      flex: 1 1 calc(33.333% - 1.8%);
      min-width: calc(33.333% - 1.8%);
      max-width: calc(33.333% - 1.8%);
    }

    .grid-uniform--s2 .soft-banner {
      flex: 1 1 calc(50% - 25px);
      min-width: calc(50% - 227px);
      max-width: calc(50% - 168px);
    }

    @media (max-width: 1300px) {
      {% comment %} .collection-page__grid-products .product-card__grid-item {
        flex: 1 1 calc(25% - 2%);
        min-width: calc(20% - 2%);
        max-width: calc(33% - 1.9%);
      } {% endcomment %}
      
      .grid-uniform--s3 .product-card__grid-item {
        flex: 1 1 calc(33.333% - 1.8%);
        min-width: calc(33.333% - 1.8%);
        max-width: calc(33.333% - 1.8%);
      }
      
      {% comment %} .grid-uniform--s2 .product-card__grid-item {
        flex: 1 1 calc(50% - 25px);
        min-width: calc(50% - 25px);
        max-width: calc(50% - 25px);
      } {% endcomment %}
    }

    @media (max-width: 1200px) {
      .collection-page__grid-products {
        gap: 25px;
      }
      
      .collection-page__grid-products .product-card__grid-item {
        flex: 1 1 calc(25% - 1.8%);
        min-width: calc(33% - 2%);
      }
    }

    @media (max-width: 1100px) {
      
      {% comment %} .collection-page__grid-products .product-card__grid-item {
        flex: 1 1 calc(25% - 1.5%);
        min-width: calc(25% - 1.5%);
      } {% endcomment %}
      
      .grid-uniform--s3 .product-card__grid-item {
        flex: 1 1 calc(33.333% - 1.5%);
        min-width: calc(33.333% - 1.5%);
        max-width: calc(33.333% - 1.5%);
      }
    }

    .collection-page__grid-products + .collection-page__grid-products {
      margin-top: 30px;
    }

    .collection-page__grid-products .product-card__grid-item-fullsize {
      background-color: #F0FFE9A3;
    }

    .collection-page__grid-products .product-card__item-title-wrapper .product-card__item-title {
      margin-top: 13px;
      padding: 0 13px;
    }

    .collection-page__grid-products .product-card__item-price {
      font-size: {{ settings.collection_product_price_font_size }}px;
      font-weight: 700;
      font-family: 'SuisseIntlMono', sans-serif;
      line-height: 1.2;
    }

    .collection-page__grid-products .product-card__item-title {
      padding: 0 ;
      margin: 0;
    }

    .collection-page__grid-products .product-card__item-price-wrapper {
      margin: 0;
      padding: 0 ;
      display: flex;
      align-items: center;
    }

    .collection-page__grid-products .product-card__reviews {
      display: flex;
      align-items: flex-start;
      gap: 4.5px;
      padding: 0 10px;
      margin: 0;
      font-size: 12px;
      flex-direction: column;
    }

    .collection-page__grid-products .product-card__reviews svg {
      width: 40.8%;
      height: auto;
    }

    .collection-page__grid-products .product-card__reviews svg path {
      fill: {{ section.settings.review_stars_color }};
    }

    body .collection-banner .collection-page__title {
      font-size: 30px;
    }

    .collection-description__text,
    .collection-description__text * {
      font-size: 18px;
    }

    .collection-template-wrapper .product-card__grid-item-image-wrapper {
      padding-top: 109%;
      border-radius: 0;
    }

    @media (max-width: 1019px) {
      .collection-page__breadcrumb-wrapper {
        margin: 44px auto 10px;
        padding: 0 22px;
      }

      .collection-page__breadcrumb-wrapper .breadcrumbs {
        width: auto;
        display: flex;
        align-items: center;
        gap: 3px;
      }

      .collection-page__breadcrumb-wrapper .breadcrumbs__item {
        padding-left: 0px;
      }

      .collection-page__wrapper{    
        padding: 20px 20px;
      } 

      .products-amount-span{
        font-size: 12px;
        margin-right: 20px;
      }


      .collection-page__grid-products {
        gap: 30px; 
      }
      
      .grid-uniform--st2 .product-card__grid-item {
        flex: 1 1 calc(50% - 3%);
        min-width: calc(50% - 1.6%);
        max-width: calc(50% - 3%);
      }
      
      .grid-uniform--st3 .product-card__grid-item {
        flex: 1 1 calc(33.333% - 1.5%);
        min-width: calc(33.333% - 1.5%);
        max-width: calc(33.333% - 1.5%);
      }
      
      /* Soft Banner tablet */
      .grid-uniform--st2 .soft-banner {
        flex: 1 1 calc(50% - 3%);
        min-width: calc(50% - 1.6%);
        max-width: calc(50% - 3%);
      }
      
      .grid-uniform--st3 .soft-banner {
        flex: 1 1 calc(33.333% - 1.5%);
        min-width: calc(33.333% - 1.5%);
        max-width: calc(33.333% - 1.5%);
      }

      @media (max-width: 980px) {
        
        .grid-uniform--st3 .product-card__grid-item {
          flex: 1 1 calc(33.333% - 2.5%);
          min-width: calc(33.333% - 2.5%);
          max-width: calc(33.333% - 2.5%);
        }

        .grid-uniform--st2 .product-card__grid-item {
        flex: 1 1 calc(50% - 3%);
