<script>
  // ── Progress bar + sticky CTA ──────────────────────────────────────────────
  (function () {
    var fill = document.getElementById('arp-progress-fill');
    var cta  = document.getElementById('arp-sticky-cta');
    var hero = document.getElementById('arp-hero');

    function onScroll() {
      var docH = document.documentElement.scrollHeight - window.innerHeight;
      if (docH > 0 && fill) fill.style.width = (window.scrollY / docH * 100) + '%';

      if (hero && cta) {
        var heroBottom = hero.getBoundingClientRect().bottom;
        if (heroBottom < 0) {
          cta.classList.add('arp-visible');
        } else {
          cta.classList.remove('arp-visible');
        }
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  })();

  // ── Kill Just Uno / Klaviyo / third-party popups ─────────────────────────
  (function killPopups() {
    function removePopups() {
      // Just Uno: outer wrapper div with iswrapper="true" and justunologo attr
      document.querySelectorAll('[iswrapper="true"]').forEach(function(el) { el.remove(); });
      document.querySelectorAll('[justunologo]').forEach(function(el) { el.remove(); });
      // Just Uno by id pattern
      document.querySelectorAll('[id="inob"], [id^="ju-"], [class*="justuno"]').forEach(function(el) { el.remove(); });
      // Klaviyo forms
      document.querySelectorAll('klaviyo-onsite-component, [class*="klaviyo-form"], [class*="kl-private"]').forEach(function(el) { el.remove(); });
      // Any fixed/absolute overlay covering the page (backdrop)
      document.querySelectorAll('body > div[style*="position: fixed"][style*="background"]').forEach(function(el) {
        if (!el.id || !el.id.startsWith('arp-')) el.remove();
      });
    }

    // Run immediately and after DOM is ready
    removePopups();
    document.addEventListener('DOMContentLoaded', removePopups);

    // Watch for dynamically injected popups
    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        m.addedNodes.forEach(function(node) {
          if (node.nodeType !== 1) return;
          if (
            node.getAttribute && (
              node.getAttribute('iswrapper') === 'true' ||
              node.hasAttribute('justunologo') ||
              (node.id && node.id === 'inob') ||
              (node.className && typeof node.className === 'string' && node.className.includes('justuno')) ||
              (node.className && typeof node.className === 'string' && node.className.includes('klaviyo'))
            )
          ) {
            node.remove();
          }
        });
      });
    });
    observer.observe(document.body || document.documentElement, { childList: true, subtree: true });
  })();

  // ── FAQ accordion ──────────────────────────────────────────────────────────
  function arpToggleFAQ(btn) {
    var answer = btn.nextElementSibling;
    var icon   = btn.querySelector('.arp-faq-btn__icon');
    var isOpen = answer.classList.contains('arp-faq-answer--open');

    // Close all
    document.querySelectorAll('.arp-faq-answer').forEach(function(a) {
      a.classList.remove('arp-faq-answer--open');
    });
    document.querySelectorAll('.arp-faq-btn__icon').forEach(function(i) {
      i.textContent = '+';
      i.classList.remove('arp-faq-btn__icon--open');
    });

    // Open clicked (if it was closed)
    if (!isOpen) {
      answer.classList.add('arp-faq-answer--open');
      icon.textContent = '−';
      icon.classList.add('arp-faq-btn__icon--open');
    }
  }
</script>
