{% comment %}
  ── Open Graph image override ────────────────────────────────────────────────
  Shopify injects og:image via theme.liquid. We use a <style>-trick to
  suppress the existing tag and inject our own via document.head so it
  appears before any crawler-visible content.
  For a guaranteed server-side fix, edit theme.liquid directly (see INSTALL.md).
{% endcomment %}
<script>
  // Run synchronously in <head> context via Shopify section rendering.
  // Most social crawlers (iMessage link preview, Slack, WhatsApp) DO execute
  // inline scripts in sections when Shopify renders the full page HTML.
  document.addEventListener('DOMContentLoaded', function() {
    var heroUrl = '{{ "arp-hero-bundle.webp" | asset_url }}';
    var tags = [
      { property: 'og:image',        content: heroUrl },
      { property: 'og:image:width',  content: '1200' },
      { property: 'og:image:height', content: '630' },
      { name:     'twitter:image',   content: heroUrl },
      { name:     'twitter:card',    content: 'summary_large_image' }
    ];
    tags.forEach(function(t) {
      var sel = t.property
        ? 'meta[property="' + t.property + '"]'
        : 'meta[name="'     + t.name     + '"]';
      var el = document.querySelector(sel);
      if (!el) { el = document.createElement('meta'); document.head.appendChild(el); }
      if (t.property) el.setAttribute('property', t.property);
      else            el.setAttribute('name', t.name);
      el.setAttribute('content', t.content);
    });
  });
</script>

