  }

  .blog-result-title {
    color: var(--color-link, #234134);
    font-size: 14px;
    font-weight: normal;
    line-height: 1.4;
    display: block;
  }

  .blog-no-result-term {
    font-weight: bold;
    font-size: 16px;
    text-align: center;
    color: #234134;
    margin: 0 0 8px 0;
    padding: 0;
  }

  .blog-no-result-message {
    text-align: center;
    color: #969696;
    font-size: 14px;
    margin: 0;
    padding: 0;
  }

  .blog-search-link-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border-top: 1px solid #c1c1c1;
    padding: 8px;
  }

  .blog-search-link-wrapper.empty {
    flex-direction: column;
  }

  .blog-no-result-all-results {
    width: 100%;
    display: block;
    text-align: center;
    font-size: 16px;
    font-weight: 400;
    padding: 8px;
    color: #234134;
    text-decoration: none;
    transition: opacity 0.1s;
  }

  .blog-no-result-all-results:hover {
    opacity: 0.7;
  }

  @media (max-width: 767px) {
    .blog-search-results-wrapper {
      width: 100%;
    }

    .blog-search-results {
      padding: 12px;
      max-height: 300px;
    }

    .blog-search-section-title {
      font-size: 14px;
    }

    .blog-result-title {
      font-size: 13px;
    }

    .blog-no-result-term {
      font-size: 14px;
    }

    .blog-no-result-message {
      font-size: 13px;
    }

    .blog-no-result-all-results {
      font-size: 14px;
    }
  }
</style>

